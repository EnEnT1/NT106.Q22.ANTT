<Page
    x:Class="Healthcare.Client.UI.Auth.ForgotPasswordPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#0059BB"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#F8F9FA"/>
        <SolidColorBrush x:Key="SurfaceContainerLowBrush" Color="#F3F4F5"/>
        <SolidColorBrush x:Key="OnSurfaceVariantBrush" Color="#414754"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#46607F"/>
        <SolidColorBrush x:Key="OutlineVariantBrush" Color="#C1C6D7"/>

        <!-- TextBox Style -->
        <Style x:Key="AuthTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#F3F4F5"/>
            <Setter Property="Foreground" Value="#191C1D"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="44,13,16,13"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="MinHeight" Value="50"/>
            <Setter Property="PlaceholderForeground" Value="#9FA4B0"/>
        </Style>

        <!-- PasswordBox Style -->
        <Style x:Key="AuthPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="#F3F4F5"/>
            <Setter Property="Foreground" Value="#191C1D"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="44,13,44,13"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="MinHeight" Value="50"/>
        </Style>

        <!-- OTP TextBox Style -->
        <Style x:Key="OtpBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#F3F4F5"/>
            <Setter Property="Foreground" Value="#191C1D"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="MaxLength" Value="1"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0059BB"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Height="{TemplateBinding Height}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#0070EA"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#004493"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#C1C6D7"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource SurfaceBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Center" MaxWidth="440"
                        Margin="24,40,24,40" Spacing="0">

                <!-- LOGO -->
                <StackPanel Orientation="Horizontal" Spacing="10"
                            HorizontalAlignment="Center" Margin="0,0,0,36">
                    <Border Width="44" Height="44" CornerRadius="12"
                            Background="#0059BB">
                        <FontIcon Glyph="&#xEA37;" FontSize="24"
                                  Foreground="White"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Quản Lý Y Tế"
                               FontSize="22" FontWeight="ExtraBold"
                               Foreground="#0059BB"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- STEP INDICATOR -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                            Spacing="8" Margin="0,0,0,28">
                    <!-- Step 1 dot -->
                    <Border x:Name="Dot1" Width="32" Height="6"
                            CornerRadius="3" Background="#0059BB"/>
                    <!-- Step 2 dot -->
                    <Border x:Name="Dot2" Width="32" Height="6"
                            CornerRadius="3" Background="#C1C6D7"/>
                    <!-- Step 3 dot -->
                    <Border x:Name="Dot3" Width="32" Height="6"
                            CornerRadius="3" Background="#C1C6D7"/>
                </StackPanel>

                <!-- ═══════════════════════════════════════ -->
                <!-- STEP 1: Nhập số điện thoại             -->
                <!-- ═══════════════════════════════════════ -->
                <StackPanel x:Name="Step1Panel" Spacing="0">

                    <!-- Card -->
                    <Border Background="#FFFFFF" CornerRadius="16"
                            Padding="36,32" BorderBrush="#F0F1F2" BorderThickness="1">
                        <StackPanel Spacing="24">

                            <!-- Icon + Title -->
                            <StackPanel HorizontalAlignment="Center" Spacing="12">
                                <Border Width="64" Height="64" CornerRadius="32"
                                        Background="#EBF2FF" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE717;" FontSize="32"
                                              Foreground="#0059BB"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Quên mật khẩu"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="#191C1D"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Vui lòng nhập số điện thoại đã đăng ký để nhận mã xác thực OTP."
                                           FontSize="13" Foreground="#46607F"
                                           TextWrapping="Wrap" TextAlignment="Center"
                                           MaxWidth="280" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Phone Input -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="SỐ ĐIỆN THOẠI"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="#414754" CharacterSpacing="80"/>
                                <Grid>
                                    <TextBox x:Name="PhoneBox"
                                             Style="{StaticResource AuthTextBoxStyle}"
                                             PlaceholderText="09xx xxx xxx"/>
                                    <FontIcon Glyph="&#xE717;" FontSize="18"
                                              Foreground="#717786"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Margin="14,0,0,0"
                                              IsHitTestVisible="False"/>
                                </Grid>
                            </StackPanel>

                            <!-- Nút Gửi OTP -->
                            <Button Style="{StaticResource PrimaryButtonStyle}"
                                    Click="SendOtp_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Gửi mã OTP"
                                               FontSize="15" FontWeight="SemiBold"
                                               Foreground="White" VerticalAlignment="Center"/>
                                    <FontIcon Glyph="&#xE76C;" FontSize="16" Foreground="White"/>
                                </StackPanel>
                            </Button>

                            <!-- Quay lại -->
                            <Border BorderBrush="#EDEEEF" BorderThickness="0,1,0,0" Padding="0,16,0,0">
                                <HyperlinkButton HorizontalAlignment="Center"
                                                 Click="BackToLogin_Click"
                                                 Padding="0">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE76B;" FontSize="14" Foreground="#0059BB"/>
                                        <TextBlock Text="Quay lại Đăng nhập"
                                                   FontSize="13" FontWeight="Medium"
                                                   Foreground="#0059BB"/>
                                    </StackPanel>
                                </HyperlinkButton>
                            </Border>

                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ═══════════════════════════════════════ -->
                <!-- STEP 2: Nhập mã OTP                    -->
                <!-- ═══════════════════════════════════════ -->
                <StackPanel x:Name="Step2Panel" Spacing="0" Visibility="Collapsed">

                    <Border Background="#FFFFFF" CornerRadius="16"
                            Padding="36,32" BorderBrush="#F0F1F2" BorderThickness="1">
                        <StackPanel Spacing="24">

                            <!-- Icon + Title -->
                            <StackPanel HorizontalAlignment="Center" Spacing="12">
                                <Border Width="72" Height="72" CornerRadius="36"
                                        Background="#EBF2FF" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE8D7;" FontSize="36"
                                              Foreground="#0059BB"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Xác thực tài khoản"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="#191C1D"
                                           HorizontalAlignment="Center"/>
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <TextBlock Text="Mã OTP đã được gửi về số điện thoại"
                                               FontSize="13" Foreground="#46607F"
                                               TextAlignment="Center"/>
                                    <TextBlock x:Name="MaskedPhoneText"
                                               Text="09xx xxx xxx"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="#191C1D"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- OTP 6 ô -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center" Spacing="10">
                                <TextBox x:Name="Otp1" Style="{StaticResource OtpBoxStyle}"
                                         PlaceholderText="-" TextChanged="OtpBox_TextChanged"/>
                                <TextBox x:Name="Otp2" Style="{StaticResource OtpBoxStyle}"
                                         PlaceholderText="-" TextChanged="OtpBox_TextChanged"/>
                                <TextBox x:Name="Otp3" Style="{StaticResource OtpBoxStyle}"
                                         PlaceholderText="-" TextChanged="OtpBox_TextChanged"/>
                                <TextBox x:Name="Otp4" Style="{StaticResource OtpBoxStyle}"
                                         PlaceholderText="-" TextChanged="OtpBox_TextChanged"/>
                                <TextBox x:Name="Otp5" Style="{StaticResource OtpBoxStyle}"
                                         PlaceholderText="-" TextChanged="OtpBox_TextChanged"/>
                                <TextBox x:Name="Otp6" Style="{StaticResource OtpBoxStyle}"
                                         PlaceholderText="-" TextChanged="OtpBox_TextChanged"/>
                            </StackPanel>

                            <!-- Xác thực -->
                            <Button Style="{StaticResource PrimaryButtonStyle}"
                                    Click="VerifyOtp_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Xác thực ngay"
                                               FontSize="15" FontWeight="SemiBold"
                                               Foreground="White" VerticalAlignment="Center"/>
                                    <FontIcon Glyph="&#xE76C;" FontSize="16" Foreground="White"/>
                                </StackPanel>
                            </Button>

                            <!-- Gửi lại OTP -->
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="Bạn chưa nhận được mã?"
                                           FontSize="13" Foreground="#46607F"
                                           HorizontalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" Spacing="8"
                                            HorizontalAlignment="Center">
                                    <TextBlock x:Name="CountdownText"
                                               Text="Gửi lại mã sau 01:59"
                                               FontSize="13" Foreground="#9FA4B0"
                                               FontStyle="Italic"
                                               VerticalAlignment="Center"/>
                                    <HyperlinkButton x:Name="ResendBtn"
                                                     Content="Gửi lại ngay"
                                                     FontSize="13" FontWeight="Medium"
                                                     Foreground="#0059BB"
                                                     IsEnabled="False"
                                                     Padding="0"
                                                     Click="ResendOtp_Click"/>
                                </StackPanel>
                            </StackPanel>

                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ═══════════════════════════════════════ -->
                <!-- STEP 3: Tạo mật khẩu mới               -->
                <!-- ═══════════════════════════════════════ -->
                <StackPanel x:Name="Step3Panel" Spacing="0" Visibility="Collapsed">

                    <Border Background="#FFFFFF" CornerRadius="16"
                            Padding="36,32" BorderBrush="#F0F1F2" BorderThickness="1">
                        <StackPanel Spacing="24">

                            <!-- Icon + Title -->
                            <StackPanel HorizontalAlignment="Center" Spacing="12">
                                <Border Width="64" Height="64" CornerRadius="14"
                                        Background="#D8E2FF" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE72E;" FontSize="32"
                                              Foreground="#0059BB"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Thiết lập mật khẩu mới"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="#191C1D"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Vui lòng nhập mật khẩu mới cho tài khoản của bạn."
                                           FontSize="13" Foreground="#46607F"
                                           TextWrapping="Wrap" TextAlignment="Center"
                                           MaxWidth="280" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Mật khẩu mới -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="MẬT KHẨU MỚI"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="#414754" CharacterSpacing="80"/>
                                <Grid>
                                    <PasswordBox x:Name="NewPasswordBox"
                                                 Style="{StaticResource AuthPasswordBoxStyle}"
                                                 PlaceholderText="••••••••"
                                                 PasswordRevealMode="Hidden"/>
                                    <FontIcon Glyph="&#xE72E;" FontSize="18" Foreground="#717786"
                                              HorizontalAlignment="Left" VerticalAlignment="Center"
                                              Margin="14,0,0,0" IsHitTestVisible="False"/>
                                    <Button x:Name="RevealNewBtn"
                                            HorizontalAlignment="Right" VerticalAlignment="Center"
                                            Background="Transparent" BorderThickness="0"
                                            Padding="8" Margin="0,0,6,0"
                                            Click="RevealNew_Click">
                                        <FontIcon x:Name="RevealNewIcon"
                                                  Glyph="&#xE7B3;" FontSize="16" Foreground="#717786"/>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <!-- Xác nhận mật khẩu -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="XÁC NHẬN MẬT KHẨU MỚI"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="#414754" CharacterSpacing="80"/>
                                <Grid>
                                    <PasswordBox x:Name="ConfirmNewPasswordBox"
                                                 Style="{StaticResource AuthPasswordBoxStyle}"
                                                 PlaceholderText="••••••••"
                                                 PasswordRevealMode="Hidden"/>
                                    <FontIcon Glyph="&#xE72E;" FontSize="18" Foreground="#717786"
                                              HorizontalAlignment="Left" VerticalAlignment="Center"
                                              Margin="14,0,0,0" IsHitTestVisible="False"/>
                                    <Button x:Name="RevealConfirmBtn"
                                            HorizontalAlignment="Right" VerticalAlignment="Center"
                                            Background="Transparent" BorderThickness="0"
                                            Padding="8" Margin="0,0,6,0"
                                            Click="RevealConfirm_Click">
                                        <FontIcon x:Name="RevealConfirmIcon"
                                                  Glyph="&#xE7B3;" FontSize="16" Foreground="#717786"/>
                                    </Button>
                                </Grid>
                                <TextBlock Text="Gợi ý: Mật khẩu nên chứa ít nhất 8 ký tự, bao gồm chữ cái và số."
                                           FontSize="11" Foreground="#9FA4B0"
                                           FontStyle="Italic" TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Cập nhật -->
                            <Button Style="{StaticResource PrimaryButtonStyle}"
                                    Click="UpdatePassword_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="Cập nhật mật khẩu"
                                               FontSize="15" FontWeight="SemiBold"
                                               Foreground="White" VerticalAlignment="Center"/>
                                    <FontIcon Glyph="&#xE76C;" FontSize="16" Foreground="White"/>
                                </StackPanel>
                            </Button>

                            <!-- Quay lại đăng nhập -->
                            <Border BorderBrush="#EDEEEF" BorderThickness="0,1,0,0" Padding="0,16,0,0">
                                <HyperlinkButton HorizontalAlignment="Center"
                                                 Click="BackToLogin_Click" Padding="0">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE76B;" FontSize="14" Foreground="#0059BB"/>
                                        <TextBlock Text="Quay lại Đăng nhập"
                                                   FontSize="13" FontWeight="Medium"
                                                   Foreground="#0059BB"/>
                                    </StackPanel>
                                </HyperlinkButton>
                            </Border>

                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- FOOTER -->
                <TextBlock Text="© 2024 HỆ THỐNG QUẢN LÝ Y TẾ DIGITAL SANCTUARY"
                           FontSize="10" FontWeight="Medium"
                           Foreground="#9FA4B0" CharacterSpacing="60"
                           HorizontalAlignment="Center"
                           Margin="0,28,0,0"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
