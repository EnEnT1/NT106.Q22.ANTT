<Page
    x:Class="Healthcare.Client.UI.Auth.RegisterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#0059BB"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#F8F9FA"/>
        <SolidColorBrush x:Key="SurfaceContainerLowBrush" Color="#F3F4F5"/>
        <SolidColorBrush x:Key="OnSurfaceBrush" Color="#191C1D"/>
        <SolidColorBrush x:Key="OnSurfaceVariantBrush" Color="#414754"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#46607F"/>
        <SolidColorBrush x:Key="OutlineBrush" Color="#717786"/>
        <SolidColorBrush x:Key="OutlineVariantBrush" Color="#C1C6D7"/>

        <!-- TextBox Style chung -->
        <Style x:Key="AuthTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#F3F4F5"/>
            <Setter Property="Foreground" Value="#191C1D"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="44,13,16,13"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="MinHeight" Value="50"/>
            <Setter Property="PlaceholderForeground" Value="#9FA4B0"/>
        </Style>

        <!-- PasswordBox Style chung -->
        <Style x:Key="AuthPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Background" Value="#F3F4F5"/>
            <Setter Property="Foreground" Value="#191C1D"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="44,13,44,13"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="MinHeight" Value="50"/>
        </Style>

        <!-- Primary Button -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0059BB"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Height="{TemplateBinding Height}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#0070EA"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#004493"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="RootBorder" Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#C1C6D7"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <!-- Toàn trang nền xám nhạt -->
    <Grid Background="{StaticResource SurfaceBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Center" MaxWidth="480" Margin="24,0,24,40">

                <!-- ══════════════════════════════════ -->
                <!-- HEADER                             -->
                <!-- ══════════════════════════════════ -->
                <Border Background="#F8F9FA" Padding="32,14,32,14" Margin="-24,0,-24,0">
                    <Grid>
                        <!-- Logo + Tên hệ thống -->
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xEA37;"
                                      FontSize="22"
                                      Foreground="#0059BB"/>
                            <TextBlock Text="Quản Lý Y Tế"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#1A3A6B"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Hỗ trợ -->
                        <HyperlinkButton Content="Hỗ trợ"
                                         HorizontalAlignment="Right"
                                         FontSize="13"
                                         Foreground="#46607F"
                                         Padding="0"/>
                    </Grid>
                </Border>

                <!-- ══════════════════════════════════ -->
                <!-- BRANDING + TITLE                   -->
                <!-- ══════════════════════════════════ -->
                <StackPanel HorizontalAlignment="Center" Spacing="8" Margin="0,36,0,28">
                    <!-- Icon tròn -->
                    <Border Width="64" Height="64"
                            CornerRadius="32"
                            Background="#EBF2FF"
                            HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE95E;"
                                  FontSize="34"
                                  Foreground="#0059BB"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Tạo tài khoản mới"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#191C1D"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Bắt đầu quản lý hồ sơ sức khỏe của bạn ngay hôm nay"
                               FontSize="14"
                               Foreground="#46607F"
                               FontWeight="Medium"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>
                </StackPanel>

                <!-- ══════════════════════════════════ -->
                <!-- CARD FORM                          -->
                <!-- ══════════════════════════════════ -->
                <Border Background="#FFFFFF"
                        CornerRadius="16"
                        Padding="36,32,36,32"
                        BorderBrush="#F0F1F2"
                        BorderThickness="1">
                    <StackPanel Spacing="20">

                        <!-- Họ và tên -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="HỌ VÀ TÊN NGƯỜI DÙNG"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="#414754" CharacterSpacing="80"/>
                            <Grid>
                                <TextBox x:Name="FullNameBox"
                                         Style="{StaticResource AuthTextBoxStyle}"
                                         PlaceholderText="Nguyễn Văn A"/>
                                <FontIcon Glyph="&#xE77B;" FontSize="18" Foreground="#717786"
                                          HorizontalAlignment="Left" VerticalAlignment="Center"
                                          Margin="14,0,0,0" IsHitTestVisible="False"/>
                            </Grid>
                        </StackPanel>

                        <!-- Email + SĐT (2 cột) -->
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Email -->
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="EMAIL"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="#414754" CharacterSpacing="80"/>
                                <Grid>
                                    <TextBox x:Name="EmailBox"
                                             Style="{StaticResource AuthTextBoxStyle}"
                                             PlaceholderText="vi-du@email.com"/>
                                    <FontIcon Glyph="&#xE715;" FontSize="18" Foreground="#717786"
                                              HorizontalAlignment="Left" VerticalAlignment="Center"
                                              Margin="14,0,0,0" IsHitTestVisible="False"/>
                                </Grid>
                            </StackPanel>

                            <!-- Số điện thoại -->
                            <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Text="SỐ ĐIỆN THOẠI"
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="#414754" CharacterSpacing="80"/>
                                <Grid>
                                    <TextBox x:Name="PhoneBox"
                                             Style="{StaticResource AuthTextBoxStyle}"
                                             PlaceholderText="0901 234 567"/>
                                    <FontIcon Glyph="&#xE717;" FontSize="18" Foreground="#717786"
                                              HorizontalAlignment="Left" VerticalAlignment="Center"
                                              Margin="14,0,0,0" IsHitTestVisible="False"/>
                                </Grid>
                            </StackPanel>
                        </Grid>

                        <!-- Mật khẩu -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="MẬT KHẨU"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="#414754" CharacterSpacing="80"/>
                            <Grid>
                                <PasswordBox x:Name="PasswordBox"
                                             Style="{StaticResource AuthPasswordBoxStyle}"
                                             PlaceholderText="••••••••"
                                             PasswordRevealMode="Hidden"/>
                                <FontIcon Glyph="&#xE72E;" FontSize="18" Foreground="#717786"
                                          HorizontalAlignment="Left" VerticalAlignment="Center"
                                          Margin="14,0,0,0" IsHitTestVisible="False"/>
                                <Button x:Name="RevealPasswordBtn"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Background="Transparent" BorderThickness="0"
                                        Padding="8" Margin="0,0,6,0"
                                        Click="RevealPassword_Click">
                                    <FontIcon x:Name="RevealPasswordIcon"
                                              Glyph="&#xE7B3;" FontSize="16" Foreground="#717786"/>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <!-- Xác nhận mật khẩu -->
                        <StackPanel Spacing="6">
                            <TextBlock Text="XÁC NHẬN MẬT KHẨU"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="#414754" CharacterSpacing="80"/>
                            <Grid>
                                <PasswordBox x:Name="ConfirmPasswordBox"
                                             Style="{StaticResource AuthPasswordBoxStyle}"
                                             PlaceholderText="••••••••"
                                             PasswordRevealMode="Hidden"/>
                                <FontIcon Glyph="&#xE72E;" FontSize="18" Foreground="#717786"
                                          HorizontalAlignment="Left" VerticalAlignment="Center"
                                          Margin="14,0,0,0" IsHitTestVisible="False"/>
                                <Button x:Name="RevealConfirmBtn"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Background="Transparent" BorderThickness="0"
                                        Padding="8" Margin="0,0,6,0"
                                        Click="RevealConfirm_Click">
                                    <FontIcon x:Name="RevealConfirmIcon"
                                              Glyph="&#xE7B3;" FontSize="16" Foreground="#717786"/>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <!-- Checkbox Điều khoản -->
                        <CheckBox x:Name="TermsCheckBox" Margin="0,4,0,0">
                            <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#46607F">
                                <Run Text="Tôi đồng ý với các "/>
                                <Hyperlink NavigateUri="#" Foreground="#0059BB">Điều khoản sử dụng</Hyperlink>
                                <Run Text=" và "/>
                                <Hyperlink NavigateUri="#" Foreground="#0059BB">Chính sách bảo mật</Hyperlink>
                                <Run Text=" của Digital Sanctuary."/>
                            </TextBlock>
                        </CheckBox>

                        <!-- Nút Đăng ký -->
                        <Button x:Name="RegisterBtn"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="RegisterBtn_Click"
                                Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Đăng ký ngay"
                                           FontSize="15" FontWeight="Bold"
                                           Foreground="White" VerticalAlignment="Center"/>
                                <FontIcon Glyph="&#xE76C;"
                                          FontSize="16" Foreground="White"/>
                            </StackPanel>
                        </Button>

                        <!-- Đã có tài khoản -->
                        <Border BorderBrush="#EDEEEF" BorderThickness="0,1,0,0" Padding="0,20,0,0">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="Bạn đã có tài khoản?"
                                           FontSize="13" Foreground="#46607F"
                                           VerticalAlignment="Center"/>
                                <HyperlinkButton Content="Đăng nhập"
                                                 FontSize="13" FontWeight="Bold"
                                                 Foreground="#0059BB"
                                                 Padding="4,0"
                                                 Click="GoToLogin_Click"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- ══════════════════════════════════ -->
                <!-- TRUST INDICATORS                   -->
                <!-- ══════════════════════════════════ -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="32" Margin="0,24,0,0"
                            Opacity="0.5">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE72E;" FontSize="16" Foreground="#717786"/>
                        <TextBlock Text="BẢO MẬT SSL"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#717786" CharacterSpacing="120"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE8D7;" FontSize="16" Foreground="#717786"/>
                        <TextBlock Text="MÃ HÓA DỮ LIỆU"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#717786" CharacterSpacing="120"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- ══════════════════════════════════ -->
                <!-- FOOTER                             -->
                <!-- ══════════════════════════════════ -->
                <Border BorderBrush="#EDEEEF" BorderThickness="0,1,0,0" Margin="0,32,0,0" Padding="0,24,0,0">
                    <StackPanel Spacing="12">
                        <TextBlock Text="© 2024 Hệ Thống Quản Lý Y Tế Digital Sanctuary. Bảo lưu mọi quyền."
                                   FontSize="11" Foreground="#9FA4B0"
                                   HorizontalAlignment="Center" FontWeight="Light"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20">
                            <HyperlinkButton Content="Điều khoản sử dụng" FontSize="11" Foreground="#9FA4B0" Padding="0"/>
                            <HyperlinkButton Content="Chính sách bảo mật" FontSize="11" Foreground="#9FA4B0" Padding="0"/>
                            <HyperlinkButton Content="Liên hệ" FontSize="11" Foreground="#9FA4B0" Padding="0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
