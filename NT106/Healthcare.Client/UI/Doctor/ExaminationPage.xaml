<Page
    x:Class="Healthcare.Client.UI.Doctor.ExaminationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:Healthcare.Client.UI.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource AppBackdropGradientBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="7*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDE: DOMINANT VIDEO AREA -->
        <Grid Grid.Column="0" Margin="20">
            <!-- Video call control -->
            <Border CornerRadius="20" Background="Black" Shadow="{StaticResource HealthcareThemeShadow}">
                <components:VideoCallControl x:Name="VideoCall"
                                             CallStarted="VideoCall_CallStarted"
                                             CallEnded="VideoCall_CallEnded"
                                             Visibility="Visible"/>
            </Border>

            <!-- STT Toast: hiện text vừa nhận được, tự ẩn sau 4 giây -->
            <Border x:Name="SttToast"
                    Visibility="Collapsed"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Stretch"
                    Margin="20,0,140,28"
                    Background="#CC1E293B"
                    CornerRadius="14"
                    Padding="16,10">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon Glyph="&#xE720;" FontSize="14" Foreground="#7DD3FC" VerticalAlignment="Center"/>
                    <TextBlock x:Name="SttToastText"
                               Text=""
                               FontSize="13"
                               Foreground="White"
                               TextWrapping="Wrap"
                               MaxLines="3"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Floating Mic Button (bottom-right of video) -->
            <Button x:Name="BtnMicFloat"
                    Click="BtnMic_Click"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Right"
                    Margin="0,0,20,20"
                    Width="56" Height="56"
                    Padding="0"
                    Background="#CC0F172A"
                    Foreground="White"
                    BorderThickness="0"
                    CornerRadius="28"
                    ToolTipService.ToolTip="Nhấn để ghi âm chẩn đoán">
                <Grid>
                    <FontIcon x:Name="MicIconFloat" Glyph="&#xE720;" FontSize="22"/>
                    <!-- Vòng tròn đỏ nhấp nháy khi đang ghi -->
                    <Ellipse x:Name="RecordingRing"
                             Width="56" Height="56"
                             Stroke="#EF4444"
                             StrokeThickness="3"
                             Opacity="0"/>
                </Grid>
            </Button>
        </Grid>

        <!-- RIGHT SIDE: INFORMATION & TOOLS PANEL (Stacked UI) -->
        <Grid Grid.Column="1" Margin="0,20,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Navigation Tabs -->
            <Border Grid.Row="0" Background="White" CornerRadius="16" Padding="8" Margin="0,0,0,16" Shadow="{StaticResource HealthcareThemeShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Click="BtnNav_Click" Tag="info" Style="{StaticResource DefaultButtonStyle}" HorizontalAlignment="Stretch" Padding="0,10">
                        <FontIcon x:Name="IconInfo" Glyph="&#xE77B;" FontSize="20" Foreground="#0284C7"/>
                    </Button>
                    <Button Grid.Column="1" Click="BtnNav_Click" Tag="chat" Style="{StaticResource DefaultButtonStyle}" HorizontalAlignment="Stretch" Padding="0,10">
                        <FontIcon x:Name="IconChat" Glyph="&#xE8F2;" FontSize="20" Foreground="#64748B"/>
                    </Button>
                    <Button Grid.Column="2" Click="BtnNav_Click" Tag="notes" Style="{StaticResource DefaultButtonStyle}" HorizontalAlignment="Stretch" Padding="0,10">
                        <FontIcon x:Name="IconNotes" Glyph="&#xE70B;" FontSize="20" Foreground="#64748B"/>
                    </Button>
                    <Button Grid.Column="3" Click="BtnNav_Click" Tag="prescription" Style="{StaticResource DefaultButtonStyle}" HorizontalAlignment="Stretch" Padding="0,10">
                        <FontIcon x:Name="IconPrescription" Glyph="&#xE950;" FontSize="20" Foreground="#64748B"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Panels -->
            <Grid Grid.Row="1">
                <!-- Info Panel -->
                <Border x:Name="InfoPanel" Visibility="Visible" Background="White" CornerRadius="20" Padding="24" Shadow="{StaticResource HealthcareThemeShadow}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="24">
                            <TextBlock Text="Thông tin bệnh nhân" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                            
                            <StackPanel HorizontalAlignment="Center" Spacing="12">
                                <PersonPicture x:Name="PatientAvatar" Width="120" Height="120" Background="#F1F5F9"/>
                                <TextBlock x:Name="TxtPatientName" Text="Đang tải..." FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <Border Background="#EEF2FF" CornerRadius="20" Padding="14,6" HorizontalAlignment="Center">
                                    <TextBlock x:Name="TxtCondition" Text="Duy trì ổn định" FontSize="12" FontWeight="Bold" Foreground="#4F46E5"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Spacing="16">
                                <Grid>
                                    <TextBlock Text="Tuổi / Giới tính" Foreground="#64748B" FontSize="14"/>
                                    <TextBlock x:Name="TxtPatientMeta" Text="--" FontWeight="SemiBold" HorizontalAlignment="Right" FontSize="14"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="Cân nặng / Chiều cao" Foreground="#64748B" FontSize="14"/>
                                    <TextBlock Text="65kg / 170cm" FontWeight="SemiBold" HorizontalAlignment="Right" FontSize="14"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="Nhóm máu" Foreground="#64748B" FontSize="14"/>
                                    <TextBlock Text="O+" FontWeight="Bold" Foreground="#DC2626" HorizontalAlignment="Right" FontSize="14"/>
                                </Grid>
                            </StackPanel>

                            <Button x:Name="BtnFinish" Click="BtnFinish_Click" HorizontalAlignment="Stretch" Margin="0,12,0,0" Padding="0,14" Background="#EF4444" Foreground="White" CornerRadius="12" BorderThickness="0" FontWeight="Bold">
                                <TextBlock Text="Kết thúc phiên khám"/>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Chat Panel -->
                <Border x:Name="ChatPanel" Visibility="Collapsed" Background="White" CornerRadius="20" Shadow="{StaticResource HealthcareThemeShadow}">
                    <components:ChatControl x:Name="Chat"/>
                </Border>

                <!-- Notes Panel -->
                <Border x:Name="NotesPanel" Visibility="Collapsed" Background="White" CornerRadius="20" Padding="24" Shadow="{StaticResource HealthcareThemeShadow}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="20">
                            <TextBlock Text="Ghi chú &amp; Chẩn đoán" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>

                            <TextBox x:Name="DiagnosisBox"
                                     Header="Chẩn đoán xác định"
                                     PlaceholderText="Nhập hoặc đọc chẩn đoán bằng giọng nói..."
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="100"/>

                            <StackPanel Spacing="12">
                                <Grid>
                                    <TextBlock Text="Ghi chú nhanh" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <Button Click="BtnAddNote_Click" HorizontalAlignment="Right" Content="Thêm ghi chú" FontSize="12" Padding="12,6" Background="#F0F9FF" Foreground="#0284C7" BorderThickness="0" CornerRadius="8"/>
                                </Grid>
                                <StackPanel x:Name="QuickNotesList" Spacing="8"/>
                            </StackPanel>

                            <Button Click="BtnSaveNotes_Click" Background="#16A34A" Foreground="White" CornerRadius="12" Padding="16" HorizontalAlignment="Stretch" Margin="0,12,0,0" BorderThickness="0" FontWeight="SemiBold">
                                <TextBlock Text="Lưu hồ sơ khám"/>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Prescription Panel -->
                <Border x:Name="PrescriptionPanel" Visibility="Collapsed" Background="White" CornerRadius="20" Padding="24" Shadow="{StaticResource HealthcareThemeShadow}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="20">
                            <Grid>
                                <TextBlock Text="Đơn thuốc" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                                <Button Click="BtnAddMedicine_Click" HorizontalAlignment="Right" Content="Thêm thuốc" Padding="12,6" Background="#F0FDF4" Foreground="#16A34A" BorderThickness="0" CornerRadius="8"/>
                            </Grid>
                            <StackPanel x:Name="PrescriptionList" Spacing="8"/>
                            
                            <TextBlock Text="Ghi chú đơn thuốc" FontSize="14" FontWeight="Bold" Margin="0,12,0,0"/>
                            <TextBox PlaceholderText="Dặn dò bệnh nhân về liều dùng..." AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>