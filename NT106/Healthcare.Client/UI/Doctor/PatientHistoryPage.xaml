                                        CornerRadius="8"
                                        Padding="8,4"
                                        FontSize="14"
                                        Foreground="#94A3B8"/>
                            </Grid>

                            <!-- Timeline Items -->
                            <!--
                                TODO [SUPABASE]: Thay toàn bộ StackPanel tĩnh (3 visit cứng) này
