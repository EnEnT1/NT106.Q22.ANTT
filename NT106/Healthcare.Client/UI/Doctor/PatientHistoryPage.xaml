                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ── Save Button ── -->
                    <StackPanel HorizontalAlignment="Right" Margin="0,8,0,32">
                        <Button x:Name="SaveButton"
                                Content="Lưu thông tin hồ sơ"
