                                  - Summary       : tóm tắt kết quả khám
                                  - IsLatest      : true → chấm xanh; false → chấm xám
                            -->
                            <StackPanel Spacing="0">

                                <!-- Visit 1 - Today - TODO [SUPABASE]: xóa item cứng khi dùng ItemsRepeater -->
                                <Grid Margin="0,0,0,28">
