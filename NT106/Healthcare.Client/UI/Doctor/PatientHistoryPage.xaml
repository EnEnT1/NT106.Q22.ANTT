                                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7BA;"
                                                  FontSize="16" Foreground="#D97706"
                                                  VerticalAlignment="Center"/>
                                        <TextBlock FontSize="11" FontWeight="Bold"
                                                   Foreground="#92400E"
                                                   VerticalAlignment="Center">
                                            <Run Text="NGUY CƠ CAO: " FontWeight="Black" FontSize="9"
