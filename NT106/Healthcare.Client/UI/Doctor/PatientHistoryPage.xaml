<Page
    x:Class="Healthcare.Client.UI.Doctor.PatientHistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#0059BB"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="ExtraBold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="CharacterSpacing" Value="100"/>
        </Style>

        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="ExtraBold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>
    </Page.Resources>

    <Page.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F0F9FF" Offset="0"/>
            <GradientStop Color="#EEF2FF" Offset="0.45"/>
            <GradientStop Color="#FFFFFF" Offset="1"/>
        </LinearGradientBrush>
    </Page.Background>

    <Grid Padding="24" ColumnSpacing="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: PATIENT LIST -->
        <Border Grid.Column="0"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="18"
                Padding="18">

            <Grid RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock Text="DANH SÁCH BỆNH NHÂN"
                               FontSize="11"
                               FontWeight="ExtraBold"
                               CharacterSpacing="140"
                               Foreground="#64748B"/>

                    <TextBlock x:Name="TxtPatientCount"
                               Text="Đang tải..."
                               FontSize="22"
                               FontWeight="ExtraBold"
                               Foreground="#1E293B"/>
                </StackPanel>

                <TextBox Grid.Row="1"
                         x:Name="SearchPatientBox"
                         PlaceholderText="Tìm theo tên, mã bệnh nhân..."
                         TextChanged="SearchPatientBox_TextChanged"/>

                <ListView Grid.Row="2"
                          x:Name="PatientListView"
                          SelectionMode="Single"
                          IsItemClickEnabled="True"
                          ItemClick="PatientListView_ItemClick">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,10"/>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#F8FAFC"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="14">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Width="44"
                                            Height="44"
                                            CornerRadius="22"
                                            Background="{Binding AvatarBackground}">
                                        <TextBlock Text="{Binding Initials}"
                                                   FontSize="14"
                                                   FontWeight="ExtraBold"
                                                   Foreground="{Binding AvatarForeground}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Text="{Binding FullName}"
                                                   FontSize="14"
                                                   FontWeight="ExtraBold"
                                                   Foreground="#1E293B"/>

                                        <TextBlock Text="{Binding PatientCode}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="#64748B"/>

                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Border Background="{Binding StatusBackground}"
                                                    CornerRadius="10"
                                                    Padding="8,3">
                                                <TextBlock Text="{Binding StatusText}"
                                                           FontSize="10"
                                                           FontWeight="Bold"
                                                           Foreground="{Binding StatusForeground}"/>
                                            </Border>

                                            <TextBlock Text="{Binding VisitCountText}"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       Foreground="#64748B"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- CENTER: PATIENT DETAIL -->
        <Grid Grid.Column="1">
            <Border x:Name="EmptyStatePanel"
                    Background="White"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="32"
                    Visibility="Visible">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="12">
                    <FontIcon Glyph="&#xE77B;"
                              FontSize="52"
                              Foreground="#94A3B8"
                              HorizontalAlignment="Center"/>

                    <TextBlock Text="Chọn một bệnh nhân"
                               FontSize="24"
                               FontWeight="ExtraBold"
                               Foreground="#1E293B"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Bấm vào bệnh nhân ở danh sách bên trái để xem hồ sơ, dấu hiệu sinh tồn, dị ứng, tiền sử bệnh và lịch sử thăm khám."
                               FontSize="13"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="#64748B"
                               MaxWidth="480"/>
                </StackPanel>
            </Border>

            <ScrollViewer x:Name="PatientDetailScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="Collapsed">
                <StackPanel Spacing="20">

                    <!-- HEADER -->
                    <Border Style="{StaticResource CardStyle}">
                        <Grid ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Grid Width="64" Height="64">
                                <Ellipse Fill="#E2E8F0"/>
                                <FontIcon FontFamily="Segoe MDL2 Assets"
                                          Glyph="&#xE77B;"
                                          FontSize="28"
                                          Foreground="#94A3B8"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Grid>

                            <StackPanel Grid.Column="1" Spacing="10">
                                <StackPanel>
                                    <TextBlock Text="HỒ SƠ BỆNH NHÂN"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="#94A3B8"
                                               CharacterSpacing="150"/>
                                    <TextBlock x:Name="TxtHeaderPatientName"
                                               Text="Chưa chọn bệnh nhân"
                                               FontSize="22"
                                               FontWeight="ExtraBold"
                                               Foreground="#1E293B"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="28">
                                    <StackPanel>
                                        <TextBlock Text="MÃ BN" Style="{StaticResource LabelStyle}"/>
                                        <TextBlock x:Name="TxtPatientCode"
                                                   Text="#N/A"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="#334155"/>
                                    </StackPanel>

                                    <StackPanel>
                                        <TextBlock Text="CÂN NẶNG" Style="{StaticResource LabelStyle}"/>
                                        <TextBlock x:Name="TxtHeaderWeight"
                                                   Text="N/A"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="#334155"/>
                                    </StackPanel>

                                    <StackPanel>
                                        <TextBlock Text="TRẠNG THÁI" Style="{StaticResource LabelStyle}"/>
                                        <Border Background="#DCFCE7" CornerRadius="4" Padding="8,3">
                                            <TextBlock x:Name="TxtPatientStatus"
                                                       Text="Chưa rõ"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       Foreground="#15803D"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <Border Grid.Column="2"
                                    Background="#FEF2F2"
                                    BorderBrush="#FECACA"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="14,10"
                                    VerticalAlignment="Center">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="CẢNH BÁO DỊ ỨNG"
                                               FontSize="9"
                                               FontWeight="Bold"
                                               Foreground="#DC2626"
                                               CharacterSpacing="120"/>
                                    <TextBlock x:Name="TxtAllergyAlertSummary"
                                               Text="Không có dữ liệu"
                                               FontSize="13"
                                               FontWeight="ExtraBold"
                                               Foreground="#7F1D1D"
                                               TextWrapping="Wrap"
                                               MaxWidth="220"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- VITALS + ALLERGIES -->
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                            <StackPanel Spacing="16">
                                <TextBlock Text="1. DẤU HIỆU SINH TỒN"
                                           Style="{StaticResource SectionTitleStyle}"/>

                                <Grid RowSpacing="16" ColumnSpacing="16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <TextBlock Text="CHIỀU CAO" Style="{StaticResource LabelStyle}"/>
                                        <TextBlock x:Name="TxtHeight" Text="-" Style="{StaticResource ValueStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="1">
                                        <TextBlock Text="CÂN NẶNG" Style="{StaticResource LabelStyle}"/>
                                        <TextBlock x:Name="TxtWeight" Text="-" Style="{StaticResource ValueStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="2">
                                        <TextBlock Text="BMI" Style="{StaticResource LabelStyle}"/>
                                        <TextBlock x:Name="TxtBmi" Text="-" Style="{StaticResource ValueStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0">
                                        <TextBlock Text="HUYẾT ÁP" Style="{StaticResource LabelStyle}"/>
                                        <TextBlock x:Name="TxtBloodPressure" Text="-" Style="{StaticResource ValueStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="1">
                                        <TextBlock Text="NHỊP TIM" Style="{StaticResource LabelStyle}"/>
                                        <TextBlock x:Name="TxtHeartRate" Text="-" Style="{StaticResource ValueStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="2">
                                        <TextBlock Text="NHIỆT ĐỘ" Style="{StaticResource LabelStyle}"/>
                                        <TextBlock x:Name="TxtTemperature" Text="-" Style="{StaticResource ValueStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                            <StackPanel Spacing="16">
                                <TextBlock Text="2. TIỀN SỬ DỊ ỨNG"
                                           Style="{StaticResource SectionTitleStyle}"/>
                                <StackPanel x:Name="AllergyList" Spacing="10"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- MEDICAL HISTORY -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel Spacing="16">
                            <TextBlock Text="3. TIỀN SỬ BỆNH LÝ CÁ NHÂN"
                                       Style="{StaticResource SectionTitleStyle}"/>

                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="#EFF6FF"
                                        BorderBrush="#BFDBFE"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="16">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="BỆNH NỀN"
                                                   FontSize="11"
                                                   FontWeight="Black"
                                                   Foreground="#1E3A8A"/>
                                        <TextBlock x:Name="TxtChronicName"
                                                   Text="Chưa cập nhật"
                                                   FontSize="15"
                                                   FontWeight="ExtraBold"
                                                   Foreground="#1E293B"/>
                                        <TextBlock x:Name="TxtChronicYear"
                                                   Text="Phát hiện từ: --"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   Foreground="#2563EB"/>
                                        <TextBlock x:Name="TxtChronicNote"
                                                   Text="Không có ghi chú"
                                                   FontSize="11"
                                                   Foreground="#64748B"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1"
                                        Background="#EEF2FF"
                                        BorderBrush="#C7D2FE"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="16">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="PHẪU THUẬT"
                                                   FontSize="11"
                                                   FontWeight="Black"
                                                   Foreground="#3730A3"/>
                                        <TextBlock x:Name="TxtSurgeryName"
                                                   Text="Chưa cập nhật"
                                                   FontSize="15"
                                                   FontWeight="ExtraBold"
                                                   Foreground="#1E293B"/>
                                        <TextBlock x:Name="TxtSurgeryYear"
                                                   Text="Năm thực hiện: --"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   Foreground="#4F46E5"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2"
                                        Background="#ECFDF5"
                                        BorderBrush="#A7F3D0"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="16">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="TIÊM CHỦNG"
                                                   FontSize="11"
                                                   FontWeight="Black"
                                                   Foreground="#064E3B"/>
                                        <TextBlock x:Name="TxtVaccinationName"
                                                   Text="Chưa cập nhật"
                                                   FontSize="15"
                                                   FontWeight="ExtraBold"
                                                   Foreground="#1E293B"/>
                                        <TextBlock x:Name="TxtVaccinationYear"
                                                   Text="Gần nhất: --"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   Foreground="#059669"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- MEDICATION -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel Spacing="16">
                            <TextBlock Text="4. TIỀN SỬ DÙNG THUỐC"
                                       Style="{StaticResource SectionTitleStyle}"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="TÊN THUỐC" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="TxtMedName" Text="Chưa cập nhật" FontSize="13" FontWeight="ExtraBold"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="LIỀU LƯỢNG" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="TxtMedDosage" Text="Chưa cập nhật" FontSize="12"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Text="THỜI GIAN" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="TxtMedPeriod" Text="--" FontSize="11" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- FAMILY + LIFESTYLE -->
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                            <StackPanel Spacing="16">
                                <TextBlock Text="5. TIỀN SỬ GIA ĐÌNH"
                                           Style="{StaticResource SectionTitleStyle}"/>

                                <StackPanel Spacing="12">
                                    <Border Background="#EFF6FF" CornerRadius="12" Padding="14">
                                        <StackPanel>
                                            <TextBlock Text="BỐ ĐẺ" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock x:Name="TxtFatherCondition"
                                                       Text="Chưa cập nhật"
                                                       FontSize="13"
                                                       FontWeight="ExtraBold"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#FFF1F2" CornerRadius="12" Padding="14">
                                        <StackPanel>
                                            <TextBlock Text="MẸ ĐẺ" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock x:Name="TxtMotherCondition"
                                                       Text="Chưa cập nhật"
                                                       FontSize="13"
                                                       FontWeight="ExtraBold"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                            <StackPanel Spacing="16">
                                <TextBlock Text="6. LỐI SỐNG"
                                           Style="{StaticResource SectionTitleStyle}"/>

                                <Grid RowSpacing="8" ColumnSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Row="0" Grid.Column="0" Background="White" CornerRadius="12" BorderBrush="#F1F5F9" BorderThickness="1" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="THUỐC LÁ" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock x:Name="TxtSmoking" Text="Chưa cập nhật" FontSize="10" Foreground="#64748B"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="0" Grid.Column="1" Background="White" CornerRadius="12" BorderBrush="#F1F5F9" BorderThickness="1" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="RƯỢU BIA" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock x:Name="TxtAlcohol" Text="Chưa cập nhật" FontSize="10" Foreground="#64748B"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1" Grid.Column="0" Background="White" CornerRadius="12" BorderBrush="#F1F5F9" BorderThickness="1" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="VẬN ĐỘNG" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock x:Name="TxtExercise" Text="Chưa cập nhật" FontSize="10" Foreground="#64748B"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1" Grid.Column="1" Background="White" CornerRadius="12" BorderBrush="#F1F5F9" BorderThickness="1" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="GIẤC NGỦ" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock x:Name="TxtSleep" Text="Chưa cập nhật" FontSize="10" Foreground="#64748B"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- RIGHT: VISIT HISTORY -->
        <Border Grid.Column="2"
                Background="White"
                BorderBrush="#E2E8F0"
                BorderThickness="1"
                CornerRadius="18"
                Padding="20">
            <Grid RowSpacing="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock Text="LỊCH SỬ THĂM KHÁM"
                               FontSize="10"
                               FontWeight="ExtraBold"
                               Foreground="#1E293B"
                               CharacterSpacing="180"/>
                    <TextBlock x:Name="TxtVisitSubtitle"
                               Text="Chưa chọn bệnh nhân"
                               FontSize="12"
                               Foreground="#64748B"/>
                </StackPanel>

                <ListView Grid.Row="1"
                          x:Name="VisitHistoryListView"
                          SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{Binding Background}"
                                    CornerRadius="12"
                                    Padding="12"
                                    Margin="0,0,0,12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="13"
                                               FontWeight="ExtraBold"
                                               Foreground="#1E293B"/>
                                    <TextBlock Text="{Binding DateText}"
                                               FontSize="10"
                                               Foreground="#94A3B8"/>
                                    <TextBlock Text="{Binding DoctorText}"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="#334155"/>
                                    <TextBlock Text="{Binding Summary}"
                                               FontSize="10"
                                               Foreground="#64748B"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>