<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Healthcare.Client.UI.Doctor.PatientHistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Healthcare.Client.UI.Doctor"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <!-- Color Brushes -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#0059BB"/>
        <SolidColorBrush x:Key="PrimaryLightBrush" Color="#EFF4FF"/>
        <SolidColorBrush x:Key="RedBrush" Color="#DC2626"/>
        <SolidColorBrush x:Key="RedLightBrush" Color="#FEF2F2"/>
        <SolidColorBrush x:Key="OrangeBrush" Color="#EA580C"/>
        <SolidColorBrush x:Key="OrangeLightBrush" Color="#FFF7ED"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#16A34A"/>
        <SolidColorBrush x:Key="GreenLightBrush" Color="#F0FDF4"/>
        <SolidColorBrush x:Key="TealBrush" Color="#0D9488"/>
        <SolidColorBrush x:Key="PurpleBrush" Color="#7C3AED"/>
        <SolidColorBrush x:Key="EmeraldBrush" Color="#059669"/>
        <SolidColorBrush x:Key="EmeraldLightBrush" Color="#ECFDF5"/>
        <SolidColorBrush x:Key="RoseBrush" Color="#E11D48"/>
        <SolidColorBrush x:Key="BlueBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="IndigoBrush" Color="#4F46E5"/>
        <SolidColorBrush x:Key="SlateBorderBrush" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="SlateTextBrush" Color="#1E293B"/>
        <SolidColorBrush x:Key="SlateSubtextBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="SlateLightBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF"/>

        <!-- Card Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Padding" Value="24"/>
        </Style>

        <!-- Section Title Style -->
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="ExtraBold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>

        <!-- Label Style -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="CharacterSpacing" Value="100"/>
        </Style>

        <!-- Value Style -->
        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="ExtraBold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>

        <!-- Edit Button Style -->
        <Style x:Key="EditButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#DBEAFE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- Action Button Style -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="12,14"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="ExtraBold"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
    </Page.Resources>

    <!-- Root: Outer ScrollViewer -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════════════════════
                 MAIN CONTENT (Left + Center)
            ═══════════════════════════════════════════ -->
            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="24,24,12,24">
                <StackPanel Spacing="20">

                    <!-- ╔══════════════════════════════════════╗
                         ║  1. PATIENT SUMMARY HEADER          ║
                         ╚══════════════════════════════════════╝ -->
                    <Border Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Patient Info -->
                            <!-- TODO [SUPABASE]: Toàn bộ block này bind từ bảng 'patients' -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="32">
                                <!-- Avatar + Name -->
                                <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                                    <Grid>
                                        <Ellipse Width="56" Height="56">
                                            <Ellipse.Fill>
                                                <!-- TODO [SUPABASE]: ImageSource="{x:Bind ViewModel.Patient.AvatarUrl}" -->
                                                <ImageBrush ImageSource="ms-appx:///Assets/patient_avatar.png" Stretch="UniformToFill"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <!-- Online dot -->
                                        <Ellipse Width="14" Height="14"
                                                 Fill="#22C55E"
                                                 Stroke="White" StrokeThickness="2"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Bottom"/>
                                    </Grid>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="HỒ SƠ BỆNH NHÂN"
                                                   FontSize="9" FontWeight="Bold"
                                                   Foreground="#94A3B8"
                                                   CharacterSpacing="150"/>
                                        <!-- TODO [SUPABASE]: Text="{x:Bind ViewModel.Patient.FullName}" -->
                                        <TextBlock Text="Nguyễn Văn A"
                                                   FontSize="20" FontWeight="ExtraBold"
                                                   Foreground="#1E293B"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Quick Stats -->
                                <StackPanel Orientation="Horizontal" Spacing="32" VerticalAlignment="Center">
                                    <StackPanel>
                                        <TextBlock Text="MÃ BN" Style="{StaticResource LabelStyle}"/>
                                        <!-- TODO [SUPABASE]: Text="{x:Bind ViewModel.Patient.PatientCode}" -->
                                        <TextBlock Text="#127335" FontSize="13" FontWeight="Bold" Foreground="#334155"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="CÂN NẶNG" Style="{StaticResource LabelStyle}"/>
                                        <!-- TODO [SUPABASE]: Text="{x:Bind ViewModel.VitalSigns.Weight}" -->
                                        <TextBlock Text="65kg" FontSize="13" FontWeight="Bold" Foreground="#334155"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="TRẠNG THÁI" Style="{StaticResource LabelStyle}"/>
                                        <Border Background="#DCFCE7" CornerRadius="4" Padding="8,3">
                                            <!-- TODO [SUPABASE]: Text="{x:Bind ViewModel.Patient.Status}" -->
                                            <TextBlock Text="Bình thường"
                                                       FontSize="11" FontWeight="Bold"
                                                       Foreground="#15803D"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <!-- Allergy Alert -->
                            <!-- TODO [SUPABASE]: Hiển thị tổng hợp dị ứng nghiêm trọng từ bảng 'allergies' -->
                            <Border Grid.Column="1"
                                    CornerRadius="12"
                                    Padding="1"
                                    VerticalAlignment="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#DC2626" Offset="0"/>
                                        <GradientStop Color="#F43F5E" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border Background="#FEF2F2" CornerRadius="11" Padding="16,10">
                                    <StackPanel Orientation="Horizontal" Spacing="14">
                                        <Border Background="#DC2626" CornerRadius="8" Padding="6">
                                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7BA;"
                                                      FontSize="16" Foreground="White"/>
                                        </Border>
                                        <StackPanel>
                                            <TextBlock Text="CẢNH BÁO DỊ ỨNG"
                                                       FontSize="9" FontWeight="Bold"
                                                       Foreground="#DC2626"
                                                       CharacterSpacing="150"/>
                                            <!-- TODO [SUPABASE]: Text="{x:Bind ViewModel.AllergyAlertSummary}" -->
                                            <!-- AllergyAlertSummary = chuỗi ghép tên các allergen nghiêm trọng -->
                                            <TextBlock Text="Amoxicillin, Đậu phộng"
                                                       FontSize="13" FontWeight="ExtraBold"
                                                       Foreground="#7F1D1D"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ╔══════════════════════════════════════╗
                         ║  2x2 GRID: Vital Signs + Allergies  ║
                         ╚══════════════════════════════════════╝ -->
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ── Card 1: Dấu hiệu sinh tồn ── -->
                        <Border Grid.Column="0"
                                CornerRadius="16"
                                BorderThickness="0,1,1,1"
                                BorderBrush="#E2E8F0"
                                Padding="24">
                            <!-- Left accent bar -->
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#EEF4FF" Offset="0"/>
                                    <GradientStop Color="#F8FAFC" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <!-- Left blue border via grid trick -->
                                <Border HorizontalAlignment="Left" Width="4"
                                        Background="#0059BB" CornerRadius="4,0,0,4"
                                        Margin="-24,0,0,0"/>
                                <StackPanel Margin="8,0,0,0">
                                    <!-- Header -->
                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xEA92;"
                                                      FontSize="18" Foreground="#0059BB"/>
                                            <TextBlock Text="1. Dấu hiệu sinh tồn"
                                                       Style="{StaticResource SectionTitleStyle}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                x:Name="BtnEditVitals"
                                                Content="+ Sửa"
                                                Style="{StaticResource EditButtonStyle}"
                                                Foreground="#0059BB"
                                                Click="BtnEditVitals_Click"/>
                                    </Grid>

                                    <!-- Vitals Grid -->
                                    <!-- TODO [SUPABASE]: Toàn bộ UniformGrid này bind từ bảng 'vital_signs' -->
                                    <!-- Vitals: 2 rows x 3 cols (UniformGrid không có trong WinUI 3) -->
                                    <Grid RowSpacing="16" ColumnSpacing="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Row 0 -->
                                        <StackPanel Grid.Row="0" Grid.Column="0">
                                            <TextBlock Text="CHIỀU CAO" Style="{StaticResource LabelStyle}"/>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                                <!-- TODO [SUPABASE]: Text="{x:Bind ViewModel.VitalSigns.Height}" -->
                                                <TextBlock x:Name="TxtHeight" Text="170" Style="{StaticResource ValueStyle}"/>
                                                <TextBlock Text=" cm" FontSize="11" Foreground="#94A3B8"
                                                           VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="1">
                                            <TextBlock Text="CÂN NẶNG" Style="{StaticResource LabelStyle}"/>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                                <!-- TODO [SUPABASE]: Text="{x:Bind ViewModel.VitalSigns.Weight}" -->
                                                <TextBlock x:Name="TxtWeight" Text="65" Style="{StaticResource ValueStyle}"/>
                                                <TextBlock Text=" kg" FontSize="11" Foreground="#94A3B8"
                                                           VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Row="0" Grid.Column="2">
                                            <TextBlock Text="CHỈ SỐ BMI" Style="{StaticResource LabelStyle}"/>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                                                <!-- TODO [SUPABASE]: Text="{x:Bind ViewModel.VitalSigns.Bmi}" -->
                                                <TextBlock x:Name="TxtBmi" Text="22.5" Style="{StaticResource ValueStyle}"/>
                                                <Border Background="#DCFCE7" CornerRadius="4" Padding="4,2"
                                                        VerticalAlignment="Center">
                                                    <!-- TODO [SUPABASE]: Text="{x:Bind ViewModel.VitalSigns.BmiLabel}" -->
                                                    <TextBlock Text="Bình thường"
                                                               FontSize="9" FontWeight="Bold"
                                                               Foreground="#16A34A"/>
                                                </Border>
                                            </StackPanel>
                                            <!-- TODO [SUPABASE]: Value="{x:Bind ViewModel.VitalSigns.BmiPercent}" -->
                                            <ProgressBar Value="60" Maximum="100"
                                                         Height="4" CornerRadius="2"
                                                         Foreground="#22C55E"
                                                         Background="#F1F5F9"
                                                         Margin="0,4,4,0"/>
                                        </StackPanel>

                                        <!-- Row 1 -->
                                        <StackPanel Grid.Row="1" Grid.Column="0">
                                            <TextBlock Text="HUYẾT ÁP" Style="{StaticResource LabelStyle}"/>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                                <!-- TODO [SUPABASE]: Text="{x:Bind ViewModel.VitalSigns.BloodPressure}" -->
                                                <TextBlock x:Name="TxtBloodPressure" Text="120/80" Style="{StaticResource ValueStyle}"/>
                                                <TextBlock Text=" mmHg" FontSize="11" Foreground="#94A3B8"
                                                           VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="1">
                                            <TextBlock Text="NHỊP TIM" Style="{StaticResource LabelStyle}"/>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                                <!-- TODO [SUPABASE]: Text="{x:Bind ViewModel.VitalSigns.HeartRate}" -->
                                                <TextBlock x:Name="TxtHeartRate" Text="75" Style="{StaticResource ValueStyle}"/>
                                                <TextBlock Text=" bpm" FontSize="11" Foreground="#94A3B8"
                                                           VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="2">
                                            <TextBlock Text="NHIỆT ĐỘ" Style="{StaticResource LabelStyle}"/>
                                            <!-- TODO [SUPABASE]: Text="{x:Bind ViewModel.VitalSigns.Temperature}" -->
                                            <TextBlock x:Name="TxtTemperature" Text="36.8°C" Style="{StaticResource ValueStyle}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- ── Card 2: Tiền sử dị ứng ── -->
                        <Border Grid.Column="1"
                                Background="#FFF8F8"
                                CornerRadius="16"
                                BorderThickness="0,1,1,1"
                                BorderBrush="#FECACA"
                                Padding="24">
                            <Grid>
                                <Border HorizontalAlignment="Left" Width="4"
                                        Background="#DC2626" CornerRadius="4,0,0,4"
                                        Margin="-24,0,0,0"/>
                                <StackPanel Margin="8,0,0,0">
                                    <!-- Header -->
                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xEB51;"
                                                      FontSize="18" Foreground="#DC2626"/>
                                            <TextBlock Text="2. Tiền sử dị ứng"
                                                       Style="{StaticResource SectionTitleStyle}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                x:Name="BtnAddAllergy"
                                                Content="+ Thêm"
                                                Style="{StaticResource EditButtonStyle}"
                                                Foreground="#DC2626"
                                                BorderBrush="#FECACA"
                                                Click="BtnAddAllergy_Click"/>
                                    </Grid>

                                    <!-- Allergy Items -->
                                    <!--
                                        TODO [SUPABASE]: Thay toàn bộ StackPanel tĩnh này bằng ItemsRepeater:

                                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.Allergies}">
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="models:AllergyModel">
                                                    ... (1 item template dùng chung cho mọi dị ứng)
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>

                                        Các field cần bind trong AllergyModel:
                                          - Name          : tên dị ứng nguyên (AMOXICILLIN, ĐẬU PHỘNG ...)
                                          - SeverityLabel : nhãn mức độ (NGHIÊM TRỌNG / TRUNG BÌNH / NHẸ)
                                          - SeverityColor : màu badge
                                          - Symptoms      : biểu hiện lâm sàng
                                    -->
                                    <StackPanel x:Name="AllergyList" Spacing="10">
                                        <!-- Amoxicillin - TODO [SUPABASE]: xóa item cứng này khi dùng ItemsRepeater -->
                                        <Border Background="White" CornerRadius="12"
                                                BorderThickness="1" BorderBrush="#FECACA"
                                                Padding="14,12">
                                            <StackPanel Orientation="Horizontal" Spacing="14">
                                                <Border Background="#FEE2E2" CornerRadius="20"
                                                        Width="40" Height="40">
                                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xECAA;"
                                                              FontSize="18" Foreground="#DC2626"
                                                              VerticalAlignment="Center"
                                                              HorizontalAlignment="Center"/>
                                                </Border>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                                                        <Border Background="#DC2626" CornerRadius="3" Padding="5,2">
                                                            <TextBlock Text="NGHIÊM TRỌNG"
                                                                       FontSize="8" FontWeight="Black"
                                                                       Foreground="White"
                                                                       CharacterSpacing="50"/>
                                                        </Border>
                                                        <TextBlock Text="AMOXICILLIN"
                                                                   FontSize="13" FontWeight="ExtraBold"
                                                                   Foreground="#1E293B"/>
                                                    </StackPanel>
                                                    <TextBlock Text="Biểu hiện: Sốc phản vệ"
                                                               FontSize="11" FontWeight="Bold"
                                                               Foreground="#B91C1C"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Đậu phộng - TODO [SUPABASE]: xóa item cứng này khi dùng ItemsRepeater -->
                                        <Border Background="White" CornerRadius="12"
                                                BorderThickness="1" BorderBrush="#FED7AA"
                                                Padding="14,12">
                                            <StackPanel Orientation="Horizontal" Spacing="14">
                                                <Border Background="#FFEDD5" CornerRadius="20"
                                                        Width="40" Height="40">
                                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE734;"
                                                              FontSize="18" Foreground="#EA580C"
                                                              VerticalAlignment="Center"
                                                              HorizontalAlignment="Center"/>
                                                </Border>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,4">
                                                        <Border Background="#F97316" CornerRadius="3" Padding="5,2">
                                                            <TextBlock Text="TRUNG BÌNH"
                                                                       FontSize="8" FontWeight="Black"
                                                                       Foreground="White"
                                                                       CharacterSpacing="50"/>
                                                        </Border>
                                                        <TextBlock Text="ĐẬU PHỘNG"
                                                                   FontSize="13" FontWeight="ExtraBold"
                                                                   Foreground="#1E293B"/>
                                                    </StackPanel>
                                                    <TextBlock Text="Biểu hiện: Phát ban ngoài da"
                                                               FontSize="11" FontWeight="Bold"
                                                               Foreground="#C2410C"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- ╔══════════════════════════════════════╗
                         ║  3. Tiền sử bệnh lý cá nhân        ║
                         ╚══════════════════════════════════════╝ -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <!-- Header -->
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE9D9;"
                                              FontSize="18" Foreground="#7C3AED"/>
                                    <TextBlock Text="3. Tiền sử bệnh lý cá nhân"
                                               Style="{StaticResource SectionTitleStyle}"/>
                                </StackPanel>
                                <Button Grid.Column="1" x:Name="BtnEditMedHistory" Content="+ Sửa"
                                        Style="{StaticResource EditButtonStyle}"
                                        Foreground="#64748B" BorderBrush="#E2E8F0"
                                        Click="BtnEditMedHistory_Click"/>
                            </Grid>

                            <!-- 3 Sub-cards -->
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Bệnh nền -->
                                <!-- TODO [SUPABASE]: Card này bind từ bảng 'medical_history' (type = 'chronic') -->
                                <Border Grid.Column="0" CornerRadius="14"
                                        BorderThickness="1" BorderBrush="#BFDBFE"
                                        Padding="18">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#EFF6FF" Offset="0"/>
                                            <GradientStop Color="#FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,14">
                                            <Border Background="#2563EB" CornerRadius="10"
                                                    Width="36" Height="36">
                                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xECAA;"
                                                          FontSize="16" Foreground="White"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="BỆNH NỀN"
                                                       FontSize="11" FontWeight="Black"
                                                       Foreground="#1E3A8A"
                                                       CharacterSpacing="80"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <!-- TODO [SUPABASE]: Text="{x:Bind ViewModel.ChronicDisease.Name}" -->
                                        <TextBlock x:Name="TxtChronicName" Text="Cao huyết áp"
                                                   FontSize="15" FontWeight="ExtraBold"
                                                   Foreground="#1E293B"/>
                                        <!-- TODO [SUPABASE]: Text="{x:Bind ViewModel.ChronicDisease.DiagnosedYear, Converter={...}}" -->
                                        <TextBlock x:Name="TxtChronicYear" Text="Phát hiện từ: 2020"
                                                   FontSize="11" FontWeight="Bold"
                                                   Foreground="#2563EB"
                                                   FontStyle="Italic"
                                                   Margin="0,4,0,0"/>
                                        <Border BorderThickness="0,1,0,0" BorderBrush="#BFDBFE"
                                                Margin="0,10,0,0" Padding="0,8,0,0">
                                            <!-- TODO [SUPABASE]: Text="{x:Bind ViewModel.ChronicDisease.Notes}" -->
                                            <TextBlock x:Name="TxtChronicNote" Text="Kiểm soát ổn định bằng thuốc Lisinopril hàng ngày."
                                                       FontSize="11" Foreground="#64748B"
                                                       TextWrapping="Wrap"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Phẫu thuật -->
                                <!-- TODO [SUPABASE]: Card này bind từ bảng 'medical_history' (type = 'surgery') -->
                                <Border Grid.Column="1" CornerRadius="14"
                                        BorderThickness="1" BorderBrush="#C7D2FE"
                                        Padding="18">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#EEF2FF" Offset="0"/>
                                            <GradientStop Color="#FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,14">
                                            <Border Background="#4F46E5" CornerRadius="10"
                                                    Width="36" Height="36">
