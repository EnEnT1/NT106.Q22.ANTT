                                                               FontSize="10" Foreground="#64748B"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Rượu bia -->
                                        <Border Grid.Row="0" Grid.Column="1"
                                                Background="White" CornerRadius="12"
                                                BorderThickness="1" BorderBrush="#F1F5F9"
                                                Padding="12">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <Border Background="#FEF3C7" CornerRadius="8"
                                                        Width="36" Height="36">
                                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xEB5B;"
                                                              FontSize="16" Foreground="#D97706"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel>
                                                    <TextBlock Text="RƯỢU BIA"
                                                               FontSize="9" FontWeight="Black"
                                                               Foreground="#1E293B"
                                                               CharacterSpacing="80"/>
                                                    <TextBlock x:Name="TxtAlcohol" Text="1-2 lần / tuần"
                                                               FontSize="10" Foreground="#64748B"/>
                                                </StackPanel>
                                            </StackPanel>
