<Page
    x:Class="Healthcare.Client.UI.Doctor.PatientHistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource AppBackdropGradientBrush}">

    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#0059BB"/>
        <SolidColorBrush x:Key="SlateBorderBrush" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="SlateTextBrush" Color="#1E293B"/>
        <SolidColorBrush x:Key="SlateSubtextBrush" Color="#64748B"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="ExtraBold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="CharacterSpacing" Value="100"/>
        </Style>

        <Style x:Key="ValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="ExtraBold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>

        <Style x:Key="EditButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#DBEAFE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- MAIN -->
            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="24,24,12,24">
                <StackPanel Spacing="20">

                    <!-- HEADER -->
                    <Border Style="{StaticResource CardStyle}">
                        <Grid ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Grid Width="64" Height="64">
                                <Ellipse Fill="#E2E8F0"/>
                                <FontIcon FontFamily="Segoe MDL2 Assets"
                                          Glyph="&#xE77B;"
                                          FontSize="28"
                                          Foreground="#94A3B8"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Grid>

                            <StackPanel Grid.Column="1" Spacing="10">
                                <StackPanel>
                                    <TextBlock Text="HỒ SƠ BỆNH NHÂN"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="#94A3B8"
                                               CharacterSpacing="150"/>
                                    <TextBlock x:Name="TxtHeaderPatientName"
                                               Text="Đang tải..."
                                               FontSize="22"
                                               FontWeight="ExtraBold"
                                               Foreground="#1E293B"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="28">
                                    <StackPanel>
                                        <TextBlock Text="MÃ BN" Style="{StaticResource LabelStyle}"/>
                                        <TextBlock x:Name="TxtPatientCode"
                                                   Text="#N/A"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="#334155"/>
                                    </StackPanel>

                                    <StackPanel>
                                        <TextBlock Text="CÂN NẶNG" Style="{StaticResource LabelStyle}"/>
                                        <TextBlock x:Name="TxtHeaderWeight"
                                                   Text="N/A"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="#334155"/>
                                    </StackPanel>

                                    <StackPanel>
                                        <TextBlock Text="TRẠNG THÁI" Style="{StaticResource LabelStyle}"/>
                                        <Border Background="#DCFCE7" CornerRadius="4" Padding="8,3">
                                            <TextBlock x:Name="TxtPatientStatus"
                                                       Text="Chưa rõ"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       Foreground="#15803D"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <Border Grid.Column="2"
                                    Background="#FEF2F2"
                                    BorderBrush="#FECACA"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="14,10"
                                    VerticalAlignment="Center">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="CẢNH BÁO DỊ ỨNG"
                                               FontSize="9"
                                               FontWeight="Bold"
                                               Foreground="#DC2626"
                                               CharacterSpacing="120"/>
                                    <TextBlock x:Name="TxtAllergyAlertSummary"
                                               Text="Không có dữ liệu"
                                               FontSize="13"
                                               FontWeight="ExtraBold"
                                               Foreground="#7F1D1D"
                                               TextWrapping="Wrap"
                                               MaxWidth="220"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- VITALS + ALLERGIES -->
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                            <StackPanel Spacing="16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="1. DẤU HIỆU SINH TỒN"
                                               Style="{StaticResource SectionTitleStyle}"/>

                                    <Button Grid.Column="1"
                                            x:Name="BtnEditVitals"
                                            Content="+ Sửa"
                                            Style="{StaticResource EditButtonStyle}"
                                            Foreground="#0059BB"
                                            Click="BtnEditVitals_Click"/>
                                </Grid>

                                <Grid RowSpacing="16" ColumnSpacing="16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <TextBlock Text="CHIỀU CAO" Style="{StaticResource LabelStyle}"/>
                                        <TextBlock x:Name="TxtHeight" Text="-" Style="{StaticResource ValueStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="1">
                                        <TextBlock Text="CÂN NẶNG" Style="{StaticResource LabelStyle}"/>
                                        <TextBlock x:Name="TxtWeight" Text="-" Style="{StaticResource ValueStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="2">
                                        <TextBlock Text="BMI" Style="{StaticResource LabelStyle}"/>
                                        <TextBlock x:Name="TxtBmi" Text="-" Style="{StaticResource ValueStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0">
                                        <TextBlock Text="HUYẾT ÁP" Style="{StaticResource LabelStyle}"/>
                                        <TextBlock x:Name="TxtBloodPressure" Text="-" Style="{StaticResource ValueStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="1">
                                        <TextBlock Text="NHỊP TIM" Style="{StaticResource LabelStyle}"/>
                                        <TextBlock x:Name="TxtHeartRate" Text="-" Style="{StaticResource ValueStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="2">
                                        <TextBlock Text="NHIỆT ĐỘ" Style="{StaticResource LabelStyle}"/>
                                        <TextBlock x:Name="TxtTemperature" Text="-" Style="{StaticResource ValueStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                            <StackPanel Spacing="16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="2. TIỀN SỬ DỊ ỨNG"
                                               Style="{StaticResource SectionTitleStyle}"/>

                                    <Button Grid.Column="1"
                                            x:Name="BtnAddAllergy"
                                            Content="+ Thêm"
                                            Style="{StaticResource EditButtonStyle}"
                                            Foreground="#DC2626"
                                            BorderBrush="#FECACA"
                                            Click="BtnAddAllergy_Click"/>
                                </Grid>

                                <StackPanel x:Name="AllergyList" Spacing="10"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- MEDICAL HISTORY -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel Spacing="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="3. TIỀN SỬ BỆNH LÝ CÁ NHÂN"
                                           Style="{StaticResource SectionTitleStyle}"/>

                                <Button Grid.Column="1"
                                        x:Name="BtnEditMedHistory"
                                        Content="+ Sửa"
                                        Style="{StaticResource EditButtonStyle}"
                                        Foreground="#64748B"
                                        BorderBrush="#E2E8F0"
                                        Click="BtnEditMedHistory_Click"/>
                            </Grid>

                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Background="#EFF6FF"
                                        BorderBrush="#BFDBFE"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="16">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="BỆNH NỀN"
                                                   FontSize="11"
                                                   FontWeight="Black"
                                                   Foreground="#1E3A8A"/>
                                        <TextBlock x:Name="TxtChronicName"
                                                   Text="Chưa cập nhật"
                                                   FontSize="15"
                                                   FontWeight="ExtraBold"
                                                   Foreground="#1E293B"/>
                                        <TextBlock x:Name="TxtChronicYear"
                                                   Text="Phát hiện từ: --"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   Foreground="#2563EB"/>
                                        <TextBlock x:Name="TxtChronicNote"
                                                   Text="Không có ghi chú"
                                                   FontSize="11"
                                                   Foreground="#64748B"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1"
                                        Background="#EEF2FF"
                                        BorderBrush="#C7D2FE"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="16">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="PHẪU THUẬT"
                                                   FontSize="11"
                                                   FontWeight="Black"
                                                   Foreground="#3730A3"/>
                                        <TextBlock x:Name="TxtSurgeryName"
                                                   Text="Chưa cập nhật"
                                                   FontSize="15"
                                                   FontWeight="ExtraBold"
                                                   Foreground="#1E293B"/>
                                        <TextBlock x:Name="TxtSurgeryYear"
                                                   Text="Năm thực hiện: --"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   Foreground="#4F46E5"/>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2"
                                        Background="#ECFDF5"
                                        BorderBrush="#A7F3D0"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="16">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="TIÊM CHỦNG"
                                                   FontSize="11"
                                                   FontWeight="Black"
                                                   Foreground="#064E3B"/>
                                        <TextBlock x:Name="TxtVaccinationName"
                                                   Text="Chưa cập nhật"
                                                   FontSize="15"
                                                   FontWeight="ExtraBold"
                                                   Foreground="#1E293B"/>
                                        <TextBlock x:Name="TxtVaccinationYear"
                                                   Text="Gần nhất: --"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   Foreground="#059669"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- MEDICATION -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel Spacing="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="4. TIỀN SỬ DÙNG THUỐC"
                                           Style="{StaticResource SectionTitleStyle}"/>

                                <Button Grid.Column="1"
                                        x:Name="BtnEditMedication"
                                        Content="+ Sửa"
                                        Style="{StaticResource EditButtonStyle}"
                                        Foreground="#64748B"
                                        BorderBrush="#E2E8F0"
                                        Click="BtnEditMedication_Click"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="TÊN THUỐC" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="TxtMedName" Text="Chưa cập nhật" FontSize="13" FontWeight="ExtraBold"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="LIỀU LƯỢNG" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="TxtMedDosage" Text="Chưa cập nhật" FontSize="12"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Text="THỜI GIAN" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock x:Name="TxtMedPeriod" Text="--" FontSize="11" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- FAMILY + LIFESTYLE -->
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                            <StackPanel Spacing="16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="5. TIỀN SỬ GIA ĐÌNH"
                                               Style="{StaticResource SectionTitleStyle}"/>

                                    <Button Grid.Column="1"
                                            x:Name="BtnEditFamily"
                                            Content="+ Sửa"
                                            Style="{StaticResource EditButtonStyle}"
                                            Foreground="#64748B"
                                            BorderBrush="#E2E8F0"
                                            Click="BtnEditFamily_Click"/>
                                </Grid>

                                <StackPanel Spacing="12">
                                    <Border Background="#EFF6FF" CornerRadius="12" Padding="14">
                                        <StackPanel>
                                            <TextBlock Text="BỐ ĐẺ" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock x:Name="TxtFatherCondition"
                                                       Text="Chưa cập nhật"
                                                       FontSize="13"
                                                       FontWeight="ExtraBold"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Background="#FFF1F2" CornerRadius="12" Padding="14">
                                        <StackPanel>
                                            <TextBlock Text="MẸ ĐẺ" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock x:Name="TxtMotherCondition"
                                                       Text="Chưa cập nhật"
                                                       FontSize="13"
                                                       FontWeight="ExtraBold"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                            <StackPanel Spacing="16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="6. LỐI SỐNG"
                                               Style="{StaticResource SectionTitleStyle}"/>

                                    <Button Grid.Column="1"
                                            x:Name="BtnEditLifestyle"
                                            Content="+ Sửa"
                                            Style="{StaticResource EditButtonStyle}"
                                            Foreground="#059669"
                                            BorderBrush="#A7F3D0"
                                            Click="BtnEditLifestyle_Click"/>
                                </Grid>

                                <Grid RowSpacing="8" ColumnSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Row="0" Grid.Column="0" Background="White" CornerRadius="12" BorderBrush="#F1F5F9" BorderThickness="1" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="THUỐC LÁ" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock x:Name="TxtSmoking" Text="Chưa cập nhật" FontSize="10" Foreground="#64748B"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="0" Grid.Column="1" Background="White" CornerRadius="12" BorderBrush="#F1F5F9" BorderThickness="1" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="RƯỢU BIA" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock x:Name="TxtAlcohol" Text="Chưa cập nhật" FontSize="10" Foreground="#64748B"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1" Grid.Column="0" Background="White" CornerRadius="12" BorderBrush="#F1F5F9" BorderThickness="1" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="VẬN ĐỘNG" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock x:Name="TxtExercise" Text="Chưa cập nhật" FontSize="10" Foreground="#64748B"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1" Grid.Column="1" Background="White" CornerRadius="12" BorderBrush="#F1F5F9" BorderThickness="1" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="GIẤC NGỦ" Style="{StaticResource LabelStyle}"/>
                                            <TextBlock x:Name="TxtSleep" Text="Chưa cập nhật" FontSize="10" Foreground="#64748B"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <StackPanel HorizontalAlignment="Right" Margin="0,8,0,32">
                        <Button x:Name="SaveButton"
                                Content="Lưu thông tin hồ sơ"
                                Click="SaveButton_Click"
                                Background="#0059BB"
                                Foreground="White"
                                CornerRadius="10"
                                Padding="48,12"
                                FontSize="13"
                                FontWeight="ExtraBold"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- SIDEBAR -->
            <Border Grid.Column="1"
                    Background="White"
                    BorderThickness="1,0,0,0"
                    BorderBrush="#E2E8F0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                    <StackPanel Spacing="24">
                        <TextBlock Text="LỊCH SỬ THĂM KHÁM"
                                   FontSize="10"
                                   FontWeight="ExtraBold"
                                   Foreground="#1E293B"
                                   CharacterSpacing="180"/>

                        <StackPanel Spacing="14">
                            <Border Background="#EFF6FF" CornerRadius="12" Padding="12">
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="TxtVisit1Type" Text="Chưa có dữ liệu" FontSize="13" FontWeight="ExtraBold"/>
                                    <TextBlock x:Name="TxtVisit1Date" Text="--" FontSize="10" Foreground="#94A3B8"/>
                                    <TextBlock x:Name="TxtVisit1Doctor" Text="--" FontSize="11" FontWeight="Bold" Foreground="#334155"/>
                                    <TextBlock x:Name="TxtVisit1Summary" Text="--" FontSize="10" Foreground="#64748B" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#F8FAFC" CornerRadius="12" Padding="12">
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="TxtVisit2Type" Text="Chưa có dữ liệu" FontSize="13" FontWeight="ExtraBold"/>
                                    <TextBlock x:Name="TxtVisit2Date" Text="--" FontSize="10" Foreground="#94A3B8"/>
                                    <TextBlock x:Name="TxtVisit2Doctor" Text="--" FontSize="11" FontWeight="Bold" Foreground="#334155"/>
                                    <TextBlock x:Name="TxtVisit2Summary" Text="--" FontSize="10" Foreground="#64748B" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#F8FAFC" CornerRadius="12" Padding="12">
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="TxtVisit3Type" Text="Chưa có dữ liệu" FontSize="13" FontWeight="ExtraBold"/>
                                    <TextBlock x:Name="TxtVisit3Date" Text="--" FontSize="10" Foreground="#94A3B8"/>
                                    <TextBlock x:Name="TxtVisit3Doctor" Text="--" FontSize="11" FontWeight="Bold" Foreground="#334155"/>
                                    <TextBlock x:Name="TxtVisit3Summary" Text="--" FontSize="10" Foreground="#64748B" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>