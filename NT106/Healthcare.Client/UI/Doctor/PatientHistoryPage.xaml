                            <Grid>
                                <Border HorizontalAlignment="Left" Width="4"
                                        Background="#059669" CornerRadius="4,0,0,4"
                                        Margin="-24,0,0,0"/>
                                <StackPanel Margin="8,0,0,0">
                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE734;"
                                                      FontSize="18" Foreground="#059669"/>
                                            <TextBlock Text="6. Lối sống"
                                                       Style="{StaticResource SectionTitleStyle}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" x:Name="BtnEditLifestyle" Content="+ Sửa"
                                                Style="{StaticResource EditButtonStyle}"
                                                Foreground="#059669" BorderBrush="#A7F3D0"
