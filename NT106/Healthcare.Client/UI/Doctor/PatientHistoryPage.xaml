                                                <Border Background="#E0E7FF" CornerRadius="8"
                                                        Width="36" Height="36">
                                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE708;"
                                                              FontSize="16" Foreground="#4F46E5"
