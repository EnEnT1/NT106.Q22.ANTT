                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel>
                                                    <TextBlock Text="VẬN ĐỘNG"
                                                               FontSize="9" FontWeight="Black"
                                                               Foreground="#1E293B"
