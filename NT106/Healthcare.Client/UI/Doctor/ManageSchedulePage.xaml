<Page
    x:Class="Healthcare.Client.UI.Doctor.ManageSchedulePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Healthcare.Client.UI.Doctor"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource AppBackdropGradientBrush}">

    <Page.Resources>
        <!-- Design Tokens -->
        <SolidColorBrush x:Key="MedicalBlue" Color="#3A8DFF"/>
        <SolidColorBrush x:Key="MedicalBlueLight" Color="#EBF4FF"/>
        <SolidColorBrush x:Key="SuccessGreen" Color="#10B981"/>
        <SolidColorBrush x:Key="SuccessGreenLight" Color="#ECFDF5"/>
        <SolidColorBrush x:Key="WarningAmber" Color="#F59E0B"/>
        <SolidColorBrush x:Key="WarningAmberLight" Color="#FFFBEB"/>
        <SolidColorBrush x:Key="DangerRed" Color="#EF4444"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#64748B"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="SurfaceContainerLowestBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SurfaceContainerBrush" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="OutlineBrush" Color="#94A3B8"/>
        <!-- Accent color matching the reference (indigo/blue-purple) -->
        <SolidColorBrush x:Key="AccentIndigo" Color="#5B6CF6"/>
        <SolidColorBrush x:Key="AccentIndigoLight" Color="#EEF0FE"/>
        <SolidColorBrush x:Key="TodayColumnBg" Color="#F4F5FE"/>

        <!-- Typography -->
        <Style x:Key="TitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style x:Key="SubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        </Style>

        <!-- Card Styles -->
        <Style x:Key="SurfaceCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="DayHeaderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8,10"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Button Styles -->
        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Transitions">
                <Setter.Value>
                    <TransitionCollection>
                        <EntranceThemeTransition/>
                    </TransitionCollection>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource MedicalBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="NavIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- Appointment Card Template (reference-style: left accent border + time top) -->
        <DataTemplate x:Key="AppointmentCardTemplate" x:DataType="local:AppointmentViewModel">
            <Border Margin="0,0,0,10"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="10"
                    Tapped="AppointmentCard_Tapped">
                <Border.Shadow>
                    <ThemeShadow/>
                </Border.Shadow>
                <!-- Outer card with subtle shadow -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left accent bar -->
                    <Border Grid.Column="0" 
                            Background="{StaticResource AccentIndigo}" 
                            CornerRadius="10,0,0,10"/>

                    <!-- Content -->
                    <StackPanel Grid.Column="1" Padding="10,10,10,10" Spacing="6">

                        <!-- Time range -->
                        <TextBlock Text="{x:Bind Time}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentIndigo}"/>

                        <!-- Patient name -->
                        <TextBlock Text="{x:Bind PatientName}"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimary}"
                                   TextWrapping="Wrap"/>

                        <!-- Status badge -->
                        <Border Background="{x:Bind TagBgBrush}"
                                CornerRadius="20"
                                Padding="8,3"
                                HorizontalAlignment="Left">
                            <TextBlock Text="{x:Bind StatusText}"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <ScrollViewer x:Name="MainScrollViewer" Background="Transparent" Padding="32,24">
        <StackPanel Spacing="32" HorizontalAlignment="Stretch">
            
            <!-- HEADER SECTION -->
            <Grid x:Name="PageHeaderGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="0"/> <!-- For narrow stack -->
                </Grid.RowDefinitions>

                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="Quản lý lịch khám" Style="{StaticResource TitleStyle}"/>
                    <TextBlock Text="Quản lý lịch hẹn, gọi video và nhập bệnh án chuyên nghiệp" Style="{StaticResource SubtitleStyle}"/>
                </StackPanel>

                <StackPanel x:Name="ClockPanel" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock x:Name="CurrentTimeText" Text="00:00:00" FontSize="24" FontWeight="Bold" Foreground="{StaticResource MedicalBlue}" HorizontalAlignment="Right"/>
                    <TextBlock x:Name="CurrentDateText" Text="Thứ Hai, 20/04/2026" FontSize="13" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>

            <!-- NAVIGATION TABS -->
            <Border Background="#F1F5F9" CornerRadius="12" Padding="6" HorizontalAlignment="Stretch">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Button x:Name="ListTabButton" Click="ListTab_Click" Style="{StaticResource TabButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon x:Name="ListTabIcon" Glyph="&#xE8EF;" FontSize="14"/>
                            <TextBlock x:Name="ListTabLabel" Text="Dạng danh sách" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="WeekTabButton" Click="WeekTab_Click" Style="{StaticResource TabButtonStyle}" Background="{StaticResource MedicalBlueLight}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon x:Name="WeekTabIcon" Glyph="&#xE8BF;" FontSize="14" Foreground="{StaticResource MedicalBlue}"/>
                            <TextBlock x:Name="WeekTabLabel" Text="Xem theo tuần" FontSize="13" Foreground="{StaticResource MedicalBlue}" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="MonthTabButton" Click="MonthTab_Click" Style="{StaticResource TabButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon x:Name="MonthTabIcon" Glyph="&#xE787;" FontSize="14"/>
                            <TextBlock x:Name="MonthTabLabel" Text="Xem cả tháng" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="SlotTabButton" Click="SlotTab_Click" Style="{StaticResource TabButtonStyle}" Margin="12,0,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon x:Name="SlotTabIcon" Glyph="&#xE8B0;" FontSize="14"/>
                            <TextBlock x:Name="SlotTabLabel" Text="Quản lý lịch khám" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- WEEK VIEW PANEL                                         -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <StackPanel x:Name="WeekViewPanel" Visibility="Visible" Spacing="0">

                <!-- ── Week Navigation Bar ── -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Style="{StaticResource NavIconButtonStyle}" Click="PrevWeek_Click"
                            Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <FontIcon Glyph="&#xE76B;" FontSize="14" Foreground="{StaticResource TextSecondary}"/>
                    </Button>

                    <TextBlock
                        x:Name="WeekRangeText"
                        Grid.Column="1"
                        Text="Tuần hiện tại"
                        FontSize="16"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource TextPrimary}"/>

                    <Button Grid.Column="2" Style="{StaticResource NavIconButtonStyle}" Click="NextWeek_Click"
                            Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <FontIcon Glyph="&#xE76C;" FontSize="14" Foreground="{StaticResource TextSecondary}"/>
                    </Button>
                </Grid>

                <!-- ── 7-Day Calendar Grid ── -->
                <Grid x:Name="WeekGrid" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- CHU NHAT -->
                    <StackPanel Grid.Column="0" Spacing="8">
                        <!-- Day Header -->
                        <Border x:Name="SundayHeader" CornerRadius="12" Padding="8,4" Height="85" HorizontalAlignment="Stretch" Background="Transparent">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                <TextBlock x:Name="SundayLabel" Text="CN" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource OutlineBrush}"
                                           HorizontalAlignment="Center" CharacterSpacing="80"/>
                                <Border x:Name="SundayCircle" Background="Transparent" CornerRadius="20" Width="38" Height="38">
                                    <TextBlock x:Name="SundayDate" Text="-" FontSize="22" FontWeight="Black"
                                               Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <ItemsControl ItemsSource="{x:Bind SundayList}" ItemTemplate="{StaticResource AppointmentCardTemplate}"/>
                    </StackPanel>

                    <!-- THU HAI -->
                    <StackPanel Grid.Column="1" Spacing="8">
                        <Border x:Name="MondayHeader" CornerRadius="12" Padding="8,4" Height="85" HorizontalAlignment="Stretch" Background="Transparent">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                <TextBlock x:Name="MondayLabel" Text="T2" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource OutlineBrush}"
                                           HorizontalAlignment="Center" CharacterSpacing="80"/>
                                <Border x:Name="MondayCircle" Background="Transparent" CornerRadius="20" Width="38" Height="38">
                                    <TextBlock x:Name="MondayDate" Text="-" FontSize="22" FontWeight="Black"
                                               Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <ItemsControl ItemsSource="{x:Bind MondayList}" ItemTemplate="{StaticResource AppointmentCardTemplate}"/>
                    </StackPanel>

                    <!-- THU BA -->
                    <StackPanel Grid.Column="2" Spacing="8">
                        <Border x:Name="TuesdayHeader" CornerRadius="12" Padding="8,4" Height="85" HorizontalAlignment="Stretch" Background="Transparent">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                <TextBlock x:Name="TuesdayLabel" Text="T3" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource OutlineBrush}"
                                           HorizontalAlignment="Center" CharacterSpacing="80"/>
                                <Border x:Name="TuesdayCircle" Background="Transparent" CornerRadius="20" Width="38" Height="38">
                                    <TextBlock x:Name="TuesdayDate" Text="-" FontSize="22" FontWeight="Black"
                                               Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <ItemsControl ItemsSource="{x:Bind TuesdayList}" ItemTemplate="{StaticResource AppointmentCardTemplate}"/>
                    </StackPanel>

                    <!-- THU TU -->
                    <StackPanel Grid.Column="3" Spacing="8">
                        <Border x:Name="WednesdayHeader" CornerRadius="12" Padding="8,4" Height="85" HorizontalAlignment="Stretch" Background="Transparent">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                <TextBlock x:Name="WednesdayLabel" Text="T4" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource OutlineBrush}"
                                           HorizontalAlignment="Center" CharacterSpacing="80"/>
                                <Border x:Name="WednesdayCircle" Background="Transparent" CornerRadius="20" Width="38" Height="38">
                                    <TextBlock x:Name="WednesdayDate" Text="-" FontSize="20" FontWeight="Black"
                                               Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource TodayColumnBg}" CornerRadius="12" Padding="4">
                            <ItemsControl ItemsSource="{x:Bind WednesdayList}" ItemTemplate="{StaticResource AppointmentCardTemplate}"/>
                        </Border>
                    </StackPanel>

                    <!-- THU NAM -->
                    <StackPanel Grid.Column="4" Spacing="8">
                        <Border x:Name="ThursdayHeader" CornerRadius="12" Padding="8,4" Height="85" HorizontalAlignment="Stretch" Background="Transparent">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                <TextBlock x:Name="ThursdayLabel" Text="T5" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource OutlineBrush}"
                                           HorizontalAlignment="Center" CharacterSpacing="80"/>
                                <Border x:Name="ThursdayCircle" Background="Transparent" CornerRadius="20" Width="38" Height="38">
                                    <TextBlock x:Name="ThursdayDate" Text="-" FontSize="22" FontWeight="Black"
                                               Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <ItemsControl ItemsSource="{x:Bind ThursdayList}" ItemTemplate="{StaticResource AppointmentCardTemplate}"/>
                    </StackPanel>

                    <!-- THU SAU -->
                    <StackPanel Grid.Column="5" Spacing="8">
                        <Border x:Name="FridayHeader" CornerRadius="12" Padding="8,4" Height="85" HorizontalAlignment="Stretch" Background="Transparent">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                <TextBlock x:Name="FridayLabel" Text="T6" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource OutlineBrush}"
                                           HorizontalAlignment="Center" CharacterSpacing="80"/>
                                <Border x:Name="FridayCircle" Background="Transparent" CornerRadius="20" Width="38" Height="38">
                                    <TextBlock x:Name="FridayDate" Text="-" FontSize="22" FontWeight="Black"
                                               Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <ItemsControl ItemsSource="{x:Bind FridayList}" ItemTemplate="{StaticResource AppointmentCardTemplate}"/>
                    </StackPanel>

                    <!-- THU BAY -->
                    <StackPanel Grid.Column="6" Spacing="8">
                        <Border x:Name="SaturdayHeader" CornerRadius="12" Padding="8,4" Height="85" HorizontalAlignment="Stretch" Background="Transparent">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                <TextBlock x:Name="SaturdayLabel" Text="T7" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource OutlineBrush}"
                                           HorizontalAlignment="Center" CharacterSpacing="80"/>
                                <Border x:Name="SaturdayCircle" Background="Transparent" CornerRadius="20" Width="38" Height="38">
                                    <TextBlock x:Name="SaturdayDate" Text="-" FontSize="22" FontWeight="Black"
                                               Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Border>
                        <ItemsControl ItemsSource="{x:Bind SaturdayList}" ItemTemplate="{StaticResource AppointmentCardTemplate}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>


            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- MONTH VIEW PANEL                                        -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <StackPanel x:Name="MonthViewPanel" Visibility="Collapsed" Spacing="24">
                <Border Style="{StaticResource SurfaceCardStyle}" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Click="PrevMonth_Click" Style="{StaticResource NavIconButtonStyle}">
                            <FontIcon Glyph="&#xE76B;" FontSize="14"/>
                        </Button>
                        <TextBlock x:Name="MonthYearText" Grid.Column="1" Text="Tháng 4, 2026" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <Button Grid.Column="2" Click="NextMonth_Click" Style="{StaticResource NavIconButtonStyle}">
                            <FontIcon Glyph="&#xE76C;" FontSize="14"/>
                        </Button>
                    </Grid>
                </Border>

                <Border Style="{StaticResource SurfaceCardStyle}" Padding="8">
                    <Grid x:Name="MonthCalendarGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Header -->
                            <RowDefinition Height="100"/>
                            <RowDefinition Height="100"/>
                            <RowDefinition Height="100"/>
                            <RowDefinition Height="100"/>
                            <RowDefinition Height="100"/>
                            <RowDefinition Height="100"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Day labels -->
                        <TextBlock Grid.Column="0" Text="CN" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondary}" Margin="0,8"/>
                        <TextBlock Grid.Column="1" Text="T2" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondary}" Margin="0,8"/>
                        <TextBlock Grid.Column="2" Text="T3" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondary}" Margin="0,8"/>
                        <TextBlock Grid.Column="3" Text="T4" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondary}" Margin="0,8"/>
                        <TextBlock Grid.Column="4" Text="T5" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondary}" Margin="0,8"/>
                        <TextBlock Grid.Column="5" Text="T6" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondary}" Margin="0,8"/>
                        <TextBlock Grid.Column="6" Text="T7" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource TextSecondary}" Margin="0,8"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- LIST VIEW PANEL                                         -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <StackPanel x:Name="ListViewPanel" Visibility="Collapsed" Spacing="24">
                <Border Style="{StaticResource SurfaceCardStyle}" Padding="0">
                    <ListView x:Name="AllAppointmentsListView"
                              ItemsSource="{x:Bind AllAppointmentsListVM}"
                              SelectionMode="None"
                              Padding="12">
                        <ListView.Header>
                            <Grid Padding="16,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="THỜI GIAN" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondary}" CharacterSpacing="50"/>
                                <TextBlock Grid.Column="1" Text="BỆNH NHÂN" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondary}" CharacterSpacing="50"/>
                                <TextBlock Grid.Column="2" Text="HÌNH THỨC" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondary}" CharacterSpacing="50"/>
                                <TextBlock Grid.Column="3" Text="TRẠNG THÁI" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextSecondary}" CharacterSpacing="50"/>
                            </Grid>
                        </ListView.Header>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:AppointmentViewModel">
                                <Grid Tapped="AppointmentCard_Tapped" Padding="16,12" Background="Transparent" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Time}" FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextPrimary}"/>
                                        <TextBlock Text="{x:Bind DateFormatted}" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{x:Bind PatientName}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource TextPrimary}"/>
                                    <Border Grid.Column="2" Background="{x:Bind TypeBgBrush}" CornerRadius="6" Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind TypeText}" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                    </Border>
                                    <Border Grid.Column="3" Background="{x:Bind TagBgBrush}" CornerRadius="6" Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind StatusText}" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <!-- Pagination -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="24">
                    <Button x:Name="BtnPrevPage" Click="BtnPrevPage_Click" Style="{StaticResource NavIconButtonStyle}" Background="{StaticResource SurfaceBrush}">
                        <FontIcon Glyph="&#xE76B;" FontSize="12"/>
                    </Button>
                    <TextBlock x:Name="PageInfoText" Text="Trang 1 / 1" VerticalAlignment="Center" FontWeight="Bold" Foreground="{StaticResource TextSecondary}"/>
                    <Button x:Name="BtnNextPage" Click="BtnNextPage_Click" Style="{StaticResource NavIconButtonStyle}" Background="{StaticResource SurfaceBrush}">
                        <FontIcon Glyph="&#xE76C;" FontSize="12"/>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- SLOT MANAGEMENT PANEL                                   -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Grid x:Name="SlotManagementPanel" Visibility="Collapsed" ColumnSpacing="32">
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup>
                        <VisualState x:Name="WideState">
                            <VisualState.StateTriggers>
                                <AdaptiveTrigger MinWindowWidth="1000" />
                            </VisualState.StateTriggers>
                        </VisualState>
                        <VisualState x:Name="NarrowState">
                            <VisualState.StateTriggers>
                                <AdaptiveTrigger MinWindowWidth="0" />
                            </VisualState.StateTriggers>
                            <VisualState.Setters>
                                <!-- Setters for narrow layout if needed -->
                                <Setter Target="SlotGrid.ColumnDefinitions[0].Width" Value="*" />
                                <Setter Target="SlotGrid.ColumnDefinitions[1].Width" Value="0" />
                                <Setter Target="RightPanelBorder.(Grid.Row)" Value="1" />
                                <Setter Target="RightPanelBorder.(Grid.Column)" Value="0" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>

                <Grid x:Name="SlotGrid" ColumnSpacing="32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="380"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Left: Configuration Tool -->
                    <Border Grid.Column="0" Style="{StaticResource SurfaceCardStyle}" VerticalAlignment="Top">
                        <StackPanel Spacing="20">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Tạo Khung Giờ" FontSize="20" FontWeight="Bold" Foreground="{StaticResource MedicalBlue}"/>
                                <TextBlock Text="Thiết lập các ca khám tự động cho ngày làm việc" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Text="Ngày áp dụng" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                <DatePicker x:Name="NewSlotDatePicker" HorizontalAlignment="Stretch"/>
                            </StackPanel>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Bắt đầu" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                    <TimePicker x:Name="NewSlotStartTime" ClockIdentifier="24HourClock" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                                <StackPanel Spacing="8" Grid.Column="1">
                                    <TextBlock Text="Kết thúc" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                    <TimePicker x:Name="NewSlotEndTime" ClockIdentifier="24HourClock" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Spacing="8">
                                <TextBlock Text="Thời lượng (phút)" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                <NumberBox x:Name="SlotDurationBox" Value="30" SpinButtonPlacementMode="Inline" HorizontalAlignment="Stretch"/>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Text="Nghỉ giữa ca (phút)" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                                <NumberBox x:Name="BufferDurationBox" Value="5" SpinButtonPlacementMode="Inline" HorizontalAlignment="Stretch"/>
                            </StackPanel>

                            <Button x:Name="BtnAutoCreateSlots" Click="BtnAutoCreateSlots_Click" Content="Tự động tạo ca" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Stretch" Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Right: Slot Inventory -->
                    <Border x:Name="RightPanelBorder" Grid.Column="1" Style="{StaticResource SurfaceCardStyle}">
                        <StackPanel Spacing="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Danh Sách Ca Khám" FontSize="20" FontWeight="Bold"/>
                                    <TextBlock Text="Các khung giờ hiện có trong hệ thống" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
                                    <DatePicker x:Name="FilterSlotDatePicker" DateChanged="FilterSlotDatePicker_DateChanged" Height="38"/>
                                    <Button Click="BtnDeleteAllAvailableSlots_Click" Content="Xóa trống" Foreground="{StaticResource DangerRed}" Background="Transparent" BorderThickness="1" BorderBrush="#FECACA" HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>

                            <ListView x:Name="SlotsListView" ItemsSource="{x:Bind DoctorSlotsList}" SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:SlotViewModel">
                                        <Grid Padding="8,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" ColumnSpacing="20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <FontIcon Glyph="&#xE822;" FontSize="18" Foreground="{StaticResource MedicalBlue}" VerticalAlignment="Center"/>
                                            
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind TimeRange}" FontWeight="Bold" FontSize="15" Foreground="{StaticResource TextPrimary}"/>
                                                <TextBlock Text="{x:Bind DateFormatted}" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                                            </StackPanel>

                                            <Border Grid.Column="2" Background="{x:Bind StatusBg}" CornerRadius="12" Padding="12,3" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind StatusText}" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                            </Border>

                                            <Button Grid.Column="3" Click="BtnDeleteSlot_Click" CommandParameter="{x:Bind Id}" Visibility="{x:Bind CanDeleteVisibility}" Style="{StaticResource NavIconButtonStyle}" Foreground="{StaticResource DangerRed}">
                                                <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>