<Page
    x:Class="Healthcare.Client.UI.Doctor.ManageSchedulePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Healthcare.Client.UI.Doctor"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <!-- Color Resources -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#0059BB"/>
        <SolidColorBrush x:Key="PrimaryContainerBrush" Color="#0070EA"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#46607F"/>
        <SolidColorBrush x:Key="SurfaceContainerBrush" Color="#EDEEEF"/>
        <SolidColorBrush x:Key="SurfaceContainerLowestBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SurfaceContainerLowBrush" Color="#F3F4F5"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#BA1A1A"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#2E7D32"/>
        <SolidColorBrush x:Key="GreenLightBrush" Color="#E8F5E9"/>
        <SolidColorBrush x:Key="GreenBorderBrush" Color="#A5D6A7"/>
        <SolidColorBrush x:Key="OutlineBrush" Color="#717786"/>
        <SolidColorBrush x:Key="OutlineVariantBrush" Color="#C1C6D7"/>
        <SolidColorBrush x:Key="TertiaryFixedBrush" Color="#FFDAD6"/>
        <SolidColorBrush x:Key="TertiaryBrush" Color="#B6171E"/>
        <SolidColorBrush x:Key="SecondaryContainerBrush" Color="#BFD9FD"/>
        <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PrimaryLightBrush" Color="#1A0059BB"/>

        <!-- Card Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceContainerLowestBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <!-- Shift Card Style -->
        <Style x:Key="ShiftCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceContainerLowestBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource OutlineVariantBrush}"/>
        </Style>

        <!-- Day Header Style -->
        <Style x:Key="DayHeaderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceContainerBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8,10"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Nav Icon Button Style -->
        <Style x:Key="NavIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
        </Style>

        <!-- Tab Button Style -->
        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="32,24,32,80" Spacing="0">

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- UPCOMING SHIFT BANNER                                   -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Border
                CornerRadius="16"
                Margin="0,0,0,32"
                Padding="24,18">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0059BB" Offset="0"/>
                        <GradientStop Color="#0070EA" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Icon + Text -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                        <Border
                            Background="#33FFFFFF"
                            CornerRadius="24"
                            Width="44"
                            Height="44">
                            <FontIcon
                                Glyph="&#xEA8F;"
                                FontSize="20"
                                Foreground="White"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock
                                Text="CA TRỰC SẮP TỚI"
                                FontSize="10"
                                FontWeight="Bold"
                                Foreground="#CCFFFFFF"
                                CharacterSpacing="150"/>
                            <TextBlock
                                x:Name="UpcomingShiftText"
                                Text="Khoa Nội - Ngày mai, 08:00 - 16:00"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="White"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Right: Button -->
                    <Button
                        Grid.Column="1"
                        Content="Xem chi tiết"
                        Background="White"
                        Foreground="{StaticResource PrimaryBrush}"
                        CornerRadius="10"
                        Padding="18,10"
                        FontWeight="Bold"
                        FontSize="13"
                        BorderThickness="0"
                        VerticalAlignment="Center"
                        Click="ViewShiftDetail_Click"/>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- PAGE HEADER + FILTER BAR                                -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <StackPanel Grid.Column="0" Spacing="6" VerticalAlignment="Bottom">
                    <TextBlock
                        Text="Lịch Trực Bác Sĩ"
                        FontSize="34"
                        FontWeight="ExtraBold"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <TextBlock
                        Text="Quản lý và điều phối ca trực chuyên khoa"
                        FontSize="14"
                        FontWeight="Medium"
                        Foreground="{StaticResource SecondaryBrush}"/>
                </StackPanel>

                <!-- Controls -->
                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="12"
                    VerticalAlignment="Bottom">

                    <!-- Specialty Filter -->
                    <ComboBox
                        x:Name="SpecialtyComboBox"
                        PlaceholderText="Tất cả chuyên khoa"
                        MinWidth="180"
                        CornerRadius="10"
                        Padding="14,10"
                        FontSize="13"
                        FontWeight="SemiBold">
                        <ComboBoxItem Content="Tất cả chuyên khoa" IsSelected="True"/>
                        <ComboBoxItem Content="Nội tổng quát"/>
                        <ComboBoxItem Content="Tim mạch"/>
                        <ComboBoxItem Content="Nhi khoa"/>
                    </ComboBox>

                    <!-- Register Shift Button -->
                    <Button
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="RegisterShift_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" FontSize="16" Foreground="White"/>
                            <TextBlock Text="Đăng ký ca trực" Foreground="White" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                    <!-- Swap Shift Button -->
                    <Button
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="SwapShift_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8AB;" FontSize="16" Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock Text="Đổi ca trực" Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- VIEW MODE TABS (Tuần / Tháng)                           -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Border
                Background="{StaticResource SurfaceContainerLowBrush}"
                CornerRadius="12"
                Padding="4"
                Margin="0,0,0,20"
                HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <!-- Week Tab -->
                    <Button
                        x:Name="WeekTabButton"
                        Style="{StaticResource TabButtonStyle}"
                        Click="WeekTab_Click">
                        <Button.Background>
                            <SolidColorBrush Color="#0059BB" Opacity="1"/>
                        </Button.Background>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon x:Name="WeekTabIcon" Glyph="&#xE8BF;" FontSize="14" Foreground="White"/>
                            <TextBlock x:Name="WeekTabLabel" Text="Xem theo tuần" Foreground="White" FontWeight="Bold" FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <!-- Month Tab -->
                    <Button
                        x:Name="MonthTabButton"
                        Style="{StaticResource TabButtonStyle}"
                        Click="MonthTab_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon x:Name="MonthTabIcon" Glyph="&#xE787;" FontSize="14" Foreground="{StaticResource SecondaryBrush}"/>
                            <TextBlock x:Name="MonthTabLabel" Text="Xem cả tháng" Foreground="{StaticResource SecondaryBrush}" FontWeight="SemiBold" FontSize="13"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- WEEK VIEW PANEL                                         -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <StackPanel x:Name="WeekViewPanel" Visibility="Visible">

                <!-- ── Week Navigation Bar ── -->
                <Border
                    Background="{StaticResource SurfaceContainerLowestBrush}"
                    CornerRadius="14"
                    Padding="16,12"
                    Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Prev Week -->
                        <Button
                            Grid.Column="0"
                            x:Name="PrevWeekButton"
                            Style="{StaticResource NavIconButtonStyle}"
                            Click="PrevWeek_Click"
                            ToolTipService.ToolTip="Tuần trước">
                            <FontIcon Glyph="&#xE76B;" FontSize="14"/>
                        </Button>

                        <!-- Week Label -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
                            <TextBlock
                                x:Name="WeekRangeText"
                                Text="20 – 26 tháng 1, 2025"
                                FontSize="15"
                                FontWeight="Bold"
                                HorizontalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock
                                x:Name="WeekNumberText"
                                Text="Tuần 4 · Tháng 1 năm 2025"
                                FontSize="11"
                                FontWeight="Medium"
                                HorizontalAlignment="Center"
                                Foreground="{StaticResource SecondaryBrush}"/>
                        </StackPanel>

                        <!-- Next Week -->
                        <Button
                            Grid.Column="2"
                            x:Name="NextWeekButton"
                            Style="{StaticResource NavIconButtonStyle}"
                            Click="NextWeek_Click"
                            ToolTipService.ToolTip="Tuần sau">
                            <FontIcon Glyph="&#xE76C;" FontSize="14"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- ── CALENDAR BENTO GRID (7 columns) ── -->
                <Grid x:Name="WeekGrid" Margin="0,0,0,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><!-- Sun -->
                        <ColumnDefinition Width="*"/><!-- Mon -->
                        <ColumnDefinition Width="*"/><!-- Tue -->
                        <ColumnDefinition Width="*"/><!-- Wed -->
                        <ColumnDefinition Width="*"/><!-- Thu -->
                        <ColumnDefinition Width="*"/><!-- Fri -->
                        <ColumnDefinition Width="*"/><!-- Sat -->
                    </Grid.ColumnDefinitions>

                    <!-- ── SUNDAY (Col 0) ── -->
                    <Border x:Name="SundayColumnBorder" Grid.Column="0" CornerRadius="16" Margin="0,0,6,0" Background="Transparent">
                        <StackPanel x:Name="SundayColumn" Spacing="0" Margin="4">
                            <Border x:Name="SundayHeader" Style="{StaticResource DayHeaderStyle}">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <TextBlock x:Name="SundayDayName" Text="CHỦ NHẬT" FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource OutlineBrush}"
                                               CharacterSpacing="100" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="SundayDate" Text="20" FontSize="20" FontWeight="Black" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="12" Padding="14" Background="{StaticResource SurfaceContainerLowestBrush}">
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#BA1A1A" Opacity="0.35"/>
                                </Border.BorderBrush>
                                <Border.BorderThickness>4,0,0,0</Border.BorderThickness>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="CA ĐÊM" FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource ErrorBrush}" CharacterSpacing="80"/>
                                    <TextBlock Text="22:00 - 06:00" FontSize="12" FontWeight="Bold"/>
                                    <TextBlock Text="BS. Lê Văn C" FontSize="11"
                                               Foreground="{StaticResource SecondaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ── MONDAY (Col 1) ── -->
                    <Border x:Name="MondayColumnBorder" Grid.Column="1" CornerRadius="16" Margin="0,0,6,0" Background="Transparent">
                        <StackPanel x:Name="MondayColumn" Spacing="0" Margin="4">
                            <Border x:Name="MondayHeader" CornerRadius="8" Padding="8,10" Margin="0,0,0,12"
                                    Background="{StaticResource SurfaceContainerBrush}">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <TextBlock x:Name="MondayDayName" Text="THỨ HAI" FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource OutlineBrush}"
                                               CharacterSpacing="100" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="MondayDate" Text="21" FontSize="20" FontWeight="Black"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Your Shift Card -->
                            <Border CornerRadius="12" Padding="14" Margin="0,0,0,10">
                                <Border.Background>
                                    <SolidColorBrush Color="#BFD9FD" Opacity="0.35"/>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#BFD9FD"/>
                                </Border.BorderBrush>
                                <Border.BorderThickness>
                                    <Thickness>1</Thickness>
                                </Border.BorderThickness>
                                <StackPanel Spacing="6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" CornerRadius="10"
                                                Padding="6,2" HorizontalAlignment="Left">
                                            <Border.Background>
                                                <SolidColorBrush Color="#0059BB"/>
                                            </Border.Background>
                                            <TextBlock Text="Ca của bạn" FontSize="9" FontWeight="Bold"
                                                       Foreground="White" CharacterSpacing="50"/>
                                        </Border>
                                        <FontIcon Grid.Column="1" Glyph="&#xE735;" FontSize="14"
                                                  Foreground="{StaticResource PrimaryBrush}"/>
                                    </Grid>
                                    <TextBlock Text="08:00 - 16:00" FontSize="14" FontWeight="Bold"/>
                                    <TextBlock Text="Khoa Nội TQ" FontSize="11"
                                               Foreground="{StaticResource SecondaryBrush}"/>
                                    <Button
                                        Content="Đổi ca"
                                        HorizontalAlignment="Stretch"
                                        Background="White"
                                        Foreground="{StaticResource PrimaryBrush}"
                                        CornerRadius="8"
                                        Padding="0,8"
                                        FontSize="11"
                                        FontWeight="Bold"
                                        BorderThickness="1"
                                        BorderBrush="{StaticResource OutlineVariantBrush}"
                                        Click="SwapShiftCard_Click"/>
                                </StackPanel>
                            </Border>

                            <!-- Empty Slot Card -->
                            <Border CornerRadius="12" Padding="14"
                                    Background="{StaticResource GreenLightBrush}"
                                    BorderBrush="{StaticResource GreenBorderBrush}"
                                    BorderThickness="1">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="CÒN TRỐNG" FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource GreenBrush}" CharacterSpacing="80"/>
                                    <TextBlock Text="16:00 - 22:00" FontSize="14" FontWeight="Bold"
                                               Foreground="#1B5E20"/>
                                    <TextBlock Text="Chưa có BS" FontSize="11"
                                               Foreground="{StaticResource GreenBrush}"/>
                                    <Button
                                        Content="Đăng ký"
                                        HorizontalAlignment="Stretch"
                                        Background="#2E7D32"
                                        Foreground="White"
                                        CornerRadius="8"
                                        Padding="0,8"
                                        FontSize="11"
                                        FontWeight="Bold"
                                        BorderThickness="0"
                                        Click="RegisterEmptySlot_Click"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border> <!-- end MondayColumnBorder -->

                    <!-- ── TUESDAY (Col 2) ── -->
                    <Border x:Name="TuesdayColumnBorder" Grid.Column="2" CornerRadius="16" Margin="0,0,6,0" Background="Transparent">
                        <StackPanel x:Name="TuesdayColumn" Spacing="0" Margin="4">
                            <Border x:Name="TuesdayHeader" Style="{StaticResource DayHeaderStyle}">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <TextBlock x:Name="TuesdayDayName" Text="THỨ BA" FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource OutlineBrush}"
                                               CharacterSpacing="100" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TuesdayDate" Text="22" FontSize="20" FontWeight="Black" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="12" Padding="14" Margin="0,0,0,10"
                                    Background="{StaticResource SurfaceContainerLowestBrush}">
                                <Border.BorderThickness>4,0,0,0</Border.BorderThickness>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#46607F" Opacity="0.35"/>
                                </Border.BorderBrush>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="CA SÁNG" FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource SecondaryBrush}" CharacterSpacing="80"/>
                                    <TextBlock Text="08:00 - 16:00" FontSize="12" FontWeight="Bold"/>
                                    <TextBlock Text="BS. Hoàng Diệu" FontSize="11"
                                               Foreground="{StaticResource SecondaryBrush}"/>
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="12" Padding="14"
                                    Background="{StaticResource SurfaceContainerLowestBrush}">
                                <Border.BorderThickness>4,0,0,0</Border.BorderThickness>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#46607F" Opacity="0.35"/>
                                </Border.BorderBrush>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="CA CHIỀU" FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource SecondaryBrush}" CharacterSpacing="80"/>
                                    <TextBlock Text="16:00 - 22:00" FontSize="12" FontWeight="Bold"/>
                                    <TextBlock Text="BS. Trần Nam" FontSize="11"
                                               Foreground="{StaticResource SecondaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ── WEDNESDAY (Col 3) ── -->
                    <Border x:Name="WednesdayColumnBorder" Grid.Column="3" CornerRadius="16" Margin="0,0,6,0" Background="Transparent">
                        <StackPanel x:Name="WednesdayColumn" Spacing="0" Margin="4">
                            <Border x:Name="WednesdayHeader" Style="{StaticResource DayHeaderStyle}">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <TextBlock x:Name="WednesdayDayName" Text="THỨ TƯ" FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource OutlineBrush}"
                                               CharacterSpacing="100" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="WednesdayDate" Text="23" FontSize="20" FontWeight="Black" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="12" Padding="14"
                                    Background="{StaticResource GreenLightBrush}"
                                    BorderBrush="{StaticResource GreenBorderBrush}"
                                    BorderThickness="1">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="CÒN TRỐNG" FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource GreenBrush}" CharacterSpacing="80"/>
                                    <TextBlock Text="08:00 - 16:00" FontSize="14" FontWeight="Bold"
                                               Foreground="#1B5E20"/>
                                    <Button
                                        Content="Đăng ký"
                                        HorizontalAlignment="Stretch"
                                        Background="#2E7D32"
                                        Foreground="White"
                                        CornerRadius="8"
                                        Padding="0,8"
                                        FontSize="11"
                                        FontWeight="Bold"
                                        BorderThickness="0"
                                        Margin="0,6,0,0"
                                        Click="RegisterEmptySlot_Click"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ── THURSDAY (Col 4) ── -->
                    <Border x:Name="ThursdayColumnBorder" Grid.Column="4" CornerRadius="16" Margin="0,0,6,0" Background="Transparent">
                        <StackPanel x:Name="ThursdayColumn" Spacing="0" Margin="4">
                            <Border x:Name="ThursdayHeader" Style="{StaticResource DayHeaderStyle}">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <TextBlock x:Name="ThursdayDayName" Text="THỨ NĂM" FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource OutlineBrush}"
                                               CharacterSpacing="100" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="ThursdayDate" Text="24" FontSize="20" FontWeight="Black" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                            <Border CornerRadius="12" Padding="14">
                                <Border.Background>
                                    <SolidColorBrush Color="#BFD9FD" Opacity="0.35"/>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#BFD9FD"/>
                                </Border.BorderBrush>
                                <Border.BorderThickness>
                                    <Thickness>1</Thickness>
                                </Border.BorderThickness>
                                <StackPanel Spacing="6">
                                    <Border CornerRadius="10" Padding="6,2" HorizontalAlignment="Left">
                                        <Border.Background>
                                            <SolidColorBrush Color="#0059BB"/>
                                        </Border.Background>
                                        <TextBlock Text="Ca của bạn" FontSize="9" FontWeight="Bold"
                                                   Foreground="White" CharacterSpacing="50"/>
                                    </Border>
                                    <TextBlock Text="16:00 - 22:00" FontSize="14" FontWeight="Bold"/>
                                    <TextBlock Text="Khoa Nội TQ" FontSize="11"
                                               Foreground="{StaticResource SecondaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border> <!-- end ThursdayColumnBorder -->

                    <!-- ── FRIDAY (Col 5) ── -->
                    <Border x:Name="FridayColumnBorder" Grid.Column="5" CornerRadius="16" Margin="0,0,6,0" Background="Transparent">
                        <StackPanel x:Name="FridayColumn" Spacing="0" Margin="4">
                            <Border x:Name="FridayHeader" Style="{StaticResource DayHeaderStyle}">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <TextBlock x:Name="FridayDayName" Text="THỨ SÁU" FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource OutlineBrush}"
                                               CharacterSpacing="100" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="FridayDate" Text="25" FontSize="20" FontWeight="Black" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="12" Padding="14"
                                    Background="{StaticResource SurfaceContainerLowestBrush}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="08:00 - 16:00" FontSize="12" FontWeight="Bold"/>
                                    <TextBlock Text="BS. Phan Anh" FontSize="11"
                                               Foreground="{StaticResource SecondaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ── SATURDAY (Col 6) ── -->
                    <Border x:Name="SaturdayColumnBorder" Grid.Column="6" CornerRadius="16" Background="Transparent">
                        <StackPanel x:Name="SaturdayColumn" Spacing="0" Margin="4">
                            <Border x:Name="SaturdayHeader" Style="{StaticResource DayHeaderStyle}">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <TextBlock x:Name="SaturdayDayName" Text="THỨ BẢY" FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource OutlineBrush}"
                                               CharacterSpacing="100" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="SaturdayDate" Text="26" FontSize="20" FontWeight="Black" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="12" Padding="24" MinHeight="100"
                                    BorderBrush="{StaticResource OutlineVariantBrush}"
                                    BorderThickness="2">
                                <Border.Background>
                                    <SolidColorBrush Color="#EDEEEF" Opacity="0.5"/>
                                </Border.Background>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Spacing="6" Opacity="0.45">
                                    <FontIcon Glyph="&#xE787;" FontSize="30"
                                              HorizontalAlignment="Center"
                                              Foreground="{StaticResource OutlineBrush}"/>
                                    <TextBlock Text="Chưa có lịch" FontSize="10" FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               Foreground="{StaticResource OutlineBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- MONTH VIEW PANEL                                        -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <StackPanel x:Name="MonthViewPanel" Visibility="Collapsed">

                <!-- Month Navigation Bar -->
                <Border
                    Background="{StaticResource SurfaceContainerLowestBrush}"
                    CornerRadius="14"
                    Padding="16,12"
                    Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button
                            Grid.Column="0"
                            x:Name="PrevMonthButton"
                            Style="{StaticResource NavIconButtonStyle}"
                            Click="PrevMonth_Click"
                            ToolTipService.ToolTip="Tháng trước">
                            <FontIcon Glyph="&#xE76B;" FontSize="14"/>
                        </Button>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
                            <TextBlock
                                x:Name="MonthYearText"
                                Text="Tháng 1, 2025"
                                FontSize="16"
                                FontWeight="Bold"
                                HorizontalAlignment="Center"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock
                                x:Name="MonthSubText"
                                Text="Xem toàn cảnh lịch trực cả tháng"
                                FontSize="11"
                                FontWeight="Medium"
                                HorizontalAlignment="Center"
                                Foreground="{StaticResource SecondaryBrush}"/>
                        </StackPanel>

                        <Button
                            Grid.Column="2"
                            x:Name="NextMonthButton"
                            Style="{StaticResource NavIconButtonStyle}"
                            Click="NextMonth_Click"
                            ToolTipService.ToolTip="Tháng sau">
                            <FontIcon Glyph="&#xE76C;" FontSize="14"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- ── Day-of-week headers ── -->
                <Border
                    Background="{StaticResource SurfaceContainerBrush}"
                    CornerRadius="10"
                    Padding="0,10"
                    Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="CN" FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center" Foreground="{StaticResource ErrorBrush}"/>
                        <TextBlock Grid.Column="1" Text="T2" FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center" Foreground="{StaticResource OutlineBrush}"/>
                        <TextBlock Grid.Column="2" Text="T3" FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center" Foreground="{StaticResource OutlineBrush}"/>
                        <TextBlock Grid.Column="3" Text="T4" FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center" Foreground="{StaticResource OutlineBrush}"/>
                        <TextBlock Grid.Column="4" Text="T5" FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center" Foreground="{StaticResource OutlineBrush}"/>
                        <TextBlock Grid.Column="5" Text="T6" FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center" Foreground="{StaticResource OutlineBrush}"/>
                        <TextBlock Grid.Column="6" Text="T7" FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center" Foreground="{StaticResource SecondaryBrush}"/>
                    </Grid>
                </Border>

                <!-- ── Month Calendar Grid (dynamically populated) ── -->
                <Border
                    Background="{StaticResource SurfaceContainerLowestBrush}"
                    CornerRadius="14"
                    Padding="8"
                    Margin="0,0,0,32">
                    <ItemsControl x:Name="MonthCalendarGrid">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Grid x:Name="MonthInnerGrid">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                </Grid>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </Border>

                <!-- ── Month Legend ── -->
                <Border
                    Background="{StaticResource SurfaceContainerLowestBrush}"
                    CornerRadius="12"
                    Padding="20,14"
                    Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal" Spacing="24">
                        <TextBlock Text="Chú thích:" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource SecondaryBrush}" VerticalAlignment="Center"/>
                        <!-- Ca của bạn -->
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Border Width="12" Height="12" CornerRadius="3" Background="#0059BB"/>
                            <TextBlock Text="Ca của bạn" FontSize="12" Foreground="{StaticResource SecondaryBrush}"/>
                        </StackPanel>
                        <!-- Ca đêm -->
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Border Width="12" Height="12" CornerRadius="3" Background="#BA1A1A"/>
                            <TextBlock Text="Ca đêm" FontSize="12" Foreground="{StaticResource SecondaryBrush}"/>
                        </StackPanel>
                        <!-- Còn trống -->
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Border Width="12" Height="12" CornerRadius="3" Background="#2E7D32"/>
                            <TextBlock Text="Còn trống" FontSize="12" Foreground="{StaticResource SecondaryBrush}"/>
                        </StackPanel>
                        <!-- Hôm nay -->
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Border Width="12" Height="12" CornerRadius="3">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#0059BB" Offset="0"/>
                                        <GradientStop Color="#0070EA" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <TextBlock Text="Hôm nay" FontSize="12" Foreground="{StaticResource SecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- INSIGHT CARDS (3 columns)                              -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Card 1: Hours this month -->
                <Border Grid.Column="0" CornerRadius="16" Padding="24"
                        Background="{StaticResource SurfaceContainerLowestBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                        <Border CornerRadius="14" Width="56" Height="56">
                            <Border.Background>
                                <SolidColorBrush Color="#0059BB" Opacity="0.1"/>
                            </Border.Background>
                            <FontIcon Glyph="&#xE916;" FontSize="26"
                                      Foreground="{StaticResource PrimaryBrush}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Giờ trực tháng này"
                                       FontSize="13" FontWeight="Medium"
                                       Foreground="{StaticResource SecondaryBrush}"/>
                            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Bottom">
                                <TextBlock Text="142h"
                                           FontSize="24" FontWeight="Black"/>
                                <TextBlock Text="/ 160h"
                                           FontSize="12" FontWeight="Medium"
                                           Foreground="{StaticResource OutlineBrush}"
                                           VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Card 2: Completed shifts -->
                <Border Grid.Column="2" CornerRadius="16" Padding="24"
                        Background="{StaticResource SurfaceContainerLowestBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                        <Border CornerRadius="14" Width="56" Height="56"
                                Background="{StaticResource GreenLightBrush}">
                            <FontIcon Glyph="&#xE930;" FontSize="26"
                                      Foreground="{StaticResource GreenBrush}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Số ca đã hoàn thành"
                                       FontSize="13" FontWeight="Medium"
                                       Foreground="{StaticResource SecondaryBrush}"/>
                            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Bottom">
                                <TextBlock Text="18"
                                           FontSize="24" FontWeight="Black"/>
                                <TextBlock Text="ca trực"
                                           FontSize="12" FontWeight="Medium"
                                           Foreground="{StaticResource OutlineBrush}"
                                           VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Card 3: Pending swap requests -->
                <Border Grid.Column="4" CornerRadius="16" Padding="24"
                        Background="{StaticResource SurfaceContainerLowestBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                        <Border CornerRadius="14" Width="56" Height="56"
                                Background="{StaticResource TertiaryFixedBrush}">
                            <FontIcon Glyph="&#xE8AB;" FontSize="26"
                                      Foreground="{StaticResource TertiaryBrush}"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="Yêu cầu đổi ca chờ"
                                       FontSize="13" FontWeight="Medium"
                                       Foreground="{StaticResource SecondaryBrush}"/>
                            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Bottom">
                                <TextBlock Text="02"
                                           FontSize="24" FontWeight="Black"/>
                                <TextBlock Text="yêu cầu"
                                           FontSize="12" FontWeight="Medium"
                                           Foreground="{StaticResource OutlineBrush}"
                                           VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>
