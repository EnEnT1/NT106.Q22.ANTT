<Page
    x:Class="Healthcare.Client.UI.Doctor.ManageSchedulePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Healthcare.Client.UI.Doctor"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <!-- Color Resources -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#0059BB"/>
        <SolidColorBrush x:Key="PrimaryContainerBrush" Color="#0070EA"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#46607F"/>
        <SolidColorBrush x:Key="SurfaceContainerBrush" Color="#EDEEEF"/>
        <SolidColorBrush x:Key="SurfaceContainerLowestBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SurfaceContainerLowBrush" Color="#F3F4F5"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#BA1A1A"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#2E7D32"/>
        <SolidColorBrush x:Key="GreenLightBrush" Color="#E8F5E9"/>
        <SolidColorBrush x:Key="GreenBorderBrush" Color="#A5D6A7"/>
        <SolidColorBrush x:Key="OutlineBrush" Color="#717786"/>
        <SolidColorBrush x:Key="OutlineVariantBrush" Color="#C1C6D7"/>
        <SolidColorBrush x:Key="TertiaryFixedBrush" Color="#FFDAD6"/>
        <SolidColorBrush x:Key="TertiaryBrush" Color="#B6171E"/>
        <SolidColorBrush x:Key="SecondaryContainerBrush" Color="#BFD9FD"/>
        <SolidColorBrush x:Key="WhiteBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="PrimaryLightBrush" Color="#1A0059BB"/>

        <!-- Appointment Card Template -->
        <DataTemplate x:Key="AppointmentCardTemplate" x:DataType="local:AppointmentViewModel">
            <Border 
                CornerRadius="12" 
                Padding="14" 
                Margin="0,0,0,10" 
                Background="{x:Bind BgBrush}"
                Tapped="AppointmentCard_Tapped">
                <Border.BorderThickness>1</Border.BorderThickness>
                <Border.BorderBrush>
                    <SolidColorBrush Color="{x:Bind BorderColorCode}"/>
                </Border.BorderBrush>
                <StackPanel Spacing="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border 
                            Grid.Column="0" 
                            CornerRadius="10" 
                            Padding="6,2" 
                            HorizontalAlignment="Left" 
                            Background="{x:Bind TagBgBrush}">
                            <TextBlock 
                                Text="{x:Bind StatusText}" 
                                FontSize="9" 
                                FontWeight="Bold" 
                                Foreground="White" 
                                CharacterSpacing="50"/>
                        </Border>
                        <FontIcon 
                            Grid.Column="1" 
                            Glyph="&#xE735;" 
                            FontSize="14" 
                            Foreground="{x:Bind TagBgBrush}"/>
                    </Grid>

                    <StackPanel Spacing="2">
                        <TextBlock 
                            Text="{x:Bind Time}" 
                            FontSize="14" 
                            FontWeight="Bold"/>
                        <TextBlock 
                            Text="{x:Bind PatientName}" 
                            FontSize="12" 
                            Foreground="{StaticResource SecondaryBrush}" 
                            FontWeight="SemiBold"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                        <Border Background="{x:Bind TypeBgBrush}" 
                                CornerRadius="4" 
                                Padding="4,1">
                            <TextBlock Text="{x:Bind TypeText}" FontSize="9" Foreground="White" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>

                    <!-- Actions removed - handle in Detail page -->
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{StaticResource OutlineVariantBrush}"/>
        </Style>

        <!-- Day Header Style -->
        <Style x:Key="DayHeaderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceContainerBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8,10"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <!-- Nav Icon Button Style -->
        <Style x:Key="NavIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
        </Style>

        <!-- Tab Button Style -->
        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter x:Name="ContentPresenter"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Content="{TemplateBinding Content}"
                            ContentTransitions="{TemplateBinding ContentTransitions}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            Padding="{TemplateBinding Padding}"
                            HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                            <ContentPresenter.RenderTransform>
                                <CompositeTransform x:Name="ContentTransform" ScaleX="1.0" ScaleY="1.0" CenterX="40" CenterY="15"/>
                            </ContentPresenter.RenderTransform>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ContentTransform" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="ContentTransform" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ContentTransform" Storyboard.TargetProperty="ScaleX" To="1.05" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="ContentTransform" Storyboard.TargetProperty="ScaleY" To="1.05" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ContentTransform" Storyboard.TargetProperty="ScaleX" To="0.95" Duration="0:0:0.05"/>
                                            <DoubleAnimation Storyboard.TargetName="ContentTransform" Storyboard.TargetProperty="ScaleY" To="0.95" Duration="0:0:0.05"/>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </ContentPresenter>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <ScrollViewer 
        VerticalScrollBarVisibility="Auto" 
        HorizontalScrollBarVisibility="Disabled">
        <StackPanel 
            Margin="32,24,32,80" 
            Spacing="0">

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- UPCOMING SHIFT BANNER                                   -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Border
                CornerRadius="16"
                Margin="0,0,0,32"
                Padding="24,18">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0059BB" Offset="0"/>
                        <GradientStop Color="#0070EA" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel 
                        Grid.Column="0" 
                        Orientation="Horizontal" 
                        Spacing="16" 
                        VerticalAlignment="Center">
                        <Border 
                            Background="#33FFFFFF" 
                            CornerRadius="24" 
                            Width="44" 
                            Height="44">
                            <FontIcon 
                                Glyph="&#xE8F9;" 
                                FontSize="20" 
                                Foreground="White" 
                                VerticalAlignment="Center" 
                                HorizontalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock 
                                Text="CA KHÁM SẮP TỚI" 
                                FontSize="10" 
                                FontWeight="Bold" 
                                Foreground="#CCFFFFFF" 
                                CharacterSpacing="150"/>
                            <TextBlock 
                                x:Name="UpcomingShiftText" 
                                Text="Đang cập nhật..." 
                                FontSize="16" 
                                FontWeight="SemiBold" 
                                Foreground="White"/>
                        </StackPanel>
                    </StackPanel>

                    <Button 
                        Grid.Column="1" 
                        Content="Làm mới lịch khám" 
                        Background="White" 
                        Foreground="{StaticResource PrimaryBrush}" 
                        CornerRadius="10" 
                        Padding="18,10" 
                        FontWeight="Bold" 
                        FontSize="13" 
                        VerticalAlignment="Center" 
                        Click="BtnRefresh_Click"/>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- PAGE HEADER                                            -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Grid x:Name="PageHeaderGrid" Margin="0,0,0,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <StackPanel 
                    Grid.Column="0" 
                    Spacing="6" 
                    VerticalAlignment="Bottom">
                    <TextBlock
                        Text="Quản lý lịch khám"
                        FontSize="34"
                        FontWeight="ExtraBold"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <TextBlock
                        Text="Quản lý lịch hẹn, gọi video và nhập bệnh án"
                        FontSize="14"
                        FontWeight="Medium"
                        Foreground="{StaticResource SecondaryBrush}"/>
                </StackPanel>

                <!-- Real-time Clock -->
                <StackPanel 
                    x:Name="ClockPanel"
                    Grid.Column="1" 
                    VerticalAlignment="Bottom" 
                    HorizontalAlignment="Right" 
                    Spacing="2">
                    <TextBlock 
                        x:Name="CurrentTimeText" 
                        Text="00:00:00" 
                        FontSize="30" 
                        FontWeight="Black" 
                        Foreground="{StaticResource PrimaryBrush}" 
                        HorizontalAlignment="Right"/>
                    <TextBlock 
                        x:Name="CurrentDateText" 
                        Text="Thời gian thực" 
                        FontSize="13" 
                        FontWeight="Bold" 
                        Foreground="{StaticResource SecondaryBrush}" 
                        HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- VIEW MODE TABS                                         -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Border
                Background="{StaticResource SurfaceContainerLowBrush}"
                CornerRadius="12"
                Padding="4"
                Margin="0,0,0,20"
                HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <Button 
                        x:Name="ListTabButton" 
                        Click="ListTab_Click" 
                        Style="{StaticResource TabButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon 
                                x:Name="ListTabIcon"
                                Glyph="&#xE8FD;" 
                                FontSize="14" 
                                Foreground="{StaticResource SecondaryBrush}"/>
                            <TextBlock 
                                x:Name="ListTabLabel"
                                Text="Dạng danh sách" 
                                Foreground="{StaticResource SecondaryBrush}" 
                                FontWeight="SemiBold" 
                                FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Button 
                        x:Name="WeekTabButton" 
                        Click="WeekTab_Click" 
                        Style="{StaticResource TabButtonStyle}"
                        Background="{StaticResource PrimaryBrush}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon 
                                x:Name="WeekTabIcon"
                                Glyph="&#xE8BF;" 
                                FontSize="14" 
                                Foreground="White"/>
                            <TextBlock 
                                x:Name="WeekTabLabel"
                                Text="Xem theo tuần" 
                                Foreground="White" 
                                FontWeight="Bold" 
                                FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Button 
                        x:Name="MonthTabButton" 
                        Click="MonthTab_Click" 
                        Style="{StaticResource TabButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon 
                                x:Name="MonthTabIcon"
                                Glyph="&#xE787;" 
                                FontSize="14" 
                                Foreground="{StaticResource SecondaryBrush}"/>
                            <TextBlock 
                                x:Name="MonthTabLabel"
                                Text="Xem cả tháng" 
                                Foreground="{StaticResource SecondaryBrush}" 
                                FontWeight="SemiBold" 
                                FontSize="13"/>
                        </StackPanel>
                    </Button>
                    <Button 
                        x:Name="SlotTabButton" 
                        Click="SlotTab_Click" 
                        Style="{StaticResource TabButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon 
                                x:Name="SlotTabIcon"
                                Glyph="&#xE8B0;" 
                                FontSize="14" 
                                Foreground="{StaticResource SecondaryBrush}"/>
                            <TextBlock 
                                x:Name="SlotTabLabel"
                                Text="Quản lý lịch khám" 
                                Foreground="{StaticResource SecondaryBrush}" 
                                FontWeight="SemiBold" 
                                FontSize="13"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- WEEK VIEW PANEL                                         -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <StackPanel x:Name="WeekViewPanel" Visibility="Visible">

                <!-- ── Week Navigation Bar ── -->
                <Border
                    Background="{StaticResource SurfaceContainerLowestBrush}"
                    CornerRadius="14"
                    Padding="16,12"
                    Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button 
                            Grid.Column="0" 
                            Style="{StaticResource NavIconButtonStyle}" 
                            Click="PrevWeek_Click">
                            <FontIcon Glyph="&#xE76B;" FontSize="14"/>
                        </Button>

                        <StackPanel 
                            Grid.Column="1" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center" 
                            Spacing="2">
                            <TextBlock 
                                x:Name="WeekRangeText" 
                                Text="Tuần hiện tại" 
                                FontSize="15" 
                                FontWeight="Bold" 
                                HorizontalAlignment="Center" 
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </StackPanel>

                        <Button 
                            Grid.Column="2" 
                            Style="{StaticResource NavIconButtonStyle}" 
                            Click="NextWeek_Click">
                            <FontIcon Glyph="&#xE76C;" FontSize="14"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- ── CALENDAR BENTO GRID ── -->
                <Grid x:Name="WeekGrid" Margin="0,0,0,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="16" Margin="0,0,6,0" Background="Transparent">
                        <StackPanel Spacing="0" Margin="4">
                            <Border Style="{StaticResource DayHeaderStyle}">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <TextBlock 
                                        Text="CHỦ NHẬT" 
                                        FontSize="9" 
                                        FontWeight="Bold" 
                                        Foreground="{StaticResource OutlineBrush}" 
                                        CharacterSpacing="100"/>
                                    <TextBlock 
                                        x:Name="SundayDate" 
                                        Text="-" 
                                        FontSize="20" 
                                        FontWeight="Black" 
                                        HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ItemsControl 
                                ItemsSource="{x:Bind SundayList}" 
                                ItemTemplate="{StaticResource AppointmentCardTemplate}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" CornerRadius="16" Margin="0,0,6,0" Background="Transparent">
                        <StackPanel Spacing="0" Margin="4">
                            <Border CornerRadius="8" Padding="8,10" Margin="0,0,0,12" Background="{StaticResource SurfaceContainerBrush}">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <TextBlock 
                                        Text="THỨ HAI" 
                                        FontSize="9" 
                                        FontWeight="Bold" 
                                        Foreground="{StaticResource OutlineBrush}" 
                                        CharacterSpacing="100"/>
                                    <TextBlock 
                                        x:Name="MondayDate" 
                                        Text="-" 
                                        FontSize="20" 
                                        FontWeight="Black" 
                                        HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ItemsControl 
                                ItemsSource="{x:Bind MondayList}" 
                                ItemTemplate="{StaticResource AppointmentCardTemplate}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" CornerRadius="16" Margin="0,0,6,0" Background="Transparent">
                        <StackPanel Spacing="0" Margin="4">
                            <Border Style="{StaticResource DayHeaderStyle}">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <TextBlock 
                                        Text="THỨ BA" 
                                        FontSize="9" 
                                        FontWeight="Bold" 
                                        Foreground="{StaticResource OutlineBrush}" 
                                        CharacterSpacing="100"/>
                                    <TextBlock 
                                        x:Name="TuesdayDate" 
                                        Text="-" 
                                        FontSize="20" 
                                        FontWeight="Black" 
                                        HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ItemsControl 
                                ItemsSource="{x:Bind TuesdayList}" 
                                ItemTemplate="{StaticResource AppointmentCardTemplate}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" CornerRadius="16" Margin="0,0,6,0" Background="Transparent">
                        <StackPanel Spacing="0" Margin="4">
                            <Border Style="{StaticResource DayHeaderStyle}">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <TextBlock 
                                        Text="THỨ TƯ" 
                                        FontSize="9" 
                                        FontWeight="Bold" 
                                        Foreground="{StaticResource OutlineBrush}" 
                                        CharacterSpacing="100"/>
                                    <TextBlock 
                                        x:Name="WednesdayDate" 
                                        Text="-" 
                                        FontSize="20" 
                                        FontWeight="Black" 
                                        HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ItemsControl 
                                ItemsSource="{x:Bind WednesdayList}" 
                                ItemTemplate="{StaticResource AppointmentCardTemplate}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4" CornerRadius="16" Margin="0,0,6,0" Background="Transparent">
                        <StackPanel Spacing="0" Margin="4">
                            <Border Style="{StaticResource DayHeaderStyle}">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <TextBlock 
                                        Text="THỨ NĂM" 
                                        FontSize="9" 
                                        FontWeight="Bold" 
                                        Foreground="{StaticResource OutlineBrush}" 
                                        CharacterSpacing="100"/>
                                    <TextBlock 
                                        x:Name="ThursdayDate" 
                                        Text="-" 
                                        FontSize="20" 
                                        FontWeight="Black" 
                                        HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ItemsControl 
                                ItemsSource="{x:Bind ThursdayList}" 
                                ItemTemplate="{StaticResource AppointmentCardTemplate}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="5" CornerRadius="16" Margin="0,0,6,0" Background="Transparent">
                        <StackPanel Spacing="0" Margin="4">
                            <Border Style="{StaticResource DayHeaderStyle}">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <TextBlock 
                                        Text="THỨ SÁU" 
                                        FontSize="9" 
                                        FontWeight="Bold" 
                                        Foreground="{StaticResource OutlineBrush}" 
                                        CharacterSpacing="100"/>
                                    <TextBlock 
                                        x:Name="FridayDate" 
                                        Text="-" 
                                        FontSize="20" 
                                        FontWeight="Black" 
                                        HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ItemsControl 
                                ItemsSource="{x:Bind FridayList}" 
                                ItemTemplate="{StaticResource AppointmentCardTemplate}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="6" CornerRadius="16" Background="Transparent">
                        <StackPanel Spacing="0" Margin="4">
                            <Border Style="{StaticResource DayHeaderStyle}">
                                <StackPanel HorizontalAlignment="Center" Spacing="2">
                                    <TextBlock 
                                        Text="THỨ BẢY" 
                                        FontSize="9" 
                                        FontWeight="Bold" 
                                        Foreground="{StaticResource OutlineBrush}" 
                                        CharacterSpacing="100"/>
                                    <TextBlock 
                                        x:Name="SaturdayDate" 
                                        Text="-" 
                                        FontSize="20" 
                                        FontWeight="Black" 
                                        HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ItemsControl 
                                ItemsSource="{x:Bind SaturdayList}" 
                                ItemTemplate="{StaticResource AppointmentCardTemplate}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- MONTH VIEW PANEL                                        -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <StackPanel x:Name="MonthViewPanel" Visibility="Collapsed">
                <Border 
                    Background="{StaticResource SurfaceContainerLowestBrush}" 
                    CornerRadius="14" 
                    Padding="16,12" 
                    Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button 
                            Grid.Column="0" 
                            Style="{StaticResource NavIconButtonStyle}" 
                            Click="PrevMonth_Click">
                            <FontIcon Glyph="&#xE76B;" FontSize="14"/>
                        </Button>

                        <StackPanel 
                            Grid.Column="1" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center" 
                            Spacing="2">
                            <TextBlock 
                                x:Name="MonthYearText" 
                                Text="Tháng 1, 2025" 
                                FontSize="16" 
                                FontWeight="Bold" 
                                HorizontalAlignment="Center" 
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </StackPanel>

                        <Button 
                            Grid.Column="2" 
                            Style="{StaticResource NavIconButtonStyle}" 
                            Click="NextMonth_Click">
                            <FontIcon Glyph="&#xE76C;" FontSize="14"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Day-of-week headers -->
                <Border 
                    Background="{StaticResource SurfaceContainerBrush}" 
                    CornerRadius="10" 
                    Padding="0,10" 
                    Margin="0,0,0,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="CN" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource OutlineBrush}"/>
                        <TextBlock Grid.Column="1" Text="T2" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource OutlineBrush}"/>
                        <TextBlock Grid.Column="2" Text="T3" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource OutlineBrush}"/>
                        <TextBlock Grid.Column="3" Text="T4" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource OutlineBrush}"/>
                        <TextBlock Grid.Column="4" Text="T5" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource OutlineBrush}"/>
                        <TextBlock Grid.Column="5" Text="T6" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource OutlineBrush}"/>
                        <TextBlock Grid.Column="6" Text="T7" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource OutlineBrush}"/>
                    </Grid>
                </Border>

                <!-- Month Calendar Grid -->
                <Border 
                    Background="{StaticResource SurfaceContainerLowestBrush}" 
                    CornerRadius="14" 
                    Padding="8" 
                    Margin="0,0,0,32">
                    <Grid x:Name="MonthCalendarGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="100"/>
                            <RowDefinition Height="100"/>
                            <RowDefinition Height="100"/>
                            <RowDefinition Height="100"/>
                            <RowDefinition Height="100"/>
                            <RowDefinition Height="100"/>
                        </Grid.RowDefinitions>
                    </Grid>
                </Border>
            </StackPanel>
            
            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- LIST VIEW PANEL                                         -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <StackPanel x:Name="ListViewPanel" Visibility="Collapsed">
                <Border Background="White" CornerRadius="16" BorderBrush="#E5E7EB" BorderThickness="1" Padding="8">
                    <ListView x:Name="AllAppointmentsListView"
                              ItemsSource="{x:Bind AllAppointmentsListVM}"
                              SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="16,12"/>
                                <Setter Property="BorderBrush" Value="#F3F4F6"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.Header>
                            <Grid Padding="16,4,16,12" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="THỜI GIAN" FontSize="10" FontWeight="Bold" Foreground="#6B7280" CharacterSpacing="50"/>
                                <TextBlock Grid.Column="1" Text="BỆNH NHÂN" FontSize="10" FontWeight="Bold" Foreground="#6B7280" CharacterSpacing="50"/>
                                <TextBlock Grid.Column="2" Text="HÌNH THỨC" FontSize="10" FontWeight="Bold" Foreground="#6B7280" CharacterSpacing="50"/>
                                <TextBlock Grid.Column="3" Text="TRẠNG THÁI" FontSize="10" FontWeight="Bold" Foreground="#6B7280" CharacterSpacing="50"/>
                            </Grid>
                        </ListView.Header>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:AppointmentViewModel">
                                <Grid Tapped="AppointmentCard_Tapped" Background="Transparent">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Time}" FontWeight="Bold" FontSize="15" Foreground="#111827"/>
                                        <TextBlock Text="{x:Bind DateFormatted}" FontSize="12" Foreground="#6B7280"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1" Text="{x:Bind PatientName}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="14" Foreground="#111827"/>

                                    <Border Grid.Column="2" Background="{x:Bind TypeBgBrush}" CornerRadius="6" Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind TypeText}" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                    </Border>

                                    <TextBlock Grid.Column="3" Text="{x:Bind StatusText}" VerticalAlignment="Center" Foreground="{x:Bind TagBgBrush}" FontSize="12" FontWeight="Bold"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
                
                <!-- Pagination -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0" Spacing="20">
                    <Button x:Name="BtnPrevPage" Click="BtnPrevPage_Click" Style="{StaticResource NavIconButtonStyle}">
                        <FontIcon Glyph="&#xE76B;" FontSize="14"/>
                    </Button>
                    <TextBlock x:Name="PageInfoText" Text="Trang 1 / 1" VerticalAlignment="Center" FontWeight="Bold" Foreground="{StaticResource SecondaryBrush}"/>
                    <Button x:Name="BtnNextPage" Click="BtnNextPage_Click" Style="{StaticResource NavIconButtonStyle}">
                        <FontIcon Glyph="&#xE76C;" FontSize="14"/>
                    </Button>
                </StackPanel>

            </StackPanel>

            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- SLOT MANAGEMENT PANEL                                   -->
            <!-- ═══════════════════════════════════════════════════════ -->
            <Grid x:Name="SlotManagementPanel" Visibility="Collapsed">
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup>
                        <VisualState x:Name="WideState">
                            <VisualState.StateTriggers>
                                <AdaptiveTrigger MinWindowWidth="1000" />
                            </VisualState.StateTriggers>
                        </VisualState>
                        <VisualState x:Name="NarrowState">
                            <VisualState.StateTriggers>
                                <AdaptiveTrigger MinWindowWidth="0" />
                            </VisualState.StateTriggers>
                            <VisualState.Setters>
                                <Setter Target="PageHeaderGrid.ColumnDefinitions[1].Width" Value="0" />
                                <Setter Target="PageHeaderGrid.RowDefinitions[1].Height" Value="Auto" />
                                <Setter Target="ClockPanel.(Grid.Column)" Value="0" />
                                <Setter Target="ClockPanel.(Grid.Row)" Value="1" />
                                <Setter Target="ClockPanel.HorizontalAlignment" Value="Left" />
                                <Setter Target="ClockPanel.Margin" Value="0,12,0,0" />
                                <Setter Target="CurrentTimeText.HorizontalAlignment" Value="Left" />
                                <Setter Target="CurrentDateText.HorizontalAlignment" Value="Left" />

                                <Setter Target="SlotMainGrid.ColumnDefinitions[0].Width" Value="*" />
                                <Setter Target="SlotMainGrid.ColumnDefinitions[1].Width" Value="0" />
                                <Setter Target="SlotMainGrid.RowDefinitions[1].Height" Value="Auto" />
                                <Setter Target="RightPanelBorder.(Grid.Column)" Value="0" />
                                <Setter Target="RightPanelBorder.(Grid.Row)" Value="1" />
                                <Setter Target="RightPanelBorder.Margin" Value="0,20,0,0" />
                                <Setter Target="SlotHeaderPanel.Orientation" Value="Vertical" />
                                <Setter Target="SlotHeaderActions.HorizontalAlignment" Value="Left" />
                                <Setter Target="SlotHeaderActions.Margin" Value="0,12,0,0" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>

                <Grid x:Name="SlotMainGrid" ColumnSpacing="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Create Slots Tool -->
                    <Border Grid.Column="0" Background="White" CornerRadius="16" BorderBrush="#E5E7EB" BorderThickness="1" Padding="24" VerticalAlignment="Top">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Tạo Khung giờ Mới" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                            
                            <StackPanel Spacing="8">
                                <TextBlock Text="Ngày áp dụng" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SecondaryBrush}"/>
                                <DatePicker x:Name="NewSlotDatePicker" HorizontalAlignment="Stretch"/>
                            </StackPanel>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Giờ bắt đầu" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SecondaryBrush}"/>
                                    <TimePicker x:Name="NewSlotStartTime" ClockIdentifier="24HourClock" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                                <StackPanel Spacing="8" Grid.Column="1">
                                    <TextBlock Text="Giờ kết thúc" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SecondaryBrush}"/>
                                    <TimePicker x:Name="NewSlotEndTime" ClockIdentifier="24HourClock" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Spacing="8">
                                <TextBlock Text="Thời lượng mỗi ca (phút)" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SecondaryBrush}"/>
                                <NumberBox x:Name="SlotDurationBox" Value="30" SpinButtonPlacementMode="Inline" SmallChange="5"/>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Text="Thời gian nghỉ (buffer - phút)" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SecondaryBrush}"/>
                                <NumberBox x:Name="BufferDurationBox" Value="5" SpinButtonPlacementMode="Inline" SmallChange="5"/>
                            </StackPanel>

                            <Button Content="Tự động tạo các ca" 
                                    Click="BtnAutoCreateSlots_Click"
                                    Style="{StaticResource PrimaryButtonStyle}" 
                                    HorizontalAlignment="Stretch" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Slots List -->
                    <Border x:Name="RightPanelBorder" Grid.Column="1" Background="White" CornerRadius="16" BorderBrush="#E5E7EB" BorderThickness="1" Padding="24">
                        <StackPanel Spacing="16">
                            <StackPanel x:Name="SlotHeaderPanel" Orientation="Horizontal" HorizontalAlignment="Stretch">
                                <TextBlock Text="Danh sách các Khung giờ" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                                <StackPanel x:Name="SlotHeaderActions" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                                    <DatePicker x:Name="FilterSlotDatePicker" DateChanged="FilterSlotDatePicker_DateChanged"/>
                                    <Button Content="Xoá tất cả trống" Click="BtnDeleteAllAvailableSlots_Click" Foreground="Red"/>
                                </StackPanel>
                            </StackPanel>

                            <ListView x:Name="SlotsListView" ItemsSource="{x:Bind DoctorSlotsList}" SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:SlotViewModel">
                                        <Grid Padding="0,8" BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind TimeRange}" FontWeight="Bold" FontSize="16"/>
                                                <TextBlock Text="{x:Bind DateFormatted}" FontSize="12" Foreground="#6B7280"/>
                                            </StackPanel>

                                            <Border Grid.Column="1" Background="{x:Bind StatusBg}" CornerRadius="6" Padding="8,3" Margin="0,0,12,0" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind StatusText}" FontSize="10" Foreground="White" FontWeight="Bold"/>
                                            </Border>

                                            <Button Grid.Column="2" 
                                                    Click="BtnDeleteSlot_Click" 
                                                    CommandParameter="{x:Bind Id}"
                                                    Background="Transparent" 
                                                    Padding="8"
                                                    Visibility="{x:Bind CanDeleteVisibility}">
                                                <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="#BA1A1A"/>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>