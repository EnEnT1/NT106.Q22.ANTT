<Page
    x:Class="Healthcare.Client.UI.Doctor.DoctorHomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <SolidColorBrush x:Key="PrimaryBlueBrush" Color="#0059BB"/>
        <SolidColorBrush x:Key="SoftBlueBrush" Color="#EFF6FF"/>
        <SolidColorBrush x:Key="SoftGreenBrush" Color="#ECFDF5"/>
        <SolidColorBrush x:Key="SoftOrangeBrush" Color="#FFF7ED"/>
        <SolidColorBrush x:Key="SoftPurpleBrush" Color="#F5F3FF"/>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B"/>
    </Page.Resources>

    <Page.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F0F9FF" Offset="0"/>
            <GradientStop Color="#EEF2FF" Offset="0.45"/>
            <GradientStop Color="#FFFFFF" Offset="1"/>
        </LinearGradientBrush>
    </Page.Background>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="32,28,32,40" Spacing="24">

            <!-- HEADER -->
            <Border Background="#FFFFFF"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="20"
                    Padding="24">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="6">
                        <TextBlock x:Name="TxtWelcome"
                                   Text="Chào buổi sáng, Bác sĩ"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                        <TextBlock x:Name="TxtSubtitle"
                                   Text="Đang tải dữ liệu lịch khám hôm nay..."
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="#EFF6FF"
                            CornerRadius="18"
                            Padding="16"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Width="42"
                                    Height="42"
                                    CornerRadius="21"
                                    Background="#0059BB">
                                <FontIcon Glyph="&#xE77B;"
                                          FontSize="20"
                                          Foreground="White"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Border>

                            <StackPanel Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Dashboard bác sĩ"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#0059BB"/>
                                <TextBlock Text="Theo dõi lịch khám nhanh"
                                           FontSize="11"
                                           Foreground="#475569"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- MAIN LAYOUT -->
            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT COLUMN -->
                <StackPanel Grid.Column="0" Spacing="20">

                    <!-- STATS -->
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ĐÃ KHÁM -->
                        <Border Grid.Column="0"
                                Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="20">
                            <StackPanel Spacing="16">
                                <Grid>
                                    <Border Width="48"
                                            Height="48"
                                            CornerRadius="14"
                                            Background="#EFF6FF"
                                            HorizontalAlignment="Left">
                                        <FontIcon Glyph="&#xE8D4;"
                                                  FontSize="22"
                                                  Foreground="#2563EB"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="ĐÃ KHÁM"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               CharacterSpacing="60"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>

                                    <TextBlock x:Name="TxtExamined"
                                               Text="00"
                                               FontSize="34"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>

                                    <TextBlock Text="Tổng số ca đã hoàn thành"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- CẦN CHÚ Ý -->
                        <Border Grid.Column="1"
                                Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="20">
                            <StackPanel Spacing="16">
                                <Border Width="48"
                                        Height="48"
                                        CornerRadius="14"
                                        Background="#FEF2F2"
                                        HorizontalAlignment="Left">
                                    <FontIcon Glyph="&#xE7BA;"
                                              FontSize="22"
                                              Foreground="#DC2626"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="CẦN CHÚ Ý"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               CharacterSpacing="60"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>

                                    <TextBlock x:Name="TxtEmergency"
                                               Text="00"
                                               FontSize="34"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>

                                    <TextBlock Text="Ca đã đến hoặc đang khám"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- LỊCH HẸN -->
                        <Border Grid.Column="2"
                                Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="20">
                            <StackPanel Spacing="16">
                                <Border Width="48"
                                        Height="48"
                                        CornerRadius="14"
                                        Background="#FFF7ED"
                                        HorizontalAlignment="Left">
                                    <FontIcon Glyph="&#xE787;"
                                              FontSize="22"
                                              Foreground="#EA580C"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="LỊCH HẸN"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               CharacterSpacing="60"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>

                                    <TextBlock x:Name="TxtAppointments"
                                               Text="00"
                                               FontSize="34"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>

                                    <TextBlock Text="Tổng lịch hẹn hôm nay"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- QUICK ACCESS -->
                    <Border Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="22">
                        <StackPanel Spacing="18">
                            <Grid>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE945;"
                                              FontSize="18"
                                              Foreground="#0059BB"/>
                                    <TextBlock Text="Truy cập nhanh"
                                               FontSize="17"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </Grid>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        HorizontalAlignment="Stretch"
                                        Background="#EFF6FF"
                                        BorderBrush="#BFDBFE"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="14"
                                        Click="QuickAccess_ManageSchedule">
                                    <StackPanel Spacing="10" HorizontalAlignment="Center">
                                        <Border Width="54"
                                                Height="54"
                                                CornerRadius="16"
                                                Background="#DBEAFE">
                                            <FontIcon Glyph="&#xE787;"
                                                      FontSize="26"
                                                      Foreground="#2563EB"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Quản lý lịch khám"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#1E3A8A"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Grid.Column="1"
                                        HorizontalAlignment="Stretch"
                                        Background="#ECFDF5"
                                        BorderBrush="#A7F3D0"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="14"
                                        Click="QuickAccess_PatientHistory">
                                    <StackPanel Spacing="10" HorizontalAlignment="Center">
                                        <Border Width="54"
                                                Height="54"
                                                CornerRadius="16"
                                                Background="#CCFBF1">
                                            <FontIcon Glyph="&#xE9F9;"
                                                      FontSize="26"
                                                      Foreground="#0F766E"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Danh sách bệnh nhân"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#115E59"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Grid.Column="2"
                                        HorizontalAlignment="Stretch"
                                        Background="#F5F3FF"
                                        BorderBrush="#DDD6FE"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="14"
                                        Click="QuickAccess_Revenue">
                                    <StackPanel Spacing="10" HorizontalAlignment="Center">
                                        <Border Width="54"
                                                Height="54"
                                                CornerRadius="16"
                                                Background="#EDE9FE">
                                            <FontIcon Glyph="&#xE9D2;"
                                                      FontSize="26"
                                                      Foreground="#7C3AED"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Kết quả khám"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#5B21B6"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- QUEUE -->
                    <Border Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="18">
                        <StackPanel>
                            <Grid Padding="22,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="3">
                                    <TextBlock Text="Hàng chờ khám"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Danh sách bệnh nhân có lịch khám trong hôm nay"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="8"
                                            VerticalAlignment="Center">
                                    <Button x:Name="BtnQueueAll"
                                            Content="Tất cả (0)"
                                            Background="#0059BB"
                                            Foreground="White"
                                            BorderThickness="0"
                                            CornerRadius="18"
                                            FontSize="12"
                                            Padding="14,6"
                                            Click="BtnQueueAll_Click"/>

                                    <Button x:Name="BtnQueuePriority"
                                            Content="Ưu tiên (0)"
                                            Background="#F1F5F9"
                                            Foreground="#334155"
                                            BorderBrush="#CBD5E1"
                                            BorderThickness="1"
                                            CornerRadius="18"
                                            FontSize="12"
                                            Padding="14,6"
                                            Click="BtnQueuePriority_Click"/>
                                </StackPanel>
                            </Grid>

                            <ListView x:Name="QueueListView"
                                      SelectionMode="None"
                                      IsItemClickEnabled="True"
                                      ItemClick="QueueItem_Click">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="18,12"/>
                                        <Setter Property="BorderBrush" Value="#F1F5F9"/>
                                        <Setter Property="BorderThickness" Value="0,1,0,0"/>
                                    </Style>
                                </ListView.ItemContainerStyle>

                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="14">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="32"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Width="42"
                                                    Height="42"
                                                    CornerRadius="21"
                                                    Background="{Binding NumberBackground}">
                                                <TextBlock Text="{Binding QueueNumber}"
                                                           FontSize="13"
                                                           FontWeight="Bold"
                                                           Foreground="{Binding NumberForeground}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Spacing="4">
                                                <TextBlock Text="{Binding PatientName}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Symptom}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Right"
                                                        Margin="0,0,12,0"
                                                        Spacing="2">
                                                <TextBlock Text="{Binding TimeLabel}"
                                                           FontSize="10"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding TimeValue}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           HorizontalAlignment="Right"/>
                                            </StackPanel>

                                            <Border Grid.Column="3"
                                                    Background="{Binding BadgeBackground}"
                                                    CornerRadius="16"
                                                    Padding="12,5"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StatusText}"
                                                           FontSize="10"
                                                           FontWeight="Bold"
                                                           Foreground="{Binding BadgeForeground}"/>
                                            </Border>

                                            <FontIcon Grid.Column="4"
                                                      Glyph="&#xE76C;"
                                                      FontSize="14"
                                                      Foreground="#94A3B8"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <Button HorizontalAlignment="Stretch"
                                    Background="#F8FAFC"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="0,1,0,0"
                                    Padding="0,16"
                                    CornerRadius="0,0,18,18"
                                    Click="BtnViewAllQueue_Click">
                                <TextBlock Text="Xem toàn bộ danh sách hàng chờ"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#0059BB"
                                           HorizontalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- RIGHT COLUMN -->
                <StackPanel Grid.Column="1" Spacing="20">

                    <!-- TODAY SCHEDULE -->
                    <Border Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="20">
                        <StackPanel Spacing="18">
                            <Grid>
                                <StackPanel Spacing="3">
                                    <TextBlock Text="Lịch biểu hôm nay"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Các mốc lịch khám trong ngày"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>

                                <Button HorizontalAlignment="Right"
                                        Background="#EFF6FF"
                                        BorderBrush="#BFDBFE"
                                        BorderThickness="1"
                                        Width="36"
                                        Height="36"
                                        Padding="0"
                                        CornerRadius="18"
                                        ToolTipService.ToolTip="Thêm sự kiện"
                                        Click="BtnAddSchedule_Click">
                                    <FontIcon Glyph="&#xE710;"
                                              FontSize="16"
                                              Foreground="#0059BB"/>
                                </Button>
                            </Grid>

                            <ListView x:Name="ScheduleListView"
                                      SelectionMode="None">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Padding" Value="0,0,0,18"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListViewItem">
                                                    <ContentPresenter/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListView.ItemContainerStyle>

                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Width="14"
                                                    Height="14"
                                                    CornerRadius="7"
                                                    Background="{Binding DotColor}"
                                                    VerticalAlignment="Top"
                                                    Margin="0,4,0,0"/>

                                            <StackPanel Grid.Column="1" Spacing="4">
                                                <TextBlock Text="{Binding TimeRange}"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           Foreground="{Binding TimeColor}"/>
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <Button HorizontalAlignment="Stretch"
                                    Background="#F8FAFC"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1"
                                    Content="Xem lịch đầy đủ"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="#0059BB"
                                    Padding="0,12"
                                    CornerRadius="12"
                                    Click="BtnViewFullSchedule_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- CLINICAL REMINDER -->
                    <Border Background="#0059BB"
                            CornerRadius="18"
                            Padding="22">
                        <StackPanel Spacing="14">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE946;"
                                          Foreground="White"
                                          FontSize="18"/>
                                <TextBlock Text="Lời nhắc lâm sàng"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                            </StackPanel>

                            <TextBlock x:Name="TxtClinicalReminder"
                                       Text="Theo dõi các kết quả xét nghiệm mới, bệnh nhân ưu tiên và các lịch khám cần xử lý trong hôm nay."
                                       FontSize="13"
                                       Foreground="White"
                                       Opacity="0.9"
                                       TextWrapping="Wrap"/>

                            <Button Content="Xem kết quả"
                                    Background="White"
                                    Foreground="#0059BB"
                                    BorderThickness="0"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    CornerRadius="10"
                                    Padding="16,9"
                                    HorizontalAlignment="Left"
                                    Click="BtnViewLabResult_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- AREA STATUS -->
                    <Border Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="18">
                        <StackPanel Spacing="12">
                            <TextBlock Text="KHU VỰC KHÁM"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       CharacterSpacing="60"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>

                            <Border Height="128"
                                    CornerRadius="14"
                                    Background="#F8FAFC"
                                    BorderBrush="#E5E7EB"
                                    BorderThickness="1">
                                <StackPanel VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            Spacing="8">
                                    <Border Width="50"
                                            Height="50"
                                            CornerRadius="25"
                                            Background="#EFF6FF">
                                        <FontIcon Glyph="&#xE707;"
                                                  FontSize="26"
                                                  Foreground="#0059BB"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </Border>

                                    <TextBlock Text="Khu Nội trú - Tầng 2"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#0059BB"
                                               HorizontalAlignment="Center"/>

                                    <TextBlock Text="Trạng thái: Đang hoạt động"
                                               FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>