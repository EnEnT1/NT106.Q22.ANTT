<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Healthcare.Client.UI.Doctor.RevenuePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F0F9FF" Offset="0"/>
            <GradientStop Color="#EEF2FF" Offset="0.45"/>
            <GradientStop Color="#FFFFFF" Offset="1"/>
        </LinearGradientBrush>
    </Page.Background>

    <Page.Resources>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#0059BB"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Padding" Value="22"/>
        </Style>

        <Style x:Key="StatLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="CharacterSpacing" Value="80"/>
        </Style>

        <Style x:Key="StatValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="ExtraBold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="ExtraBold"/>
            <Setter Property="Foreground" Value="#1E293B"/>
        </Style>
    </Page.Resources>

    <Grid>
        <ScrollViewer x:Name="MainScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="32,24,32,48">

            <StackPanel Spacing="24">

                <!-- HEADER -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Kết quả khám chi tiết sức khỏe"
                                       FontSize="30"
                                       FontWeight="ExtraBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>

                            <TextBlock Text="Theo dõi danh sách kết quả khám, chẩn đoán, thuốc AI nhận diện và trạng thái thanh toán."
                                       FontSize="14"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                x:Name="RefreshButton"
                                Background="#0059BB"
                                BorderThickness="0"
                                CornerRadius="10"
                                Padding="16,10"
                                Click="RefreshButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE72C;"
                                          FontFamily="Segoe MDL2 Assets"
                                          FontSize="14"
                                          Foreground="White"/>
                                <TextBlock Text="Làm mới"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- FILTERS -->
                <Border Background="White"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="18">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="SearchBox"
                                 Grid.Column="0"
                                 PlaceholderText="Tìm theo tên bệnh nhân, chẩn đoán, mã kết quả..."
                                 TextChanged="SearchBox_TextChanged"/>

                        <ComboBox x:Name="StatusFilter"
                                  Grid.Column="1"
                                  SelectedIndex="0"
                                  SelectionChanged="StatusFilter_SelectionChanged">
                            <ComboBoxItem Content="Tất cả trạng thái"/>
                            <ComboBoxItem Content="Đã thanh toán"/>
                            <ComboBoxItem Content="Đang xử lý"/>
                            <ComboBoxItem Content="Chưa thanh toán"/>
                        </ComboBox>

                        <ComboBox x:Name="DateFilter"
                                  Grid.Column="2"
                                  SelectedIndex="0"
                                  SelectionChanged="DateFilter_SelectionChanged">
                            <ComboBoxItem Content="Tất cả thời gian"/>
                            <ComboBoxItem Content="Hôm nay"/>
                            <ComboBoxItem Content="Tháng này"/>
                            <ComboBoxItem Content="Năm nay"/>
                        </ComboBox>

                        <Button Grid.Column="3"
                                x:Name="ExportButton"
                                Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="16,8"
                                Click="ExportButton_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE898;"
                                          FontFamily="Segoe MDL2 Assets"
                                          FontSize="14"
                                          Foreground="#0059BB"/>
                                <TextBlock Text="Xuất báo cáo"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#0059BB"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- KPI CARDS -->
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Background="#EFF6FF">
                        <StackPanel Spacing="12">
                            <Border Width="46" Height="46" CornerRadius="14" Background="#DBEAFE" HorizontalAlignment="Left">
                                <FontIcon Glyph="&#xE9D2;"
                                          FontFamily="Segoe MDL2 Assets"
                                          FontSize="22"
                                          Foreground="#2563EB"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Text="TỔNG KẾT QUẢ" Style="{StaticResource StatLabelStyle}"/>
                            <TextBlock x:Name="TxtTotalResults" Text="0" Style="{StaticResource StatValueStyle}"/>
                            <TextBlock Text="Hồ sơ khám đã ghi nhận"
                                       FontSize="12"
                                       Foreground="#64748B"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Background="#ECFDF5">
                        <StackPanel Spacing="12">
                            <Border Width="46" Height="46" CornerRadius="14" Background="#D1FAE5" HorizontalAlignment="Left">
                                <FontIcon Glyph="&#xE77B;"
                                          FontFamily="Segoe MDL2 Assets"
                                          FontSize="22"
                                          Foreground="#059669"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Text="BỆNH NHÂN" Style="{StaticResource StatLabelStyle}"/>
                            <TextBlock x:Name="TxtPatientCount" Text="0" Style="{StaticResource StatValueStyle}"/>
                            <TextBlock Text="Bệnh nhân có kết quả khám"
                                       FontSize="12"
                                       Foreground="#64748B"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Background="#FFF7ED">
                        <StackPanel Spacing="12">
                            <Border Width="46" Height="46" CornerRadius="14" Background="#FED7AA" HorizontalAlignment="Left">
                                <FontIcon Glyph="&#xE70F;"
                                          FontFamily="Segoe MDL2 Assets"
                                          FontSize="22"
                                          Foreground="#EA580C"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Text="ĐƠN THUỐC AI" Style="{StaticResource StatLabelStyle}"/>
                            <TextBlock x:Name="TxtMedicineCount" Text="0" Style="{StaticResource StatValueStyle}"/>
                            <TextBlock Text="Kết quả có thuốc nhận diện"
                                       FontSize="12"
                                       Foreground="#64748B"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3" Style="{StaticResource CardStyle}" Background="#F5F3FF">
                        <StackPanel Spacing="12">
                            <Border Width="46" Height="46" CornerRadius="14" Background="#EDE9FE" HorizontalAlignment="Left">
                                <FontIcon Glyph="&#xE8C7;"
                                          FontFamily="Segoe MDL2 Assets"
                                          FontSize="22"
                                          Foreground="#7C3AED"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock Text="TỔNG CHI PHÍ" Style="{StaticResource StatLabelStyle}"/>
                            <TextBlock x:Name="TxtTotalPaidAmount" Text="0 VNĐ" Style="{StaticResource StatValueStyle}" FontSize="24"/>
                            <TextBlock Text="Tổng chi phí đã ghi nhận"
                                       FontSize="12"
                                       Foreground="#64748B"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- RESULT LIST -->
                <Border Background="White"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        CornerRadius="18">
                    <Grid RowSpacing="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Padding="24,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Danh sách kết quả khám"
                                           Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock x:Name="TxtResultSubtitle"
                                           Text="Đang tải dữ liệu..."
                                           FontSize="13"
                                           Foreground="#64748B"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1"
                                       x:Name="TxtPaginationInfoTop"
                                       Text="0 kết quả"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#64748B"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <ListView Grid.Row="1"
                                  x:Name="ResultListView"
                                  SelectionMode="None"
                                  IsItemClickEnabled="True"
                                  ItemClick="ResultListView_ItemClick">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                </Style>
                            </ListView.ItemContainerStyle>

                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#F1F5F9"
                                            BorderThickness="0,1,0,0"
                                            Padding="24,18">
                                        <Grid ColumnSpacing="18">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="1.5*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="1.2*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Width="48"
                                                    Height="48"
                                                    CornerRadius="24"
                                                    Background="{Binding AvatarBackground}">
                                                <TextBlock Text="{Binding Initials}"
                                                           FontSize="14"
                                                           FontWeight="ExtraBold"
                                                           Foreground="{Binding AvatarForeground}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding PatientName}"
                                                           FontSize="15"
                                                           FontWeight="ExtraBold"
                                                           Foreground="#1E293B"/>
                                                <TextBlock Text="{Binding ExamDateText}"
                                                           FontSize="12"
                                                           Foreground="#64748B"/>
                                                <TextBlock Text="{Binding DoctorNameText}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="#0059BB"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Spacing="5" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DiagnosisText}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="#1E293B"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding MedicineText}"
                                                           FontSize="12"
                                                           Foreground="#64748B"
                                                           TextWrapping="Wrap"
                                                           MaxLines="2"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="3" Spacing="6" VerticalAlignment="Center">
                                                <Border Background="{Binding StatusBackground}"
                                                        CornerRadius="16"
                                                        Padding="10,4"
                                                        HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding PaymentStatusText}"
                                                               FontSize="11"
                                                               FontWeight="Bold"
                                                               Foreground="{Binding StatusForeground}"/>
                                                </Border>

                                                <TextBlock Text="{Binding AmountText}"
                                                           FontSize="13"
                                                           FontWeight="ExtraBold"
                                                           Foreground="#1E293B"/>
                                            </StackPanel>

                                            <FontIcon Grid.Column="4"
                                                      Glyph="&#xE76C;"
                                                      FontFamily="Segoe MDL2 Assets"
                                                      FontSize="14"
                                                      Foreground="#94A3B8"
                                                      VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Border x:Name="EmptyState"
                                Grid.Row="1"
                                Visibility="Collapsed"
                                Padding="28,52">
                            <StackPanel HorizontalAlignment="Center" Spacing="10">
                                <FontIcon Glyph="&#xE9F9;"
                                          FontFamily="Segoe MDL2 Assets"
                                          FontSize="44"
                                          Foreground="#CBD5E1"
                                          HorizontalAlignment="Center"/>
                                <TextBlock Text="Chưa có kết quả khám phù hợp"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="#64748B"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Thử thay đổi bộ lọc hoặc làm mới dữ liệu."
                                           FontSize="12"
                                           Foreground="#94A3B8"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2"
                                Background="#F8FAFC"
                                BorderBrush="#F1F5F9"
                                BorderThickness="0,1,0,0"
                                Padding="24,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="TxtPaginationInfo"
                                           Text="Hiển thị 0 / 0 kết quả"
                                           FontSize="12"
                                           Foreground="#64748B"
                                           VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                    <Button x:Name="PrevPageButton"
                                            Content="Trước"
                                            CornerRadius="8"
                                            Padding="12,6"
                                            Click="PrevPage_Click"/>

                                    <TextBlock x:Name="TxtPageNumber"
                                               Text="1 / 1"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#64748B"
                                               VerticalAlignment="Center"/>

                                    <Button x:Name="NextPageButton"
                                            Content="Sau"
                                            CornerRadius="8"
                                            Padding="12,6"
                                            Click="NextPage_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- LOADING -->
        <Border x:Name="LoadingOverlay"
                Background="#80FFFFFF"
                Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12">
                <ProgressRing IsActive="True"
                              Width="44"
                              Height="44"
                              Foreground="#0059BB"/>
                <TextBlock Text="Đang tải kết quả khám..."
                           FontSize="13"
                           Foreground="#64748B"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>