<Page
    x:Class="Healthcare.Client.UI.Patient.BookAppointmentPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Healthcare.Client.UI.Patient"
    mc:Ignorable="d">

    <Page.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#f0f9ff" Offset="0"/>
            <GradientStop Color="#e0e7ff" Offset="0.25"/>
            <GradientStop Color="#faf5ff" Offset="0.50"/>
            <GradientStop Color="#fdf4ff" Offset="0.75"/>
            <GradientStop Color="#ffffff" Offset="1"/>
        </LinearGradientBrush>
    </Page.Background>
    
    <Page.Resources>
        <Style x:Key="CleanGridViewItemStyle" TargetType="GridViewItem">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid x:Name="RootGrid">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="LayoutStates">
                <!-- Màn hình Rộng (Wide) -->
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1000"/>
                    </VisualState.StateTriggers>
                </VisualState>

                <!-- Màn hình Hẹp (Narrow) -->
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0"/>
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <!-- Dashboard adjustments -->
                        <Setter Target="DashboardStack.Margin" Value="20,40,20,40"/>
                        <Setter Target="DashboardHeader.Orientation" Value="Vertical"/>
                        <Setter Target="BtnNewAppointment.HorizontalAlignment" Value="Left"/>
                        <Setter Target="BtnNewAppointment.Margin" Value="0,20,0,0"/>

                        <!-- Booking Flow adjustments -->
                        <Setter Target="BookingGridColumn2.Width" Value="0"/>
                        <Setter Target="RightSummaryColumn.Visibility" Value="Collapsed"/>
                        <Setter Target="BookingMainStack.Padding" Value="20,40,20,40"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- 1. DASHBOARD: DANH SÁCH LỊCH HẸN                                -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid x:Name="DashboardContainer" Visibility="Visible" VerticalAlignment="Stretch">
            <ScrollViewer VerticalScrollBarVisibility="Auto" VerticalScrollMode="Auto">
                <StackPanel x:Name="DashboardStack" Margin="60,40,60,60" Spacing="40" MaxWidth="1100" HorizontalAlignment="Center">
                    
                    <StackPanel x:Name="DashboardHeader" MaxWidth="1100" HorizontalAlignment="Stretch">
                        <Grid>
                            <StackPanel Spacing="10">
                                <TextBlock Text="Lịch hẹn của tôi" FontSize="36" FontWeight="ExtraBold" Foreground="#0F172A" CharacterSpacing="-15"/>
                                <TextBlock Text="Xem lại các cuộc hẹn đã đặt và quản lý việc thăm khám của bạn." FontSize="16" Foreground="#64748B"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <ListView x:Name="ApptListView" ItemsSource="{x:Bind UserAppointments}" SelectionMode="None" Visibility="{x:Bind HideIfEmpty(UserAppointments.Count), Mode=OneWay}">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0,0,0,20"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:UserAppointmentViewModel">
                                <Border Background="White" CornerRadius="20" Padding="24" BorderBrush="#F1F5F9" BorderThickness="1">
                                    <Grid ColumnSpacing="24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid Grid.Column="0">
                                            <PersonPicture Width="72" Height="72" DisplayName="{x:Bind DoctorName}"/>
                                        </Grid>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                                            <TextBlock Text="{x:Bind DoctorName}" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
                                            <TextBlock Text="{x:Bind Specialty}" FontSize="15" Foreground="#64748B"/>
                                            <StackPanel Orientation="Horizontal" Spacing="24" Margin="0,8,0,0">
                                                <TextBlock Text="{x:Bind DateStr}" FontSize="14" FontWeight="SemiBold" Foreground="#334155"/>
                                                <TextBlock Text="{x:Bind TimeStr}" FontSize="14" FontWeight="SemiBold" Foreground="#334155"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="12" HorizontalAlignment="Right">
                                            <Border Background="{x:Bind StatusBgHex}" Padding="16,8" CornerRadius="12">
                                                <TextBlock Text="{x:Bind StatusText}" FontSize="13" FontWeight="Bold" Foreground="{x:Bind StatusColorHex}"/>
                                            </Border>
                                            <TextBlock Text="{x:Bind Type}" FontSize="13" Foreground="#94A3B8" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel x:Name="EmptyState" Spacing="24" HorizontalAlignment="Center" Margin="0,80,0,0"
                                Visibility="{x:Bind ShowIfEmpty(UserAppointments.Count), Mode=OneWay}">
                        <Border Width="120" Height="120" CornerRadius="60" Background="#F1F5F9">
                            <FontIcon Glyph="&#xE787;" FontSize="48" Foreground="#94A3B8" FontFamily="Segoe Fluent Icons"/>
                        </Border>
                        <TextBlock Text="Chưa có lịch hẹn nào" FontSize="20" FontWeight="SemiBold" Foreground="#64748B"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
            <Button x:Name="BtnNewAppointment" Click="BtnNewAppointment_Click" 
                    VerticalAlignment="Bottom" HorizontalAlignment="Right"
                    Margin="0,0,60,60" Padding="28,20" 
                    Background="#2563EB" CornerRadius="30"
                    BorderThickness="0"
                    Canvas.ZIndex="100">
                <Button.Shadow>
                    <ThemeShadow />
                </Button.Shadow>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <FontIcon Glyph="&#xE710;" FontSize="20" Foreground="White" FontFamily="Segoe Fluent Icons"/>
                    <TextBlock Text="Đặt lịch mới" Foreground="White" FontWeight="Bold" FontSize="16"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- 2. BOOKING FLOW: CÁC BƯỚC ĐẶT LỊCH                             -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <Grid x:Name="BookingFlowContainer" Visibility="Collapsed" VerticalAlignment="Stretch">
            <Grid VerticalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="360"/>
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Auto">
                    <StackPanel x:Name="BookingMainStack" Spacing="35" Padding="50,40,30,60" MaxWidth="1000" HorizontalAlignment="Center">
                        
                        <Button x:Name="BtnBackToList" Click="BtnBackToList_Click" Background="Transparent" Padding="0" BorderThickness="0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE72B;" FontSize="14" Foreground="#2563EB" FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="Quay lại danh sách" FontSize="14" Foreground="#2563EB" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                        <TextBlock Text="Đặt Lịch Khám Mới" FontSize="36" FontWeight="ExtraBold" Foreground="#0F172A" CharacterSpacing="-15"/>

                        <Grid Margin="0,10,0,30" MaxWidth="800" HorizontalAlignment="Center">
                             <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                             <Rectangle x:Name="StepLine1" Grid.Column="1" Height="2" Fill="#E2E8F0" VerticalAlignment="Top" Margin="0,15,0,0"/>
                             <Rectangle x:Name="StepLine2" Grid.Column="3" Height="2" Fill="#E2E8F0" VerticalAlignment="Top" Margin="0,15,0,0"/>
                             
                             <StackPanel Grid.Column="0" HorizontalAlignment="Center" Spacing="10">
                                 <Border x:Name="Step1Circle" Width="32" Height="32" CornerRadius="16" Background="#2563EB">
                                     <TextBlock Text="1" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                 </Border>
                                 <TextBlock x:Name="Step1Label" Text="Thông tin" FontSize="12" FontWeight="Bold" Foreground="#2563EB"/>
                             </StackPanel>
                             
                             <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="10">
                                 <Border x:Name="Step2Circle" Width="32" Height="32" CornerRadius="16" Background="#E2E8F0">
                                     <TextBlock x:Name="Step2Num" Text="2" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                 </Border>
                                 <TextBlock x:Name="Step2Label" Text="Thanh toán" FontSize="12" FontWeight="Bold" Foreground="#64748B"/>
                             </StackPanel>

                             <StackPanel Grid.Column="4" HorizontalAlignment="Center" Spacing="10">
                                 <Border x:Name="Step3Circle" Width="32" Height="32" CornerRadius="16" Background="#E2E8F0">
                                     <TextBlock x:Name="Step3Num" Text="3" Foreground="#64748B" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                 </Border>
                                 <TextBlock x:Name="Step3Label" Text="Hoàn tất" FontSize="12" FontWeight="Bold" Foreground="#64748B"/>
                             </StackPanel>
                        </Grid>

                        <StackPanel x:Name="StepFormPanel" Spacing="40">

                             <!-- 1. Chọn Bác Sĩ -->
                             <StackPanel Spacing="20">
                                 <TextBlock Text="Chọn Bác Sĩ" FontSize="20" FontWeight="Bold"/>
                                 <GridView x:Name="DoctorsGridView" SelectionChanged="DoctorsGridView_SelectionChanged" HorizontalAlignment="Center" ItemContainerStyle="{StaticResource CleanGridViewItemStyle}">
                                     <GridView.ItemTemplate>
                                         <DataTemplate x:DataType="local:DoctorViewModel">
                                             <Border Width="280" Height="110" CornerRadius="20" Padding="14" Margin="4"
                                                     BorderBrush="{x:Bind BorderColor, Mode=OneWay}" 
                                                     BorderThickness="{x:Bind BorderThickness, Mode=OneWay}"
                                                     Background="{x:Bind BackgroundColor, Mode=OneWay}">
                                                 <Grid ColumnSpacing="16">
                                                     <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                     <PersonPicture Grid.Column="0" Width="60" Height="60" DisplayName="{x:Bind FullName}"/>
                                                     <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                         <TextBlock Text="{x:Bind FullName}" FontWeight="Bold"/>
                                                         <TextBlock Text="{x:Bind Specialty}" FontSize="13"/>
                                                         <TextBlock Text="{x:Bind ConsultationFeeFormatted, Mode=OneWay}" FontSize="13" Foreground="#2563EB" FontWeight="Bold"/>
                                                     </StackPanel>
                                                 </Grid>
                                             </Border>
                                         </DataTemplate>
                                     </GridView.ItemTemplate>
                                 </GridView>
                             </StackPanel>

                             <!-- 2. Chọn Ngày -->
                             <StackPanel Spacing="20">
                                 <TextBlock Text="Chọn Ngày" FontSize="20" FontWeight="Bold"/>
                                 <GridView x:Name="DatesGridView" SelectionChanged="DatesGridView_SelectionChanged" HorizontalAlignment="Center" ItemContainerStyle="{StaticResource CleanGridViewItemStyle}">
                                     <GridView.ItemTemplate>
                                         <DataTemplate x:DataType="local:DateViewModel">
                                             <Border Width="80" Height="100" CornerRadius="16" Margin="4" Padding="10"
                                                     BorderBrush="{x:Bind BorderColor, Mode=OneWay}" 
                                                     BorderThickness="{x:Bind BorderThickness, Mode=OneWay}"
                                                     Background="{x:Bind BackgroundColor, Mode=OneWay}">
                                                 <StackPanel VerticalAlignment="Center">
                                                     <TextBlock Text="{x:Bind DayOfWeekStr}" HorizontalAlignment="Center" FontSize="12"/>
                                                     <TextBlock Text="{x:Bind DayStr}" HorizontalAlignment="Center" FontSize="24" FontWeight="Bold"/>
                                                 </StackPanel>
                                             </Border>
                                         </DataTemplate>
                                     </GridView.ItemTemplate>
                                 </GridView>
                             </StackPanel>

                             <!-- 3. Chọn Khung Giờ -->
                             <StackPanel Spacing="20">
                                 <TextBlock Text="Chọn Khung Giờ" FontSize="20" FontWeight="Bold"/>
                                 <GridView x:Name="TimeSlotsGridView" SelectionChanged="TimeSlotsGridView_SelectionChanged" HorizontalAlignment="Center" ItemContainerStyle="{StaticResource CleanGridViewItemStyle}">
                                     <GridView.ItemTemplate>
                                         <DataTemplate x:DataType="local:TimeSlotViewModel">
                                             <Border Width="120" Height="50" CornerRadius="12" Margin="4"
                                                     BorderBrush="{x:Bind BorderColor, Mode=OneWay}" 
                                                     BorderThickness="{x:Bind BorderThickness, Mode=OneWay}"
                                                     Background="{x:Bind BackgroundColor, Mode=OneWay}">
                                                 <TextBlock Text="{x:Bind StartTimeStr}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                             </Border>
                                         </DataTemplate>
                                     </GridView.ItemTemplate>
                                 </GridView>
                             </StackPanel>

                             <!-- 4. Hình thức khám -->
                             <StackPanel Spacing="20">
                                 <TextBlock Text="Hình thức khám" FontSize="20" FontWeight="Bold"/>
                                 <StackPanel Orientation="Horizontal" Spacing="40">
                                     <RadioButton x:Name="TypeOnline" Content="Khám Online" IsChecked="True" Checked="ExaminationType_Checked"/>
                                     <RadioButton x:Name="TypeOffline" Content="Khám tại chỗ" Checked="ExaminationType_Checked"/>
                                 </StackPanel>
                             </StackPanel>

                             <!-- 5. Phương thức thanh toán -->
                             <StackPanel x:Name="PaymentMethodSection" Spacing="20">
                                 <TextBlock Text="Phương thức thanh toán" FontSize="20" FontWeight="Bold"/>
                                 <StackPanel Orientation="Horizontal" Spacing="40">
                                     <RadioButton x:Name="PaymentOnline" Content="Qua VNPay" IsChecked="True"/>
                                     <RadioButton x:Name="PaymentManual" Content="Tại quầy" Visibility="Collapsed"/>
                                 </StackPanel>
                             </StackPanel>

                             <Button x:Name="BtnConfirm" Click="BtnConfirm_Click" HorizontalAlignment="Stretch" Padding="20" Background="#2563EB" Foreground="White" CornerRadius="16">
                                 <TextBlock Text="Xác nhận &amp; Tiếp tục" FontWeight="Bold" FontSize="16"/>
                             </Button>
                        </StackPanel>

                        <!-- Step 2: Payment -->
                        <StackPanel x:Name="StepPaymentPanel" Visibility="Collapsed" Spacing="24" MaxWidth="600" HorizontalAlignment="Center">
                             <Border x:Name="StepPaymentOnlinePanel" Background="White" CornerRadius="20" Padding="32" BorderBrush="#E2E8F0" BorderThickness="1">
                                 <StackPanel Spacing="24">
                                     <TextBlock Text="Thanh toán trực tuyến" FontSize="22" FontWeight="Bold"/>
                                     <Grid Background="#F1F5F9" CornerRadius="12" Padding="20">
                                         <StackPanel Spacing="10">
                                             <Grid><TextBlock Text="Số tiền:" Foreground="#64748B"/><TextBlock x:Name="DlgAmount" HorizontalAlignment="Right" FontWeight="Bold"/></Grid>
                                             <Grid><TextBlock Text="Mã GD:" Foreground="#64748B"/><TextBlock x:Name="DlgRef" HorizontalAlignment="Right"/></Grid>
                                         </StackPanel>
                                     </Grid>
                                     <Button x:Name="BtnOpenVNPay" Click="BtnOpenVNPay_Click" Content="Mở trang VNPay" HorizontalAlignment="Stretch" Padding="16" Background="#0052CC" Foreground="White" CornerRadius="12"/>
                                     <Button x:Name="BtnPaymentDone" Click="BtnPaymentDone_Click" IsEnabled="False" HorizontalAlignment="Stretch" Padding="14" Background="#DCFCE7" Foreground="#166534" CornerRadius="12">
                                         <TextBlock x:Name="BtnPaymentDoneText" Text="✓ Đã thanh toán, tiếp tục"/>
                                     </Button>
                                 </StackPanel>
                             </Border>

                             <Border x:Name="StepPaymentOfflinePanel" Background="White" CornerRadius="20" Padding="32" BorderBrush="#E2E8F0" BorderThickness="1">
                                 <StackPanel Spacing="24" HorizontalAlignment="Center">
                                     <TextBlock x:Name="SuccessMessage" TextAlignment="Center" FontWeight="SemiBold"/>
                                     <TextBlock x:Name="CountdownText" FontSize="12" Foreground="#94A3B8"/>
                                     <Button x:Name="BtnOfflineProceed" Click="BtnOfflineProceed_Click" Content="Tiếp tục" HorizontalAlignment="Stretch" Padding="16" Background="#2563EB" Foreground="White" CornerRadius="12"/>
                                 </StackPanel>
                             </Border>
                        </StackPanel>

                        <!-- Step 3: Success -->
                        <StackPanel x:Name="StepSuccessPanel" Visibility="Collapsed" Spacing="30" MaxWidth="600" HorizontalAlignment="Center">
                             <Border Background="White" CornerRadius="20" Padding="40" BorderBrush="#E2E8F0" BorderThickness="1">
                                 <StackPanel Spacing="24" HorizontalAlignment="Center">
                                     <FontIcon Glyph="&#xE73E;" FontSize="48" Foreground="#10B981" FontFamily="Segoe Fluent Icons"/>
                                     <TextBlock Text="Thành công!" FontSize="28" FontWeight="Bold"/>
                                     <StackPanel Spacing="10" MinWidth="250">
                                         <Grid><TextBlock Text="Bác sĩ:"/><TextBlock x:Name="SuccDoctorName" HorizontalAlignment="Right" FontWeight="SemiBold"/></Grid>
                                         <Grid><TextBlock Text="Thời gian:"/><TextBlock x:Name="SuccTime" HorizontalAlignment="Right" FontWeight="SemiBold"/></Grid>
                                         <Grid><TextBlock Text="Mã GD:"/><TextBlock x:Name="SuccRef" HorizontalAlignment="Right" FontWeight="SemiBold"/></Grid>
                                     </StackPanel>
                                     <Button x:Name="BtnGoHome" Click="BtnBackToList_Click" Content="Quay về danh sách" HorizontalAlignment="Stretch" Padding="16" Background="#2563EB" Foreground="White" CornerRadius="12"/>
                                 </StackPanel>
                             </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- Sidebar Summary -->
                <Border x:Name="RightSummaryColumn" Grid.Column="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1,0,0,0">
                    <StackPanel Padding="24,40,24,24" Spacing="30">
                        <TextBlock Text="Tóm tắt lịch hẹn" FontSize="20" FontWeight="Bold"/>
                        <StackPanel Spacing="16">
                            <TextBlock x:Name="SumDoctorName" Text="Bác sĩ: --" Foreground="#1E293B"/>
                            <TextBlock x:Name="SumSpecialty" Text="Chuyên khoa: --" Foreground="#64748B"/>
                            <TextBlock x:Name="SumTime" Text="Thời gian: --" Foreground="#64748B"/>
                            <TextBlock x:Name="SumFee" Text="Phí: 0 VNĐ" FontSize="22" FontWeight="Bold" Foreground="#2563EB"/>
                        </StackPanel>
                        <Border x:Name="SumPaymentMsg" Background="#EFF6FF" CornerRadius="12" Padding="16" Visibility="Collapsed">
                             <TextBlock Text="Vui lòng thanh toán Online ở bước tiếp theo." FontSize="12" Foreground="#1E40AF" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
