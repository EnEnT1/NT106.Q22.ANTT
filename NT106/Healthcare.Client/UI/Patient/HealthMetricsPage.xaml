<Page
    x:Class="Healthcare.Client.UI.Patient.HealthMetricsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource AppBackdropGradientBrush}">

    <Page.Resources>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#191C1D"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2D6CDF"/>
        <SolidColorBrush x:Key="OptimalBrush" Color="#22C55E"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
        <SolidColorBrush x:Key="HighRiskBrush" Color="#EF4444"/>
        <SolidColorBrush x:Key="TrackBrush" Color="#E2E8F0"/>

        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource GlassCardAcrylicBrush}"/>
            <Setter Property="BorderBrush" Value="#D0E4FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Padding" Value="24"/>
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource GlassHeaderAcrylicBrush}"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <Style x:Key="TitleTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Page.Resources>

    <!-- Main content only: đặt Page này vào Frame bên trong Shell có TopBar/SideBar riêng -->
    <ScrollViewer Background="Transparent"
                  HorizontalScrollMode="Disabled"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollMode="Auto"
                  VerticalScrollBarVisibility="Auto">
        <Grid Padding="32,8,32,32" MaxWidth="1400" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Top card: Cardiovascular summary -->
            <Border Grid.Row="0"
                    Style="{StaticResource GlassCardStyle}"
                    Translation="0,0,2"
                    Shadow="{StaticResource HealthcareThemeShadow}">
                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <Border Width="34" Height="34" CornerRadius="17" Background="#BFE0F2FE" BorderBrush="#66FFFFFF" BorderThickness="1">
                                    <FontIcon Glyph="&#xEB51;" FontSize="15" Foreground="{StaticResource PrimaryBrush}"/>
                                </Border>
                                <TextBlock Text="Hệ Tim Mạch" Style="{StaticResource TitleTextStyle}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <TextBlock Text="Nguy cơ" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center"/>
                                <Grid Width="150" Height="14" VerticalAlignment="Center">
                                    <Border Height="6" CornerRadius="3" VerticalAlignment="Center">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                                <GradientStop Color="#22C55E" Offset="0"/>
                                                <GradientStop Color="#F59E0B" Offset="0.55"/>
                                                <GradientStop Color="#EF4444" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <Ellipse Width="13" Height="13" Fill="{StaticResource WarningBrush}" Stroke="White" StrokeThickness="2" HorizontalAlignment="Right" Margin="0,0,52,0"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE74A;" FontSize="10" Foreground="{StaticResource HighRiskBrush}"/>
                                    <TextBlock Text="Cao 35.4%" Foreground="{StaticResource HighRiskBrush}" FontSize="12" FontWeight="Bold"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <Grid Padding="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Bottom">
                                    <Border Width="18" Height="52" Background="{StaticResource HighRiskBrush}" CornerRadius="3,3,0,0" Opacity="0.85"/>
                                    <Border Width="18" Height="34" Background="{StaticResource OptimalBrush}" CornerRadius="3,3,0,0" Opacity="0.9"/>
                                </StackPanel>
                                <Border Background="#99FFFFFF" BorderBrush="#66FFFFFF" BorderThickness="1" CornerRadius="5" Padding="8,3">
                                    <TextBlock Text="+4 năm" FontSize="12" FontWeight="Bold" Foreground="#475569"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="1" HorizontalAlignment="Center" Spacing="6">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                                    <Ellipse Width="7" Height="7" Fill="{StaticResource HighRiskBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="Tuổi sinh học tim" Style="{StaticResource CaptionTextStyle}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                                    <TextBlock Text="48" FontSize="34" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="tuổi" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Bottom" Margin="0,0,0,6"/>
                                </StackPanel>
                            </StackPanel>

                            <FontIcon Grid.Column="2" Glyph="&#xE76C;" FontSize="36" Foreground="#94A3B8" VerticalAlignment="Center" Margin="20,0"/>

                            <StackPanel Grid.Column="3" HorizontalAlignment="Center" Spacing="6">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                                    <Ellipse Width="7" Height="7" Fill="{StaticResource OptimalBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="Tuổi thực tế" Style="{StaticResource CaptionTextStyle}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                                    <TextBlock Text="40" FontSize="34" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="tuổi" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Bottom" Margin="0,0,0,6"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <Border Grid.Column="1" CornerRadius="18" Padding="20" VerticalAlignment="Stretch" BorderBrush="#33FFFFFF" BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#CC3B82F6" Offset="0"/>
                                <GradientStop Color="#CC1D4ED8" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <StackPanel Spacing="18" VerticalAlignment="Center">
                                <TextBlock Text="Tim của bạn đang lão hóa nhanh hơn 4 năm so với tuổi thực tế."
                                           Foreground="#EFF6FF"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                                <Button Content="Xem báo cáo đầy đủ"
                                        HorizontalAlignment="Left"
                                        Padding="14,8"
                                        CornerRadius="8"
                                        Background="#33FFFFFF"
                                        BorderBrush="#55FFFFFF"
                                        Foreground="White"
                                        FontSize="12"
                                        FontWeight="SemiBold"/>
                            </StackPanel>
                            <FontIcon Glyph="&#xE783;" FontSize="96" Foreground="#22FFFFFF" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-12,-26"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Middle card: key metrics -->
            <Border Grid.Row="2"
                    Style="{StaticResource GlassCardStyle}"
                    Translation="0,0,2"
                    Shadow="{StaticResource HealthcareThemeShadow}">
                <StackPanel Spacing="20">
                    <Grid>
                        <TextBlock Text="Các chỉ số cần lưu ý" Style="{StaticResource TitleTextStyle}" VerticalAlignment="Center"/>
                        <Button HorizontalAlignment="Right" Width="34" Height="34" CornerRadius="17" Padding="0" Background="#55FFFFFF" BorderBrush="#66FFFFFF">
                            <FontIcon Glyph="&#xE8A7;" FontSize="13" Foreground="#475569"/>
                        </Button>
                    </Grid>

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}">
                            <StackPanel Spacing="8">
                                <Grid>
                                    <TextBlock Text="Huyết áp" FontSize="14" FontWeight="SemiBold" Foreground="#334155"/>
                                    <FontIcon Glyph="&#xE76C;" FontSize="13" Foreground="#94A3B8" HorizontalAlignment="Right"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="110/80" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="mmHg" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                                </StackPanel>
                                <TextBlock Text="Bình thường" Style="{StaticResource CaptionTextStyle}" HorizontalAlignment="Right"/>
                                <Grid Height="6">
                                    <Border Background="{StaticResource TrackBrush}" CornerRadius="3"/>
                                    <Border Width="120" Background="#CC3B82F6" CornerRadius="3" HorizontalAlignment="Left"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="60" FontSize="10" Foreground="#64748B"/>
                                    <TextBlock Text="130" FontSize="10" Foreground="#64748B" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}">
                            <StackPanel Spacing="8">
                                <Grid>
                                    <TextBlock Text="HbA1c" FontSize="14" FontWeight="SemiBold" Foreground="#334155"/>
                                    <FontIcon Glyph="&#xE76C;" FontSize="13" Foreground="#94A3B8" HorizontalAlignment="Right"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="5.1" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="%" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                                </StackPanel>
                                <TextBlock Text="Tối ưu" Style="{StaticResource CaptionTextStyle}" HorizontalAlignment="Right"/>
                                <Grid Height="6">
                                    <Border Background="{StaticResource TrackBrush}" CornerRadius="3"/>
                                    <Border Width="75" Background="#E63B82F6" CornerRadius="3" HorizontalAlignment="Left"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="5.0" FontSize="10" Foreground="#64748B"/>
                                    <TextBlock Text="14.0" FontSize="10" Foreground="#64748B" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource MetricCardStyle}">
                            <StackPanel Spacing="8">
                                <Grid>
                                    <TextBlock Text="Cholesterol" FontSize="14" FontWeight="SemiBold" Foreground="#334155"/>
                                    <FontIcon Glyph="&#xE76C;" FontSize="13" Foreground="#94A3B8" HorizontalAlignment="Right"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="190" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="mg/dL" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                                </StackPanel>
                                <TextBlock Text="Cận cao" Foreground="{StaticResource WarningBrush}" FontSize="12" HorizontalAlignment="Right"/>
                                <Grid Height="6">
                                    <Border Background="{StaticResource TrackBrush}" CornerRadius="3"/>
                                    <Border Width="230" Background="#CC38BDF8" CornerRadius="3" HorizontalAlignment="Left"/>
                                </Grid>
                                <Grid>
                                    <TextBlock Text="40" FontSize="10" Foreground="#64748B"/>
                                    <TextBlock Text="200" FontSize="10" Foreground="#64748B" HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Bottom: chart + pulse rate -->
            <Grid Grid.Row="4" ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource GlassCardStyle}"
                        Translation="0,0,2"
                        Shadow="{StaticResource HealthcareThemeShadow}">
                    <StackPanel Spacing="18">
                        <Grid>
                            <TextBlock Text="Kế hoạch Sức khỏe" Style="{StaticResource TitleTextStyle}" VerticalAlignment="Center"/>
                            <Border Background="#66FFFFFF" BorderBrush="#80FFFFFF" BorderThickness="1" CornerRadius="8" Padding="10,6" HorizontalAlignment="Right">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE787;" FontSize="13" Foreground="#475569"/>
                                    <TextBlock Text="26 Th3 - 24 Th4, 2024" FontSize="12" Foreground="#475569" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Grid Height="180">
                            <Canvas Margin="0,0,0,8">
                                <Line X1="0" Y1="25" X2="520" Y2="25" Stroke="#80CBD5E1" StrokeThickness="1" StrokeDashArray="4,4"/>
                                <TextBlock Canvas.Left="0" Canvas.Top="17" Text="240" FontSize="10" Foreground="#64748B"/>
                                <Line X1="0" Y1="70" X2="520" Y2="70" Stroke="#80CBD5E1" StrokeThickness="1" StrokeDashArray="4,4"/>
                                <TextBlock Canvas.Left="0" Canvas.Top="62" Text="180" FontSize="10" Foreground="#64748B"/>
                                <Line X1="0" Y1="115" X2="520" Y2="115" Stroke="#80CBD5E1" StrokeThickness="1" StrokeDashArray="4,4"/>
                                <TextBlock Canvas.Left="0" Canvas.Top="107" Text="120" FontSize="10" Foreground="#64748B"/>
                                <Line X1="0" Y1="160" X2="520" Y2="160" Stroke="#80CBD5E1" StrokeThickness="1" StrokeDashArray="4,4"/>
                                <TextBlock Canvas.Left="0" Canvas.Top="152" Text="60" FontSize="10" Foreground="#64748B"/>

                                <Rectangle Canvas.Left="0" Canvas.Top="70" Width="520" Height="45" Fill="#55E2E8F0"/>
                                <Polyline Stroke="{StaticResource HighRiskBrush}" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Points="30,110 55,126 80,104 105,115 130,98 155,104 180,104 205,92 230,104 255,110 280,58 305,92 330,132 355,98 380,110 405,80 430,110 455,98 485,104"/>
                            </Canvas>
                        </Grid>

                        <Grid Margin="24,0,24,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="6 AM" FontSize="10" Foreground="#64748B"/>
                            <TextBlock Grid.Column="1" Text="8 AM" FontSize="10" Foreground="#64748B"/>
                            <TextBlock Grid.Column="2" Text="10 AM" FontSize="10" Foreground="#64748B"/>
                            <TextBlock Grid.Column="3" Text="12 PM" FontSize="10" Foreground="#64748B"/>
                            <TextBlock Grid.Column="4" Text="2 PM" FontSize="10" Foreground="#64748B"/>
                            <TextBlock Grid.Column="5" Text="4 PM" FontSize="10" Foreground="#64748B"/>
                            <TextBlock Grid.Column="6" Text="NOW" FontSize="10" Foreground="#64748B" HorizontalAlignment="Right"/>
                        </Grid>

                        <Border Height="1" Background="#44CBD5E1"/>

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="127" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="bpm" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                                </StackPanel>
                                <TextBlock Text="Hiện tại" Style="{StaticResource CaptionTextStyle}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="80" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="bpm" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                                </StackPanel>
                                <TextBlock Text="Thấp nhất" Style="{StaticResource CaptionTextStyle}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="145" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="bpm" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                                </StackPanel>
                                <TextBlock Text="Cao nhất" Style="{StaticResource CaptionTextStyle}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource GlassCardStyle}"
                        Translation="0,0,3"
                        Shadow="{StaticResource HealthcareThemeShadow}">
                    <StackPanel Spacing="20">
                        <Grid>
                            <TextBlock Text="Nhịp tim" Style="{StaticResource TitleTextStyle}" VerticalAlignment="Center"/>
                            <Button HorizontalAlignment="Right" Width="34" Height="34" CornerRadius="17" Padding="0" Background="#E8F0FE" BorderBrush="#D0E4FF">
                                <FontIcon Glyph="&#xE8A7;" FontSize="13" Foreground="#475569"/>
                            </Button>
                        </Grid>

                        <!-- Gauge: cung trơn + gradient, vùng tối ưu xanh -->
                        <Grid Height="228" HorizontalAlignment="Stretch" MaxWidth="320">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Viewbox Grid.Row="0" MaxWidth="300" MaxHeight="170" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Top">
                                <Grid Width="300" Height="170">
                                    <!-- Nền cung mờ -->
                                    <Path Data="M 36 148 A 114 114 0 0 1 264 148"
                                          Stroke="#F1F5F9" StrokeThickness="20"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Fill="Transparent"/>

                                    <!-- Track chính -->
                                    <Path Data="M 36 148 A 114 114 0 0 1 264 148"
                                          Stroke="#E2E8F0" StrokeThickness="16"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Fill="Transparent"/>

                                    <!-- Giá trị hiện tại ~54 bpm (gần nửa đầu cung) -->
                                    <Path Data="M 36 148 A 114 114 0 0 1 162 46"
                                          StrokeThickness="16"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Fill="Transparent">
                                        <Path.Stroke>
                                            <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                                                <GradientStop Color="#2D6CDF" Offset="0"/>
                                                <GradientStop Color="#0EA5E9" Offset="0.45"/>
                                                <GradientStop Color="#22C55E" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Path.Stroke>
                                    </Path>

                                    <!-- Chấm đầu cung -->
                                    <Ellipse Width="14" Height="14" Fill="White" Stroke="#CBD5E1" StrokeThickness="2"
                                             Margin="29,141,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>

                                    <!-- Nút chỉ giá trị -->
                                    <Ellipse Width="20" Height="20" Fill="White" Stroke="#22C55E" StrokeThickness="3"
                                             Margin="152,37,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>

                                    <!-- Nhãn min / max trên cung -->
                                    <TextBlock Text="40" FontSize="11" Foreground="#94A3B8" FontWeight="SemiBold" Margin="8,128,0,0"/>
                                    <TextBlock Text="180" FontSize="11" Foreground="#94A3B8" FontWeight="SemiBold"
                                               HorizontalAlignment="Right" Margin="0,128,8,0"/>
                                </Grid>
                            </Viewbox>

                            <StackPanel Grid.Row="1" Spacing="4" Margin="0,4,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                                    <TextBlock Text="54" FontSize="42" FontWeight="ExtraBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="bpm" FontSize="17" FontWeight="SemiBold" Foreground="#475569" VerticalAlignment="Bottom" Margin="0,0,0,10"/>
                                </StackPanel>
                                <TextBlock Text="08:12 AM" Style="{StaticResource CaptionTextStyle}" HorizontalAlignment="Center" Opacity="0.9"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="8,0">
                            <TextBlock Text="Nhịp mỗi phút" Style="{StaticResource CaptionTextStyle}"/>
                            <TextBlock Text="60" FontSize="12" FontWeight="Bold" Foreground="#334155" HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}" Padding="14">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Chỉ số Căng thẳng" FontSize="11" Foreground="#475569" FontWeight="SemiBold"/>
                                    <Border Background="#CCFFEDD5" CornerRadius="5" Padding="7,3" HorizontalAlignment="Left">
                                        <TextBlock Text="Nhẹ" FontSize="12" FontWeight="Bold" Foreground="{StaticResource WarningBrush}"/>
                                    </Border>
                                    <Grid Height="7">
                                        <Border Background="#99E2E8F0" CornerRadius="4"/>
                                        <Border Width="70" Background="{StaticResource WarningBrush}" CornerRadius="4" HorizontalAlignment="Left"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}" Padding="14">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Chất lượng Giấc ngủ" FontSize="11" Foreground="#475569" FontWeight="SemiBold"/>
                                    <Border Background="#CCDFFFEA" CornerRadius="5" Padding="7,3" HorizontalAlignment="Left">
                                        <TextBlock Text="Tốt" FontSize="12" FontWeight="Bold" Foreground="{StaticResource OptimalBrush}"/>
                                    </Border>
                                    <Grid Height="7">
                                        <Border Background="#99E2E8F0" CornerRadius="4"/>
                                        <Border Width="150" Background="{StaticResource OptimalBrush}" CornerRadius="4" HorizontalAlignment="Left"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
