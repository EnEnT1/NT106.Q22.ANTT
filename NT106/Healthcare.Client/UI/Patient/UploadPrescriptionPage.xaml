<Page
    x:Class="Healthcare.Client.UI.Patient.UploadPrescriptionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#f0f9ff" Offset="0"/>
            <GradientStop Color="#e0e7ff" Offset="0.25"/>
            <GradientStop Color="#faf5ff" Offset="0.50"/>
            <GradientStop Color="#fdf4ff" Offset="0.75"/>
            <GradientStop Color="#ffffff" Offset="1"/>
        </LinearGradientBrush>
    </Page.Background>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="60,40,60,60" Spacing="40" MaxWidth="1100" HorizontalAlignment="Center">
            
            <StackPanel Spacing="10">
                <TextBlock Text="Nhập đơn thuốc AI" FontSize="36" FontWeight="ExtraBold" Foreground="#0F172A" CharacterSpacing="-15"/>
                <TextBlock Text="Tải lên ảnh hoặc file đơn thuốc để AI tự động trích xuất thông tin thuốc và hỗ trợ đặt lịch." 
                           FontSize="16" Foreground="#64748B"/>
            </StackPanel>

            <Grid ColumnSpacing="40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="380"/>
                </Grid.ColumnDefinitions>

                <!-- Left Column: Upload and Result -->
                <StackPanel Grid.Column="0" Spacing="40">
                    
                    <!-- Upload Area -->
                    <Border Background="White" CornerRadius="24" Padding="40" BorderBrush="#E2E8F0" BorderThickness="2">
                        <StackPanel Spacing="24" HorizontalAlignment="Center">
                            <Border Width="80" Height="80" CornerRadius="40" Background="#EFF6FF">
                                <FontIcon Glyph="&#xE8E5;" FontSize="32" Foreground="#2563EB" FontFamily="Segoe Fluent Icons"/>
                            </Border>
                            <StackPanel Spacing="8" HorizontalAlignment="Center">
                                <TextBlock Text="Chọn file đơn thuốc của bạn" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                                <TextBlock Text="Hỗ trợ ảnh (JPG, PNG), PDF hoặc file Word" FontSize="14" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                            </StackPanel>
                            
                            <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
                                <Button x:Name="BtnSelectFile" Click="BtnSelectFile_Click" Padding="24,12" CornerRadius="12" Background="#2563EB" Foreground="White" BorderThickness="0">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xED25;" FontSize="16" FontFamily="Segoe Fluent Icons"/>
                                        <TextBlock Text="Chọn file" FontWeight="Bold"/>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="BtnAnalyze" Click="BtnAnalyze_Click" IsEnabled="False" Padding="24,12" CornerRadius="12" BorderThickness="1" BorderBrush="#E2E8F0" Background="White">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE9D9;" FontSize="16" Foreground="#2563EB" FontFamily="Segoe Fluent Icons"/>
                                        <TextBlock Text="Phân tích AI" FontWeight="Bold" Foreground="#2563EB"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <Border x:Name="FileBadge" Visibility="Collapsed" Background="#F0FDF4" CornerRadius="10" Padding="12,6" HorizontalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE930;" FontSize="12" Foreground="#166534" FontFamily="Segoe Fluent Icons"/>
                                    <TextBlock x:Name="TxtFileName" FontSize="13" FontWeight="SemiBold" Foreground="#166534"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Results Area -->
                    <StackPanel Spacing="20">
                        <TextBlock Text="Danh sách thuốc phát hiện" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
                        <Border Background="White" CornerRadius="24" Padding="32" BorderBrush="#F1F5F9" BorderThickness="1" MinHeight="300">
                            <Grid>
                                <StackPanel x:Name="EmptyResultState" VerticalAlignment="Center" Spacing="16">
                                    <FontIcon Glyph="&#xE977;" FontSize="48" Foreground="#E2E8F0" FontFamily="Segoe Fluent Icons"/>
                                    <TextBlock Text="Kết quả phân tích sẽ hiển thị tại đây" FontSize="15" Foreground="#94A3B8" HorizontalAlignment="Center"/>
                                </StackPanel>
                                
                                <ListView x:Name="ListMedicines" SelectionMode="None" Visibility="Collapsed">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Padding" Value="0,0,0,12"/>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#F8FAFC" CornerRadius="12" Padding="16">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="32" Height="32" CornerRadius="8" Background="#EFF6FF" Margin="0,0,16,0">
                                                        <FontIcon Glyph="&#xE945;" FontSize="14" Foreground="#2563EB" FontFamily="Segoe Fluent Icons"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="1" Text="{Binding}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#334155"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <StackPanel x:Name="LoadingOverlay" Visibility="Collapsed" VerticalAlignment="Center" Spacing="20">
                                    <ProgressRing IsActive="True" Width="48" Height="48" Foreground="#2563EB"/>
                                    <TextBlock Text="Đang phân tích đơn thuốc bằng AI..." FontSize="14" Foreground="#2563EB" FontWeight="Bold" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Right Column: Summary and Action -->
                <StackPanel Grid.Column="1" Spacing="24">
                    <TextBlock Text="Thông tin gợi ý" FontSize="20" FontWeight="Bold" Foreground="#1E293B"/>
                    <Border Background="#2563EB" CornerRadius="24" Padding="32" BorderThickness="0">
                        <StackPanel Spacing="24">
                            <FontIcon Glyph="&#xE946;" FontSize="32" Foreground="White" FontFamily="Segoe Fluent Icons" HorizontalAlignment="Left"/>
                            <TextBlock Text="Hệ thống AI sẽ trích xuất tên thuốc và đề xuất bác sĩ phù hợp với tình trạng của bạn." 
                                       FontSize="14" Foreground="White" Opacity="0.9" TextWrapping="Wrap" LineHeight="20"/>
                            
                            <Border Background="#1D4ED8" CornerRadius="16" Padding="20">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="BƯỚC TIẾP THEO" FontSize="11" FontWeight="Bold" Foreground="White" Opacity="0.7" CharacterSpacing="50"/>
                                    <TextBlock Text="Sau khi có danh sách thuốc, bạn có thể chuyển tiếp sang trang đặt lịch để được bác sĩ tư vấn kỹ hơn." 
                                               FontSize="13" Foreground="White" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Button x:Name="BtnContinueBooking" Click="BtnBook_Click" IsEnabled="False" HorizontalAlignment="Stretch" Padding="0,16" Background="White" Foreground="#2563EB" CornerRadius="14" FontWeight="Bold">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="Tiếp tục đặt lịch"/>
                                    <FontIcon Glyph="&#xE76C;" FontSize="12" FontFamily="Segoe Fluent Icons"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Button Click="BtnCancel_Click" HorizontalAlignment="Stretch" Padding="0,14" Background="Transparent" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="14">
                        <TextBlock Text="Bỏ qua" FontSize="14" FontWeight="SemiBold" Foreground="#64748B"/>
                    </Button>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
