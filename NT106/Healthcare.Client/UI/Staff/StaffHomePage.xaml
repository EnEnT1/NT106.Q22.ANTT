<Page
    x:Class="Healthcare.Client.UI.Staff.StaffHomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:Healthcare.Client.Helpers"
    Background="{ThemeResource LayerFillColorDefaultBrush}">

    <Page.Resources>
        <helpers:ShortIdConverter x:Key="ShortIdConverter"/>
        
        <!-- Template cho Lịch hẹn (Staff View) -->
        <DataTemplate x:Key="AppointmentTemplate">
            <Grid Padding="12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <Border Width="40" Height="40" CornerRadius="10" Background="#F0FDF4">
                        <FontIcon Glyph="&#xE787;" FontSize="18" Foreground="#16A34A"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Id, Converter={StaticResource ShortIdConverter}}"
                                   FontSize="14" FontWeight="Bold" Foreground="#16A34A"/>
                        <TextBlock Text="Mã lịch hẹn" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding PatientName}" FontSize="15" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                        <FontIcon Glyph="&#xE77B;" FontSize="10" Foreground="#64748B" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding DoctorName}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="{Binding AppointmentDate, ConverterParameter='dd/MM/yyyy HH:mm'}" FontSize="14" FontWeight="Medium"/>
                    <Border Margin="0,6,0,0" Padding="8,2" HorizontalAlignment="Left" CornerRadius="4" 
                            Background="{Binding StatusBrush}">
                        <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="Bold" Foreground="White" CharacterSpacing="20"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,24,0">
                    <Border Background="#F1F5F9" Padding="12,6" CornerRadius="8">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE80F;" FontSize="12" Foreground="#475569"/>
                            <TextBlock Text="{Binding RoomCode}" FontSize="13" FontWeight="Bold" Foreground="#1e293b"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- Template cho Giao dịch (Staff View) -->
        <DataTemplate x:Key="TransactionTemplate">
            <Grid Padding="12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <Border Width="40" Height="40" CornerRadius="10" Background="#FFF7ED">
                        <FontIcon Glyph="&#xE825;" FontSize="18" Foreground="#EA580C"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Id, Converter={StaticResource ShortIdConverter}}"
                                   FontSize="14" FontWeight="Bold" Foreground="#EA580C"/>
                        <TextBlock Text="Mã giao dịch" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding PatientName}" FontSize="15" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2,0,0">
                        <FontIcon Glyph="&#xE8C7;" FontSize="10" Foreground="#64748B" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding PaymentMethod}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Amount, ConverterParameter='N0'}" FontSize="16" FontWeight="Bold" Foreground="#DC2626"/>
                    <TextBlock Text="VNĐ" FontSize="10" Foreground="#DC2626" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                    <TextBlock Text="{Binding PaidAt, ConverterParameter='dd/MM/yyyy HH:mm'}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold" Foreground="#10B981" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <NavigationView x:Name="StaffNav"
                        PaneDisplayMode="Left"
                        IsSettingsVisible="False"
                        IsBackButtonVisible="Collapsed"
                        ItemInvoked="StaffNav_ItemInvoked"
                        Background="Transparent">

            <NavigationView.PaneHeader>
                <StackPanel Orientation="Horizontal" Padding="20,24,16,16" Spacing="14">
                    <Border Width="36" Height="36" CornerRadius="10">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0891B2" Offset="0.0" />
                                <GradientStop Color="#0E7490" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <FontIcon Glyph="&#xE7E8;" FontSize="18" Foreground="White" />
                    </Border>
                    <TextBlock Text="Receptionist" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" 
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" CharacterSpacing="50"/>
                </StackPanel>
            </NavigationView.PaneHeader>

            <NavigationView.PaneFooter>
                <StackPanel Padding="16,12">
                    <Button x:Name="LogoutBtn" Background="Transparent" BorderThickness="0" Padding="8,12"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Click="LogoutBtn_Click" CornerRadius="8">
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <FontIcon Glyph="&#xE760;" FontSize="16" Foreground="#DC2626"/>
                            <TextBlock Text="Đăng xuất" FontSize="14" Foreground="#DC2626" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </NavigationView.PaneFooter>

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Tiếp nhận Lịch hẹn" Tag="Appointment" Icon="Calendar"/>
                <NavigationViewItem Content="Xử lý Thanh toán" Tag="Transaction" Icon="Calculator"/>
            </NavigationView.MenuItems>

            <Grid Padding="32,28,32,40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header Area -->
                <Grid Margin="0,0,0,24">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="HeaderTitle" Text="Danh sách Lịch hẹn"
                                   FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="Hỗ trợ người bệnh và quản lý luồng phục vụ tại quầy"
                                   FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="12">
                        <AutoSuggestBox x:Name="SearchBox" 
                                        PlaceholderText="Tìm kiếm bệnh nhân..." 
                                        QueryIcon="Find" Width="300" 
                                        VerticalAlignment="Center"
                                        TextChanged="SearchBox_TextChanged"/>
                        <Button Style="{StaticResource AccentButtonStyle}" CornerRadius="8" Padding="16,10" Click="RefreshBtn_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                                <TextBlock Text="Làm mới" FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Data Card Area -->
                <Border Grid.Row="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Column Header -->
                        <Border Grid.Row="0" CornerRadius="12,12,0,0" BorderThickness="0,0,0,1"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                Padding="24,16" Background="#F8FAFC">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="ColHeader0" Grid.Column="0" Text="MÃ SỐ" FontSize="11" FontWeight="Bold" Foreground="#64748B" CharacterSpacing="50"/>
                                <TextBlock x:Name="ColHeader1" Grid.Column="1" Text="THÔNG TIN BỆNH NHÂN" FontSize="11" FontWeight="Bold" Foreground="#64748B" CharacterSpacing="50"/>
                                <TextBlock x:Name="ColHeader2" Grid.Column="2" Text="THỜI GIAN / TRẠNG THÁI" FontSize="11" FontWeight="Bold" Foreground="#64748B" CharacterSpacing="50"/>
                                <TextBlock x:Name="ColHeader3" Grid.Column="3" Text="GHI CHÚ / PHÒNG" FontSize="11" FontWeight="Bold" Foreground="#64748B" CharacterSpacing="50"/>
                            </Grid>
                        </Border>

                        <ListView x:Name="StaffDataGrid"
                                  Grid.Row="1"
                                  SelectionMode="Single"
                                  DoubleTapped="StaffDataGrid_DoubleTapped"
                                  Padding="0,0,0,12">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                                    <Setter Property="BorderThickness" Value="0,1,0,0"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
        </NavigationView>
    </Grid>
</Page>
