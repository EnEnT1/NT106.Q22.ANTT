<Page
    x:Class="Healthcare.Client.UI.Admin.AdminHomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:Healthcare.Client.Helpers"
    Background="{ThemeResource LayerFillColorDefaultBrush}">

    <Page.Resources>
        <helpers:ShortIdConverter x:Key="ShortIdConverter"/>
        
        <!-- Template cho Người dùng (Bệnh nhân/Bác sĩ) -->
        <DataTemplate x:Key="UserTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <Border Width="36" Height="36" CornerRadius="8" Background="#EFF6FF">
                        <FontIcon Glyph="&#xEFA9;" FontSize="16" Foreground="#2563EB"/>
                    </Border>
                    <TextBlock Text="{Binding Id, Converter={StaticResource ShortIdConverter}}"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#2563EB" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding FullName}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                        <FontIcon Glyph="&#xE715;" FontSize="10" Foreground="#10B981" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Email}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ExtraInfo}" FontSize="14" FontWeight="SemiBold" Foreground="#0369A1" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding Phone}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Padding="10,6" Background="#F1F5F9" CornerRadius="6">
                        <TextBlock Text="{Binding CreatedAt}" FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                    </Border>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- Template cho Lịch hẹn -->
        <DataTemplate x:Key="AppointmentTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <Border Width="36" Height="36" CornerRadius="8" Background="#F0FDF4">
                        <FontIcon Glyph="&#xE787;" FontSize="16" Foreground="#16A34A"/>
                    </Border>
                    <TextBlock Text="{Binding Id, Converter={StaticResource ShortIdConverter}}"
                               FontSize="13" FontWeight="SemiBold" Foreground="#16A34A" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding PatientName}" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding DoctorName}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="{Binding AppointmentDate, ConverterParameter='d/M/yyyy'}" FontSize="14"/>
                    <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold" Foreground="#2563EB" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                    <TextBlock Text="{Binding RoomCode}" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <!-- Template cho Giao dịch -->
        <DataTemplate x:Key="TransactionTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <Border Width="36" Height="36" CornerRadius="8" Background="#FFF7ED">
                        <FontIcon Glyph="&#xE825;" FontSize="16" Foreground="#EA580C"/>
                    </Border>
                    <TextBlock Text="{Binding Id, Converter={StaticResource ShortIdConverter}}"
                               FontSize="13" FontWeight="SemiBold" Foreground="#EA580C" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding PatientName}" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding PaymentMethod}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Amount, ConverterParameter='C'}" FontSize="14" FontWeight="Bold" Foreground="#DC2626"/>
                    <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold" Foreground="#10B981" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                    <TextBlock Text="{Binding PaidAt}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <NavigationView x:Name="AdminNav"
                        PaneDisplayMode="Left"
                        IsSettingsVisible="False"
                        IsBackButtonVisible="Collapsed"
                        ItemInvoked="AdminNav_ItemInvoked"
                        Background="Transparent">

            <NavigationView.PaneHeader>
                <StackPanel Orientation="Horizontal" Padding="20,24,16,16" Spacing="14">
                    <Border Width="36" Height="36" CornerRadius="10">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#2563EB" Offset="0.0" />
                                <GradientStop Color="#4F46E5" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <FontIcon Glyph="&#xEA18;" FontSize="18" Foreground="White" />
                    </Border>
                    <TextBlock Text="Admin Portal" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" 
                             Foreground="{ThemeResource TextFillColorPrimaryBrush}" CharacterSpacing="10"/>
                </StackPanel>
            </NavigationView.PaneHeader>

            <NavigationView.PaneFooter>
                <StackPanel Padding="16,12">
                    <Button x:Name="LogoutBtn" Background="Transparent" BorderThickness="0" Padding="8,12"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Click="LogoutBtn_Click" CornerRadius="8">
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <FontIcon Glyph="&#xE760;" FontSize="16" Foreground="#DC2626"/>
                            <TextBlock Text="Đăng xuất" FontSize="14" Foreground="#DC2626" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </NavigationView.PaneFooter>

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Dashboard" Tag="Dashboard" Icon="Home"/>
                <NavigationViewItemSeparator/>
                <NavigationViewItem Content="Quản lý Bệnh nhân" Tag="Patient" Icon="ContactInfo"/>
                <NavigationViewItem Content="Quản lý Bác sĩ" Tag="Doctor" Icon="Contact"/>
                <NavigationViewItem Content="Quản lý Nhân viên" Tag="Staff" Icon="People"/>
                <NavigationViewItemSeparator/>
                <NavigationViewItem Content="Danh sách Lịch hẹn" Tag="Appointment" Icon="Calendar"/>
                <NavigationViewItem Content="Lịch sử Giao dịch" Tag="Transaction" Icon="Calculator"/>
            </NavigationView.MenuItems>

            <Grid Padding="32,28,32,40">
                <Grid x:Name="ListViewPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                <!-- Header Area -->
                <Grid Margin="0,0,0,24">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="HeaderTitle" Text="Quản lý Bệnh nhân"
                                   FontSize="28" FontWeight="Bold"/>
                        <TextBlock Text="Quản lý và cập nhật thông tin hệ thống"
                                   FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    
                    <StackPanel x:Name="ActionButtonsPanel"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="12">
                        <Button x:Name="AddBtn"
                                Style="{StaticResource AccentButtonStyle}"
                                CornerRadius="8"
                                Padding="16,10"
                                Click="AddBtn_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE710;" FontSize="14"/>
                                <TextBlock Text="Thêm mới" FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="EditBtn"
                                Style="{StaticResource DefaultButtonStyle}"
                                Background="#F0F9FF"
                                BorderBrush="#BAE6FD"
                                CornerRadius="8"
                                Padding="16,10"
                                Click="EditBtn_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE70F;" FontSize="14" Foreground="#0284C7"/>
                                <TextBlock Text="Sửa thông tin" FontSize="13" FontWeight="SemiBold" Foreground="#0284C7"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="DeleteBtn"
                                Style="{StaticResource DefaultButtonStyle}"
                                Background="#FEF2F2"
                                BorderBrush="#FECACA"
                                CornerRadius="8"
                                Padding="16,10"
                                Click="DeleteBtn_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="#DC2626"/>
                                <TextBlock Text="Xóa dữ liệu" FontSize="13" FontWeight="SemiBold" Foreground="#DC2626"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- List Card Area -->
                <Border Grid.Row="1"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Column Header Row -->
                        <Border Grid.Row="0"
                                CornerRadius="12,12,0,0"
                                BorderThickness="0,0,0,1"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                Padding="24,16"
                                Background="#F8FAFC">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="ColHeader0" Grid.Column="0" Text="MÃ QUẢN LÝ" FontSize="11" FontWeight="Bold"
                                           Foreground="#64748B" CharacterSpacing="50"/>
                                <TextBlock x:Name="ColHeader1" Grid.Column="1" Text="HỌ TÊN / TRẠNG THÁI LIÊN LẠC" FontSize="11" FontWeight="Bold"
                                           Foreground="#64748B" CharacterSpacing="50"/>
                                <TextBlock x:Name="ColHeader2" Grid.Column="2" Text="SĐT / NĂM SINH" FontSize="11" FontWeight="Bold"
                                           Foreground="#64748B" CharacterSpacing="50"/>
                                <TextBlock x:Name="ColHeader3" Grid.Column="3" Text="NGÀY TẠO HỒ SƠ" FontSize="11" FontWeight="Bold"
                                           Foreground="#64748B" CharacterSpacing="50"/>
                            </Grid>
                        </Border>

                        <!-- Data ListView -->
                        <ListView x:Name="AdminDataGrid"
                                  Grid.Row="1"
                                  SelectionMode="Single"
                                  DoubleTapped="AdminDataGrid_DoubleTapped"
                                  Padding="0,0,0,12">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="24,16"/>
                                    <Setter Property="BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}"/>
                                    <Setter Property="BorderThickness" Value="0,1,0,0"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="3*"/>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                            <Border Width="36" Height="36" CornerRadius="8" Background="#EFF6FF">
                                                <FontIcon Glyph="&#xEFA9;" FontSize="16" Foreground="#2563EB"/>
                                            </Border>
                                            <TextBlock Text="{Binding Id, Converter={StaticResource ShortIdConverter}}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#2563EB"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FullName}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                                                <FontIcon Glyph="&#xE715;" FontSize="10" Foreground="#10B981" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Email}"
                                                           FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Phone}"
                                                       FontSize="14"/>
                                            <TextBlock Text="{Binding DateOfBirth}"
                                                       FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Padding="10,6" Background="#F1F5F9" CornerRadius="6">
                                                <TextBlock Text="{Binding CreatedAt}"
                                                           FontSize="12" FontWeight="SemiBold" Foreground="#475569"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    
                    </Grid>
                </Border>
                </Grid>

                <ScrollViewer x:Name="DashboardPanel" Visibility="Visible" Background="#F8FAFC">
                    <StackPanel Spacing="32" Padding="32,32,32,48">
                        <!-- Header Dashboard -->
                        <Grid>
                            <StackPanel Spacing="6">
                                <TextBlock Text="Tổng quan Hệ thống" FontSize="32" FontWeight="Bold" Foreground="#1E293B"/>
                                <TextBlock Text="Chào mừng quay trở lại! Dưới đây là báo cáo vận hành hôm nay." FontSize="14" Foreground="#64748B"/>
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="White" Padding="16,8" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xEC92;" FontSize="16" Foreground="#2563EB"/>
                                    <TextBlock x:Name="TxtCurrentTime" Text="14/05/2026" FontSize="14" FontWeight="SemiBold" Foreground="#1E293B"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        
                        <!-- Statistics Cards -->
                        <Grid ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Card 1: Doanh thu -->
                            <Border Grid.Column="0" Padding="24" Background="White" CornerRadius="20" BorderBrush="#E2E8F0" BorderThickness="1">
                                <Border.Shadow>
                                    <ThemeShadow />
                                </Border.Shadow>
                                <StackPanel Spacing="16">
                                    <Grid>
                                        <Border Width="48" Height="48" CornerRadius="14" Background="#FFF7ED">
                                            <FontIcon Glyph="&#xE825;" FontSize="20" Foreground="#EA580C"/>
                                        </Border>
                                        <TextBlock Text="+12%" FontSize="12" FontWeight="Bold" Foreground="#16A34A" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,0,0"/>
                                    </Grid>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Doanh thu tháng" FontSize="14" FontWeight="Medium" Foreground="#64748B"/>
                                        <TextBlock x:Name="TxtMonthlyRevenue" Text="0 đ" FontSize="28" FontWeight="Bold" Foreground="#1E293B"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            
                            <!-- Card 2: Lượt khám -->
                            <Border Grid.Column="1" Padding="24" Background="White" CornerRadius="20" BorderBrush="#E2E8F0" BorderThickness="1">
                                <StackPanel Spacing="16">
                                    <Grid>
                                        <Border Width="48" Height="48" CornerRadius="14" Background="#F0FDF4">
                                            <FontIcon Glyph="&#xE787;" FontSize="20" Foreground="#16A34A"/>
                                        </Border>
                                        <TextBlock Text="Hôm nay" FontSize="12" FontWeight="Bold" Foreground="#2563EB" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,0,0"/>
                                    </Grid>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Lượt khám trong ngày" FontSize="14" FontWeight="Medium" Foreground="#64748B"/>
                                        <TextBlock x:Name="TxtTodayAppointments" Text="0" FontSize="28" FontWeight="Bold" Foreground="#1E293B"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Card 3: Bệnh nhân mới -->
                            <Border Grid.Column="2" Padding="24" Background="White" CornerRadius="20" BorderBrush="#E2E8F0" BorderThickness="1">
                                <StackPanel Spacing="16">
                                    <Grid>
                                        <Border Width="48" Height="48" CornerRadius="14" Background="#EFF6FF">
                                            <FontIcon Glyph="&#xEFA9;" FontSize="20" Foreground="#2563EB"/>
                                        </Border>
                                        <Border Background="#DBEAFE" Padding="6,2" CornerRadius="6" HorizontalAlignment="Right" VerticalAlignment="Top">
                                            <TextBlock Text="New" FontSize="10" FontWeight="Bold" Foreground="#2563EB"/>
                                        </Border>
                                    </Grid>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Bệnh nhân mới" FontSize="14" FontWeight="Medium" Foreground="#64748B"/>
                                        <TextBlock x:Name="TxtNewPatients" Text="0" FontSize="28" FontWeight="Bold" Foreground="#1E293B"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                        
                        <Grid>
                            <!-- Biểu đồ thu nhỏ (Bản rộng) -->
                            <Border Padding="28" Background="White" CornerRadius="24" BorderBrush="#E2E8F0" BorderThickness="1">
                                <StackPanel Spacing="24">
                                    <Grid>
                                        <TextBlock Text="Xu hướng Tăng trưởng Hệ thống" FontSize="18" FontWeight="Bold" Foreground="#1E293B"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="16">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Ellipse Width="8" Height="8" Fill="#2563EB"/>
                                                <TextBlock Text="Doanh thu" FontSize="12" Foreground="#64748B"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Ellipse Width="8" Height="8" Fill="#10B981"/>
                                                <TextBlock Text="Bệnh nhân" FontSize="12" Foreground="#64748B"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <Grid Height="320" Background="#F1F5F9" CornerRadius="12">
                                        <!-- Visual Representation of a chart -->
                                        <Canvas HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                            <Polyline Points="0,240 100,180 200,200 300,140 400,160 500,80 600,100 700,40" Stroke="#2563EB" StrokeThickness="4" Canvas.Left="40" Canvas.Top="40"/>
                                            <Polyline Points="0,280 100,260 200,220 300,240 400,180 500,200 600,150 700,130" Stroke="#10B981" StrokeThickness="4" Canvas.Left="40" Canvas.Top="40"/>
                                        </Canvas>
                                        <TextBlock Text="LiveCharts2 Engine Loading..." 
                                                   HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,24"
                                                   FontSize="12" Foreground="#94A3B8" FontWeight="Medium"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </NavigationView>
    </Grid>
</Page>