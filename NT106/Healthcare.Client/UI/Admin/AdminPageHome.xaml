<Page
    x:Class="Healthcare.Client.UI.Admin.AdminHomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    RequestedTheme="Light">

    <Grid Background="#F8F9FA">
        <NavigationView x:Name="AdminNav"
                        PaneDisplayMode="Left"
                        IsSettingsVisible="False"
                        IsBackButtonVisible="Collapsed"
                        ItemInvoked="AdminNav_ItemInvoked">

            <NavigationView.PaneHeader>
                <StackPanel Orientation="Horizontal" Padding="16,12,16,12">
                    <Button x:Name="LogoutBtn" Background="Transparent" BorderThickness="0" Padding="0" Click="LogoutBtn_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE760;" FontSize="16" Foreground="#333"/>
                            <TextBlock Text="Đăng xuất" FontSize="14" Opacity="0.7" Foreground="#333" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </NavigationView.PaneHeader>

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Quản lý Bệnh nhân" Tag="Patient" Icon="ContactInfo"/>
                <NavigationViewItem Content="Quản lý Bác sĩ" Tag="Doctor" Icon="Contact"/>
                <NavigationViewItemSeparator/>
                <NavigationViewItem Content="Danh sách Lịch hẹn" Tag="Appointment" Icon="Calendar"/>
                <NavigationViewItem Content="Lịch sử Giao dịch" Tag="Transaction" Icon="Calculator"/>
            </NavigationView.MenuItems>

            <Grid Padding="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Margin="0,0,0,16">
                    <TextBlock x:Name="HeaderTitle" Text="Quản lý Bệnh nhân"
                               FontSize="28" FontWeight="Bold"
                               Foreground="#191C1D"
                               HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    <StackPanel x:Name="ActionButtonsPanel"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right" Spacing="10">
                        <Button x:Name="AddBtn" Content="+ Thêm mới"
                                Background="#0059BB" Foreground="White" FontWeight="SemiBold"
                                Width="120" Height="38" CornerRadius="6"
                                Click="AddBtn_Click"/>
                        <Button x:Name="DeleteBtn" Content="🗑 Xóa dòng"
                                Background="#D32F2F" Foreground="White" FontWeight="SemiBold"
                                Width="110" Height="38" CornerRadius="6"
                                Click="DeleteBtn_Click"/>
                    </StackPanel>
                </Grid>

                <!-- Column Header Row -->
                <Border Grid.Row="1"
                        Background="#E8EEF7"
                        CornerRadius="8,8,0,0"
                        BorderThickness="1,1,1,0"
                        BorderBrush="#CBD5E1"
                        Padding="16,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="MÃ" FontSize="11" FontWeight="Black"
                                   Foreground="#475569" CharacterSpacing="60"/>
                        <TextBlock Grid.Column="1" Text="HỌ TÊN / EMAIL" FontSize="11" FontWeight="Black"
                                   Foreground="#475569" CharacterSpacing="60"/>
                        <TextBlock Grid.Column="2" Text="SĐT / NĂM SINH" FontSize="11" FontWeight="Black"
                                   Foreground="#475569" CharacterSpacing="60"/>
                        <TextBlock Grid.Column="3" Text="NGÀY TẠO" FontSize="11" FontWeight="Black"
                                   Foreground="#475569" CharacterSpacing="60"/>
                    </Grid>
                </Border>

                <!-- Data ListView -->
                <Border Grid.Row="2"
                        BorderThickness="1"
                        BorderBrush="#CBD5E1"
                        CornerRadius="0,0,8,8">
                    <ListView x:Name="AdminDataGrid"
                              SelectionMode="Single"
                              Background="White"
                              DoubleTapped="AdminDataGrid_DoubleTapped">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="16,10"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Id}"
                                               FontSize="12" Foreground="#1E293B"
                                               VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FullName}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#1E293B"/>
                                        <TextBlock Text="{Binding Email}"
                                                   FontSize="11" Foreground="#64748B"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Phone}"
                                                   FontSize="12" Foreground="#1E293B"/>
                                        <TextBlock Text="{Binding DateOfBirth}"
                                                   FontSize="11" Foreground="#64748B"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding CreatedAt}"
                                               FontSize="11" Foreground="#94A3B8"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>
            </Grid>
        </NavigationView>
    </Grid>
</Page>