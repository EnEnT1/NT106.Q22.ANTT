<Page
    x:Class="Healthcare.Client.UI.Components.VideoCallWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#1A1A1A">

    <Grid>
        <MediaPlayerElement x:Name="RemoteVideo" AutoPlay="True" Stretch="UniformToFill"/>

        <Border Width="240" Height="160" VerticalAlignment="Bottom" HorizontalAlignment="Right" 
                Margin="24" CornerRadius="12" BorderBrush="White" BorderThickness="2">
            <MediaPlayerElement x:Name="LocalVideo" AutoPlay="True" Stretch="UniformToFill"/>
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" 
                    Margin="0,0,0,40" Spacing="20">
            <Button x:Name="BtnMic" Content="" FontFamily="Segoe MDL2 Assets" Width="60" Height="60" 
                    CornerRadius="30" Background="#33FFFFFF" Foreground="White" Click="BtnMic_Click"/>
            <Button x:Name="BtnEndCall" Content="" FontFamily="Segoe MDL2 Assets" Width="80" Height="60" 
                    CornerRadius="30" Background="#FF4444" Foreground="White" Click="BtnEndCall_Click"/>
            <Button x:Name="BtnCamera" Content="" FontFamily="Segoe MDL2 Assets" Width="60" Height="60" 
                    CornerRadius="30" Background="#33FFFFFF" Foreground="White" Click="BtnCamera_Click"/>
        </StackPanel>

        <TextBlock x:Name="TxtStatus" Text="Đang kết nối Video..." Foreground="White" 
                   HorizontalAlignment="Left" VerticalAlignment="Top" Margin="20" FontSize="16"/>
    </Grid>
</Page>