<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Healthcare.Client.UI.Components.NotificationPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Healthcare.Client.UI.Components"
    mc:Ignorable="d"
    MinWidth="380"
    MaxWidth="420">

    <UserControl.Resources>

        <!-- ── Color Brushes ── -->
        <SolidColorBrush x:Key="PrimaryBrush"               Color="#0059BB"/>
        <SolidColorBrush x:Key="PrimaryContainerBrush"      Color="#D8E2FF"/>
        <SolidColorBrush x:Key="SecondaryContainerBrush"    Color="#BFD9FD"/>
        <SolidColorBrush x:Key="OnSecondaryContainerBrush"  Color="#455F7D"/>
        <SolidColorBrush x:Key="TertiaryBrush"              Color="#B6171E"/>
        <SolidColorBrush x:Key="TertiaryContainerBrush"     Color="#FFDAD6"/>
        <SolidColorBrush x:Key="SurfaceBrush"               Color="#F8F9FA"/>
        <SolidColorBrush x:Key="SurfaceContainerLowBrush"   Color="#F3F4F5"/>
        <SolidColorBrush x:Key="OutlineVariantBrush"        Color="#C1C6D7"/>
        <SolidColorBrush x:Key="OnSurfaceBrush"             Color="#191C1D"/>
        <SolidColorBrush x:Key="OnSurfaceVariantBrush"      Color="#414754"/>
        <SolidColorBrush x:Key="WarningBrush"               Color="#FFF3CD"/>
        <SolidColorBrush x:Key="WarningFgBrush"             Color="#856404"/>

        <!-- ── Unread dot indicator style ── -->
        <Style x:Key="UnreadDotStyle" TargetType="Ellipse">
            <Setter Property="Width"  Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Fill"   Value="#0059BB"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <!-- ── Item hover style ── -->
        <Style x:Key="NotificationItemStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding"          Value="0"/>
            <Setter Property="BorderThickness"  Value="0,0,0,1"/>
            <Setter Property="BorderBrush"      Value="#12C1C6D7"/>
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Grid x:Name="Root" Background="{TemplateBinding Background}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root"
                                                                           Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#0CF3F4F5"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root"
                                                                           Storyboard.TargetProperty="Background">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#1ABFD9FD"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- ══════════════════════════════════════════════════════════════
         Root container – white card with subtle shadow
    ══════════════════════════════════════════════════════════════════ -->
    <Border
        Background="White"
        CornerRadius="14"
        BorderBrush="#18C1C6D7"
        BorderThickness="1">
        <Border.Shadow>
            <ThemeShadow/>
        </Border.Shadow>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="Auto"/>
                <!-- Filter tabs -->
                <RowDefinition Height="*"/>
                <!-- List -->
                <RowDefinition Height="Auto"/>
                <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- ══ Header ══ -->
            <Grid Grid.Row="0" Padding="20,18,12,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title + unread count badge -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock
                        Text="Thông báo"
                        FontFamily="Segoe UI Variable Display"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="#191C1D"/>
                    <Border
                        x:Name="UnreadBadge"
                        Background="#0059BB"
                        CornerRadius="10"
                        Padding="7,2"
                        VerticalAlignment="Center">
                        <TextBlock
                            x:Name="UnreadCountText"
                            Text="3"
                            FontFamily="Segoe UI Variable Text"
                            FontSize="11"
                            FontWeight="SemiBold"
                            Foreground="White"/>
                    </Border>
                </StackPanel>

                <!-- Mark all read -->
                <Button
                    Grid.Column="1"
                    x:Name="MarkAllReadButton"
                    Content="Đánh dấu tất cả"
                    FontFamily="Segoe UI Variable Text"
                    FontSize="12"
                    Foreground="#0059BB"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="6,4"
                    CornerRadius="6"
                    VerticalAlignment="Center"
                    Click="MarkAllRead_Click"/>

                <!-- Settings button -->
                <Button
                    Grid.Column="2"
                    Width="32" Height="32"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    CornerRadius="16"
                    ToolTipService.ToolTip="Cài đặt thông báo"
                    Click="NotificationSettings_Click">
                    <FontIcon Glyph="&#xE713;" FontSize="14" Foreground="#414754"/>
                </Button>
            </Grid>

            <!-- ══ Filter Tabs ══ -->
            <Border
                Grid.Row="1"
                BorderBrush="#12C1C6D7"
                BorderThickness="0,1,0,1"
                Background="#FAFAFA"
                Padding="16,0">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <!-- Tab: Tất cả -->
                    <RadioButton
                        x:Name="TabAll"
                        Content="Tất cả"
                        GroupName="NotifTab"
                        IsChecked="True"
                        FontFamily="Segoe UI Variable Text"
                        FontSize="13"
                        Checked="Tab_Checked"
                        Tag="All"
                        Padding="12,10"
                        Style="{StaticResource DefaultRadioButtonStyle}">
                        <RadioButton.Resources>
                            <Style TargetType="RadioButton">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border
                                                x:Name="Root"
                                                Padding="{TemplateBinding Padding}"
                                                CornerRadius="0"
                                                BorderThickness="0,0,0,2"
                                                BorderBrush="Transparent">
                                                <VisualStateManager.VisualStateGroups>
                                                    <VisualStateGroup x:Name="CheckStates">
                                                        <VisualState x:Name="Checked">
                                                            <Storyboard>
                                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="BorderBrush">
                                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="#0059BB"/>
                                                                </ObjectAnimationUsingKeyFrames>
                                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Label" Storyboard.TargetProperty="Foreground">
                                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="#0059BB"/>
                                                                </ObjectAnimationUsingKeyFrames>
                                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Label" Storyboard.TargetProperty="FontWeight">
                                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="SemiBold"/>
                                                                </ObjectAnimationUsingKeyFrames>
                                                            </Storyboard>
                                                        </VisualState>
                                                        <VisualState x:Name="Unchecked"/>
                                                    </VisualStateGroup>
                                                </VisualStateManager.VisualStateGroups>
                                                <TextBlock
                                                    x:Name="Label"
                                                    Text="{TemplateBinding Content}"
                                                    FontFamily="Segoe UI Variable Text"
                                                    FontSize="13"
                                                    Foreground="#414754"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </RadioButton.Resources>
                    </RadioButton>

                    <!-- Tab: Chưa đọc -->
                    <RadioButton
                        x:Name="TabUnread"
                        Content="Chưa đọc"
                        GroupName="NotifTab"
                        FontFamily="Segoe UI Variable Text"
                        FontSize="13"
                        Checked="Tab_Checked"
                        Tag="Unread"
                        Padding="12,10"
                        Style="{StaticResource DefaultRadioButtonStyle}">
                        <RadioButton.Resources>
                            <Style TargetType="RadioButton">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="RadioButton">
                                            <Border
                                                x:Name="Root"
                                                Padding="{TemplateBinding Padding}"
                                                CornerRadius="0"
                                                BorderThickness="0,0,0,2"
                                                BorderBrush="Transparent">
                                                <VisualStateManager.VisualStateGroups>
                                                    <VisualStateGroup x:Name="CheckStates">
                                                        <VisualState x:Name="Checked">
                                                            <Storyboard>
                                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Root" Storyboard.TargetProperty="BorderBrush">
                                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="#0059BB"/>
                                                                </ObjectAnimationUsingKeyFrames>
                                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Label" Storyboard.TargetProperty="Foreground">
                                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="#0059BB"/>
                                                                </ObjectAnimationUsingKeyFrames>
                                                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Label" Storyboard.TargetProperty="FontWeight">
                                                                    <DiscreteObjectKeyFrame KeyTime="0" Value="SemiBold"/>
                                                                </ObjectAnimationUsingKeyFrames>
                                                            </Storyboard>
                                                        </VisualState>
                                                        <VisualState x:Name="Unchecked"/>
                                                    </VisualStateGroup>
                                                </VisualStateManager.VisualStateGroups>
                                                <TextBlock
                                                    x:Name="Label"
                                                    Text="{TemplateBinding Content}"
                                                    FontFamily="Segoe UI Variable Text"
                                                    FontSize="13"
                                                    Foreground="#414754"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </RadioButton.Resources>
                    </RadioButton>
                </StackPanel>
            </Border>

            <!-- ══ Notification List ══ -->
            <ScrollViewer
                Grid.Row="2"
                MaxHeight="460"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">

                <StackPanel>
                    <!-- Empty state -->
                    <StackPanel
                        x:Name="EmptyStatePanel"
                        Visibility="Collapsed"
                        HorizontalAlignment="Center"
                        Spacing="10"
                        Padding="0,40">
                        <FontIcon Glyph="&#xEA8F;" FontSize="36" Foreground="#C1C6D7" HorizontalAlignment="Center"/>
                        <TextBlock
                            Text="Không có thông báo"
                            FontFamily="Segoe UI Variable Text"
                            FontSize="14"
                            Foreground="#414754"
                            HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Items List -->
                    <ListView
                        x:Name="NotificationsListView"
                        SelectionMode="None"
                        IsItemClickEnabled="True"
                        ItemContainerStyle="{StaticResource NotificationItemStyle}"
                        ItemClick="NotificationItem_Click">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:NotificationViewModel">
                                <Grid
                                    Padding="16,14"
                                    ColumnSpacing="12"
                                    Background="{x:Bind RowBackground}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- Icon -->
                                        <ColumnDefinition Width="*"/>
                                        <!-- Content -->
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- Unread dot -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Category Icon Badge -->
                                    <Border
                                        Grid.Column="0"
                                        Width="40" Height="40"
                                        CornerRadius="12"
                                        Background="{x:Bind IconBackground}"
                                        VerticalAlignment="Top">
                                        <FontIcon
                                            Glyph="{x:Bind IconGlyph}"
                                            FontSize="18"
                                            Foreground="{x:Bind IconForeground}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Text Content -->
                                    <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                        <TextBlock
                                            Text="{x:Bind Title}"
                                            FontFamily="Segoe UI Variable Text"
                                            FontSize="13"
                                            FontWeight="{x:Bind TitleWeight}"
                                            Foreground="#191C1D"
                                            TextWrapping="Wrap"/>
                                        <TextBlock
                                            Text="{x:Bind Body}"
                                            FontFamily="Segoe UI Variable Text"
                                            FontSize="12"
                                            Foreground="#414754"
                                            TextWrapping="Wrap"
                                            MaxLines="2"
                                            TextTrimming="CharacterEllipsis"/>
                                        <TextBlock
                                            Text="{x:Bind TimeAgo}"
                                            FontFamily="Segoe UI Variable Text"
                                            FontSize="11"
                                            Foreground="#717786"/>
                                    </StackPanel>

                                    <!-- Unread indicator dot -->
                                    <Ellipse
                                        Grid.Column="2"
                                        Style="{StaticResource UnreadDotStyle}"
                                        Visibility="{x:Bind UnreadDotVisibility}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </ScrollViewer>

            <!-- ══ Footer ══ -->
            <Border
                Grid.Row="3"
                BorderBrush="#12C1C6D7"
                BorderThickness="0,1,0,0"
                Padding="16,12">
                <Button
                    x:Name="ViewAllButton"
                    HorizontalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="12,6"
                    CornerRadius="8"
                    Click="ViewAll_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock
                            Text="Xem tất cả thông báo"
                            FontFamily="Segoe UI Variable Text"
                            FontSize="13"
                            FontWeight="Medium"
                            Foreground="#0059BB"/>
                        <FontIcon Glyph="&#xE76C;" FontSize="12" Foreground="#0059BB"/>
                    </StackPanel>
                </Button>
            </Border>

        </Grid>
    </Border>
</UserControl>
