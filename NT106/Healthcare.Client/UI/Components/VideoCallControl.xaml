<UserControl
    x:Class="Healthcare.Client.UI.Components.VideoCallControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d">

    <Grid>

        <Border
            Background="Black"
            CornerRadius="16">

            <Grid>

                <!-- Waiting -->
                <Border
                    x:Name="WaitingPlaceholder"
                    Background="#1E293B"
                    CornerRadius="16">

                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="16">

                        <FontIcon
                            FontFamily="Segoe MDL2 Assets"
                            Glyph="&#xE77B;"
                            FontSize="80"
                            Foreground="#334155"
                            HorizontalAlignment="Center"/>

                        <TextBlock
                            x:Name="TxtWaitingStatus"
                            Text="Đang chờ kết nối..."
                            FontSize="15"
                            Foreground="#64748B"
                            HorizontalAlignment="Center"/>

                        <ProgressRing
                            x:Name="ConnectingRing"
                            Width="32"
                            Height="32"
                            IsActive="False"
                            Foreground="#0059BB"
                            HorizontalAlignment="Center"/>

                    </StackPanel>

                </Border>

                <!-- Daily.co -->
                <controls:WebView2
                    x:Name="VideoWebView"
                    Visibility="Collapsed"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"/>

                <!-- Badge -->
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Left"
                    Margin="20,20,0,0">

                    <Border
                        x:Name="LiveBadge"
                        Visibility="Collapsed"
                        Background="#1D4ED820"
                        CornerRadius="8"
                        BorderThickness="1"
                        BorderBrush="#3B82F640"
                        Padding="12,5">

                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="8">

                            <Ellipse
                                Width="8"
                                Height="8"
                                Fill="#22C55E"
                                VerticalAlignment="Center"/>

                            <TextBlock
                                x:Name="TxtDuration"
                                Text="LIVE 00:00"
                                FontSize="11"
                                FontWeight="Bold"
                                Foreground="White"
                                CharacterSpacing="100"/>

                        </StackPanel>

                    </Border>

                    <Border
                        x:Name="QualityBadge"
                        Visibility="Collapsed"
                        Background="#66000000"
                        CornerRadius="8"
                        Padding="10,5">

                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="6">

                            <FontIcon
                                FontFamily="Segoe MDL2 Assets"
                                Glyph="&#xEC3F;"
                                FontSize="13"
                                Foreground="White"/>

                            <TextBlock
                                x:Name="TxtQuality"
                                Text="HD Quality"
                                FontSize="10"
                                FontWeight="SemiBold"
                                Foreground="White"/>

                        </StackPanel>

                    </Border>

                </StackPanel>

                <!-- Bottom Controls -->
                <Border
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,24"
                    Background="#66000000"
                    CornerRadius="40"
                    BorderThickness="1"
                    BorderBrush="#22FFFFFF"
                    Padding="24,12">

                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="16">

                        <!-- Mic -->
                        <Button
                            x:Name="BtnMic"
                            Width="48"
                            Height="48"
                            Click="BtnMic_Click"
                            Background="#66000000"
                            BorderThickness="0">

                            <FontIcon
                                x:Name="IconMic"
                                FontFamily="Segoe MDL2 Assets"
                                Glyph="&#xE720;"
                                FontSize="20"
                                Foreground="White"/>

                        </Button>

                        <!-- Speaker -->
                        <Button
                            x:Name="BtnSpeaker"
                            Width="48"
                            Height="48"
                            Click="BtnSpeaker_Click"
                            Background="#66000000"
                            BorderThickness="0">

                            <FontIcon
                                x:Name="IconSpeaker"
                                FontFamily="Segoe MDL2 Assets"
                                Glyph="&#xE767;"
                                FontSize="20"
                                Foreground="White"/>

                        </Button>

                        <!-- End -->
                        <Button
                            x:Name="BtnEndCall"
                            Width="56"
                            Height="56"
                            Click="BtnEndCall_Click"
                            Background="#DC2626"
                            BorderThickness="0">

                            <FontIcon
                                FontFamily="Segoe MDL2 Assets"
                                Glyph="&#xE717;"
                                FontSize="24"
                                Foreground="White"/>

                        </Button>

                        <!-- Camera -->
                        <Button
                            x:Name="BtnCamera"
                            Width="48"
                            Height="48"
                            Click="BtnCamera_Click"
                            Background="#66000000"
                            BorderThickness="0">

                            <FontIcon
                                x:Name="IconCamera"
                                FontFamily="Segoe MDL2 Assets"
                                Glyph="&#xE714;"
                                FontSize="20"
                                Foreground="White"/>

                        </Button>

                        <!-- More -->
                        <Button
                            x:Name="BtnMore"
                            Width="48"
                            Height="48"
                            Click="BtnMore_Click"
                            Background="#66000000"
                            BorderThickness="0">

                            <FontIcon
                                x:Name="IconMore"
                                FontFamily="Segoe MDL2 Assets"
                                Glyph="&#xE712;"
                                FontSize="20"
                                Foreground="White"/>

                        </Button>

                    </StackPanel>

                </Border>

            </Grid>

        </Border>

    </Grid>

</UserControl>