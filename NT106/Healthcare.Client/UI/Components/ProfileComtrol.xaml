<UserControl
    x:Class="Healthcare.Client.UI.Components.ProfileControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="18">

            <TextBlock Text="Thông tin cá nhân"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#1E293B"/>

            <Border Background="White"
                    CornerRadius="16"
                    Padding="20"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">

                <StackPanel Spacing="14">

                    <TextBlock Text="Thông tin cơ bản"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#0059BB"/>

                    <Grid ColumnSpacing="16" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Họ tên:"
                                   FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   x:Name="FullNameText"
                                   Text="Đang tải..."/>

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="Email:"
                                   FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   x:Name="EmailText"
                                   Text="Đang tải..."/>

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Số điện thoại:"
                                   FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   x:Name="PhoneText"
                                   Text="Đang tải..."/>

                        <TextBlock Grid.Row="3" Grid.Column="0"
                                   Text="Vai trò:"
                                   FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="3" Grid.Column="1"
                                   x:Name="RoleText"
                                   Text="Đang tải..."/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border x:Name="PatientPanel"
                    Background="#F8FAFC"
                    CornerRadius="16"
                    Padding="20"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    Visibility="Collapsed">

                <StackPanel Spacing="14">
                    <TextBlock Text="Thông tin dành cho bệnh nhân"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#059669"/>

                    <TextBlock Text="Bạn có thể theo dõi hồ sơ bệnh án, lịch sử khám, chỉ số sức khỏe và kết quả xét nghiệm trong các mục dành cho bệnh nhân."
                               TextWrapping="Wrap"
                               Foreground="#334155"/>
                </StackPanel>
            </Border>

            <Border x:Name="DoctorPanel"
                    Background="#F8FAFC"
                    CornerRadius="16"
                    Padding="20"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    Visibility="Collapsed">

                <StackPanel Spacing="14">
                    <TextBlock Text="Thông tin dành cho bác sĩ"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#7C3AED"/>

                    <TextBlock Text="Bạn có thể quản lý lịch khám, xem bệnh nhân chờ khám, tra cứu tiền sử bệnh nhân và xem kết quả khám trong các mục dành cho bác sĩ."
                               TextWrapping="Wrap"
                               Foreground="#334155"/>
                </StackPanel>
            </Border>

            <Border x:Name="AdminPanel"
                    Background="#F8FAFC"
                    CornerRadius="16"
                    Padding="20"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    Visibility="Collapsed">

                <StackPanel Spacing="14">
                    <TextBlock Text="Thông tin dành cho quản trị viên"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#DC2626"/>

                    <TextBlock Text="Bạn có quyền quản lý người dùng và theo dõi hoạt động hệ thống."
                               TextWrapping="Wrap"
                               Foreground="#334155"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>