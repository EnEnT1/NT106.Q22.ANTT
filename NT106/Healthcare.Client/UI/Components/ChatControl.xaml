<UserControl
    x:Class="Healthcare.Client.UI.Components.ChatControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <FontIcon FontFamily="Segoe MDL2 Assets"
                          Glyph="&#xE8F2;"
                          FontSize="16"
                          Foreground="#0059BB"/>
                <StackPanel Spacing="2">
                    <TextBlock Text="Hộp thoại tư vấn"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="#1E293B"/>
                    <TextBlock x:Name="TxtSubtitle"
                               Text="Trao đổi trực tiếp trong cuộc khám"
                               FontSize="11"
                               Foreground="#64748B"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Message list -->
        <ScrollViewer x:Name="ChatScrollViewer"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="12,8">
            <StackPanel x:Name="MessageList" Spacing="6"/>
        </ScrollViewer>

        <!-- Input area -->
        <Border Grid.Row="2"
                Background="#F8FAFC"
                BorderBrush="#E5E7EB"
                BorderThickness="0,1,0,0"
                Padding="12">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="ChatInput"
                         Grid.Column="0"
                         PlaceholderText="Nhập tin nhắn..."
                         KeyDown="ChatInput_KeyDown"
                         MinHeight="42"
                         TextWrapping="Wrap"
                         AcceptsReturn="False"
                         CornerRadius="10"
                         BorderBrush="#E5E7EB"/>

                <Button x:Name="BtnSend"
                        Grid.Column="1"
                        Click="BtnSend_Click"
                        Background="#0059BB"
                        Foreground="White"
                        BorderThickness="0"
                        CornerRadius="10"
                        Padding="14,10">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="Segoe MDL2 Assets"
                                  Glyph="&#xE724;"
                                  FontSize="13"
                                  Foreground="White"/>
                        <TextBlock Text="Gửi"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>