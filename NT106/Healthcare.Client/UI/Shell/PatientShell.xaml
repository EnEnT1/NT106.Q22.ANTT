<Page
    x:Class="Healthcare.Client.UI.Shell.PatientShell"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Healthcare.Client.UI.Shell"
    xmlns:comp="using:Healthcare.Client.UI.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource AppBackdropGradientBrush}">

    <Page.Resources>
        <!-- Color Resources -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2D6CDF"/>
        <SolidColorBrush x:Key="PrimaryLightBrush" Color="#EFF4FD"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FCFDFE"/>
        <SolidColorBrush x:Key="OnSurfaceBrush" Color="#1A1C1E"/>
        <SolidColorBrush x:Key="OnSurfaceVariantBrush" Color="#5A606E"/>
        <SolidColorBrush x:Key="SlateGray50" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="SlateGray100" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="SlateGray400" Color="#94A3B8"/>
        <SolidColorBrush x:Key="SlateGray500" Color="#64748B"/>
        <SolidColorBrush x:Key="SlateGray800" Color="#1E293B"/>
        <SolidColorBrush x:Key="SlateGray900" Color="#0F172A"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#EF4444"/>
        <SolidColorBrush x:Key="BorderSubtleBrush" Color="#F1F5F9"/>

        <!-- NavItem Style (Inactive) -->
        <Style x:Key="NavItemButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="BackgroundBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{TemplateBinding CornerRadius}"/>
                            <ContentPresenter HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              Padding="{TemplateBinding Padding}"/>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="BackgroundBorder.Background" Value="#F8FAFC"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="BackgroundBorder.Background" Value="#F1F5F9"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- NavItem Style (Active) -->
        <Style x:Key="NavItemActiveStyle" TargetType="Button" BasedOn="{StaticResource NavItemButtonStyle}">
            <Setter Property="Background" Value="#EFF4FD"/>
            <Setter Property="Foreground" Value="#2D6CDF"/>
        </Style>

        <!-- Icon Button Style -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <!-- FAB Button Style: giữ màu xanh khi hover/pressed -->
        <Style x:Key="FABButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2D6CDF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="64"/>
            <Setter Property="Height" Value="64"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="RootBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <Border.RenderTransform>
                                    <ScaleTransform x:Name="ScaleTransform" ScaleX="1" ScaleY="1"
                                                    CenterX="32" CenterY="32"/>
                                </Border.RenderTransform>
                            </Border>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <!-- Giữ màu xanh, chỉ tối nhẹ -->
                                        <VisualState.Setters>
                                            <Setter Target="RootBorder.Background" Value="#2563C9"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="RootBorder.Background" Value="#1D55B0"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="RootBorder.Background" Value="#94A3B8"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar: 288px -->
            <ColumnDefinition Width="288"/>
            <!-- Main area -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════ -->
        <!--                  SIDEBAR                  -->
        <!-- ══════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource ShellSidebarAcrylicBrush}"
                BorderBrush="#D0E4FF"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Logo -->
                    <RowDefinition Height="Auto"/>  <!-- Profile -->
                    <RowDefinition Height="*"/>     <!-- Nav Items -->
                    <RowDefinition Height="Auto"/>  <!-- Logout -->
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="14"
                            Margin="24,40,24,32">
                    <Border Width="44" Height="44" CornerRadius="12"
                            Background="{StaticResource PrimaryBrush}">
                        <FontIcon Glyph="&#xE95E;" Foreground="White" FontSize="20"
                                  FontFamily="Segoe Fluent Icons"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Spacing="0">
                        <TextBlock Text="Clinical" FontSize="16" FontWeight="ExtraBold"
                                   Foreground="{StaticResource SlateGray900}"
                                   LineHeight="20"/>
                        <TextBlock Text="Sanctuary" FontSize="16" FontWeight="ExtraBold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   LineHeight="20"/>
                    </StackPanel>
                </StackPanel>

                <!-- Patient Profile Card -->
                <Border Grid.Row="1" Margin="16,0,16,32"
                        Background="{StaticResource GlassCardAcrylicBrush}"
                        CornerRadius="16"
                        Translation="0,0,4"
                        Shadow="{StaticResource HealthcareThemeShadow}">
                    <StackPanel Orientation="Horizontal" Spacing="16" Padding="16">
                        <PersonPicture x:Name="PatientAvatar" Width="44" Height="44"
                                       Initials="BA"/>
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <TextBlock x:Name="TxtPatientName" Text="Bệnh Nhân A" FontSize="13" FontWeight="Bold"
                                       Foreground="{StaticResource SlateGray800}"/>
                            <TextBlock x:Name="TxtPatientID" Text="ID: 12345678" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource SlateGray400}"
                                       CharacterSpacing="50"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Navigation Items -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Auto">
                    <StackPanel Spacing="4" Margin="16,0">
                        <!-- Home (Active) -->
                        <Button x:Name="NavHome" Style="{StaticResource NavItemActiveStyle}"
                                Click="NavHome_Click">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <FontIcon x:Name="NavHomeIcon" Glyph="&#xE80F;" FontSize="18" Foreground="#2D6CDF"
                                          FontFamily="Segoe Fluent Icons"/>
                                <TextBlock x:Name="NavHomeText" Text="Trang chủ" FontSize="14" FontWeight="Bold"
                                           Foreground="#2D6CDF" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Appointment -->
                        <Button x:Name="NavAppointment" Style="{StaticResource NavItemButtonStyle}"
                                Click="NavAppointment_Click">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <FontIcon Glyph="&#xE787;" FontSize="18"
                                          FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="Đặt lịch khám" FontSize="14"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Records -->
                        <Button x:Name="NavRecords" Style="{StaticResource NavItemButtonStyle}"
                                Click="NavRecords_Click">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <FontIcon Glyph="&#xE8A5;" FontSize="18"
                                          FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="Hồ sơ bệnh án" FontSize="14"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Payment -->
                        <Button x:Name="NavPayment" Style="{StaticResource NavItemButtonStyle}"
                                Click="NavPayment_Click">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <FontIcon Glyph="&#xE8A1;" FontSize="18"
                                          FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="Thanh toán" FontSize="14"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Health Metrics -->
                        <Button x:Name="NavHealthMetrics" Style="{StaticResource NavItemButtonStyle}"
                                Click="NavHealthMetrics_Click">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <FontIcon Glyph="&#xE9F9;" FontSize="18"
                                          FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="Chỉ số sức khỏe" FontSize="14"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Online Consultation -->
                        <Button x:Name="NavOnline" Style="{StaticResource NavItemButtonStyle}"
                                Click="NavOnline_Click">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <FontIcon Glyph="&#xE8AA;" FontSize="18"
                                          FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="Khám trực tuyến" FontSize="14"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavUploadPrescription" Style="{StaticResource NavItemButtonStyle}"
                                Click="NavUploadPrescription_Click">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <FontIcon Glyph="&#xE8E5;" FontSize="18"
                                          FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="Nhập đơn thuốc AI" FontSize="14"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>

                <!-- Logout -->
                <Border Grid.Row="3" Margin="0,0,0,16">
                    <Button Margin="16,0" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent" BorderThickness="0"
                            Padding="16,14" CornerRadius="16"
                            Click="LogoutBtn_Click">
                        <StackPanel Orientation="Horizontal" Spacing="14">
                            <FontIcon Glyph="&#xF3B1;" FontSize="18"
                                      Foreground="{StaticResource ErrorBrush}"
                                      FontFamily="Segoe Fluent Icons"/>
                            <TextBlock Text="Đăng xuất" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource ErrorBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════ -->
        <!--             RIGHT SIDE (TopBar + Content) -->
        <!-- ══════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>   <!-- TopBar -->
                <RowDefinition Height="*"/>    <!-- Page Content -->
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════ -->
            <!--                 TOP BAR               -->
            <!-- ══════════════════════════════════════ -->
            <Border Grid.Row="0"
                    Background="{StaticResource ShellTopBarAcrylicBrush}"
                    BorderBrush="#D0E4FF"
                    BorderThickness="0,0,0,1">
                <Grid Margin="40,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MaxWidth="480"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search Box -->
                    <AutoSuggestBox Grid.Column="0"
                                    PlaceholderText="Tìm kiếm bác sĩ, chuyên khoa..."
                                    VerticalAlignment="Center"
                                    QueryIcon="Find"
                                    CornerRadius="16"
                                    Background="{StaticResource SlateGray100}"/>

                    <!-- Date Badge -->
                    <Border Grid.Column="1" HorizontalAlignment="Right" Margin="0,0,24,0"
                            Background="{StaticResource GlassCardAcrylicBrush}" CornerRadius="16"
                            Padding="16,8"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="1"
                            Translation="0,0,2"
                            Shadow="{StaticResource HealthcareThemeShadow}">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE787;" FontSize="16"
                                      Foreground="{StaticResource PrimaryBrush}"
                                      FontFamily="Segoe Fluent Icons"/>
                            <TextBlock x:Name="DateTextBlock"
                                       Text="Thứ Hai, 24/05/2024"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource SlateGray500}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                                VerticalAlignment="Center">
                        <!-- Notification Bell Button with Flyout -->
                        <Button x:Name="NotificationBellButton" Style="{StaticResource IconButtonStyle}">
                            <Button.Flyout>
                                <Flyout Placement="BottomEdgeAlignedRight">
                                    <Flyout.FlyoutPresenterStyle>
                                        <Style TargetType="FlyoutPresenter">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="CornerRadius" Value="14"/>
                                            <Setter Property="MinWidth" Value="0"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </Style>
                                    </Flyout.FlyoutPresenterStyle>
                                    <comp:NotificationPanel x:Name="NotifPanel"/>
                                </Flyout>
                            </Button.Flyout>
                            <Grid>
                                <FontIcon Glyph="&#xEA8F;" FontSize="20"
                                          Foreground="{StaticResource SlateGray500}"
                                          FontFamily="Segoe Fluent Icons"/>
                                <!-- Unread badge -->
                                <Border x:Name="NotifBadge"
                                        Background="#EF4444"
                                        CornerRadius="8"
                                        MinWidth="16" Height="16"
                                        Padding="4,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="0,-4,-4,0">
                                    <TextBlock x:Name="NotifBadgeText"
                                               Text="3" FontSize="9" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>
                        <!-- Settings Button -->
                        <Button Style="{StaticResource IconButtonStyle}">
                            <FontIcon Glyph="&#xE713;" FontSize="20"
                                      Foreground="{StaticResource SlateGray500}"
                                      FontFamily="Segoe Fluent Icons"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════ -->
            <!--         PAGE CONTENT (Frame)          -->
            <!-- ══════════════════════════════════════ -->
            <Frame x:Name="ContentFrame" Grid.Row="1" Background="Transparent"/>
        </Grid>

        <!-- Floating Action Button (Chat) -->
        <Button Grid.Column="1"
                Style="{StaticResource FABButtonStyle}"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,40,40"
                Translation="0,0,8"
                Shadow="{StaticResource HealthcareThemeShadow}">
            <FontIcon Glyph="&#xE8BD;" FontSize="26" Foreground="White"
                      FontFamily="Segoe Fluent Icons"/>
        </Button>
    </Grid>
</Page>
