<Page
    x:Class="Healthcare.Client.UI.Shell.DoctorShell"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Healthcare.Client.UI.Shell"
    xmlns:comp="using:Healthcare.Client.UI.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource AppBackdropGradientBrush}">

    <Page.Resources>
        <!-- Doctor accent: teal-blue -->
        <SolidColorBrush x:Key="PrimaryBrush"           Color="#0078D4"/>
        <SolidColorBrush x:Key="PrimaryLightBrush"      Color="#EBF4FF"/>
        <SolidColorBrush x:Key="SurfaceBrush"           Color="#FCFDFE"/>
        <SolidColorBrush x:Key="OnSurfaceBrush"         Color="#1A1C1E"/>
        <SolidColorBrush x:Key="OnSurfaceVariantBrush"  Color="#5A606E"/>
        <SolidColorBrush x:Key="SlateGray50"            Color="#F8FAFC"/>
        <SolidColorBrush x:Key="SlateGray100"           Color="#F1F5F9"/>
        <SolidColorBrush x:Key="SlateGray400"           Color="#94A3B8"/>
        <SolidColorBrush x:Key="SlateGray500"           Color="#64748B"/>
        <SolidColorBrush x:Key="SlateGray800"           Color="#1E293B"/>
        <SolidColorBrush x:Key="SlateGray900"           Color="#0F172A"/>
        <SolidColorBrush x:Key="ErrorBrush"             Color="#EF4444"/>
        <SolidColorBrush x:Key="BorderSubtleBrush"      Color="#D0E8FF"/>

        <!-- Nav Item: inactive -->
        <Style x:Key="NavItemButtonStyle" TargetType="Button">
            <Setter Property="Background"               Value="Transparent"/>
            <Setter Property="Foreground"               Value="#64748B"/>
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="HorizontalAlignment"      Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                  Value="16,14"/>
            <Setter Property="CornerRadius"             Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="BackgroundBorder"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{TemplateBinding CornerRadius}"/>
                            <ContentPresenter HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              Padding="{TemplateBinding Padding}"/>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="BackgroundBorder.Background" Value="#EBF4FF"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="BackgroundBorder.Background" Value="#D6ECFF"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Nav Item: active -->
        <Style x:Key="NavItemActiveStyle" TargetType="Button" BasedOn="{StaticResource NavItemButtonStyle}">
            <Setter Property="Background" Value="#EBF4FF"/>
            <Setter Property="Foreground" Value="#0078D4"/>
        </Style>

        <!-- Icon-only round button (TopBar) -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"           Value="40"/>
            <Setter Property="Height"          Value="40"/>
            <Setter Property="CornerRadius"    Value="12"/>
            <Setter Property="Padding"         Value="0"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="288"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- SIDEBAR                                                  -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,1,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#EBF6FF" Offset="0"/>
                    <GradientStop Color="#E5EEFF" Offset="0.5"/>
                    <GradientStop Color="#EEF0FF" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Logo -->
                    <RowDefinition Height="Auto"/>  <!-- Profile card -->
                    <RowDefinition Height="*"/>     <!-- Nav items -->
                    <RowDefinition Height="Auto"/>  <!-- Logout -->
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="14"
                            Margin="24,40,24,32">
                    <Border Width="44" Height="44" CornerRadius="12"
                            Background="{StaticResource PrimaryBrush}">
                        <FontIcon Glyph="&#xE95E;" Foreground="White" FontSize="20"
                                  FontFamily="Segoe Fluent Icons"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Spacing="0">
                        <TextBlock Text="Clinical" FontSize="16" FontWeight="ExtraBold"
                                   Foreground="{StaticResource SlateGray900}"
                                   LineHeight="20"/>
                        <TextBlock Text="Sanctuary" FontSize="16" FontWeight="ExtraBold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   LineHeight="20"/>
                    </StackPanel>
                </StackPanel>

                <!-- Doctor Profile Card -->
                <Border Grid.Row="1" Margin="16,0,16,32"
                        Background="{StaticResource GlassCardAcrylicBrush}"
                        CornerRadius="16"
                        Translation="0,0,4"
                        Shadow="{StaticResource HealthcareThemeShadow}">
                    <StackPanel Orientation="Horizontal" Spacing="16" Padding="16">
                        <PersonPicture x:Name="DoctorAvatar" Width="44" Height="44"
                                       DisplayName="Bác sĩ"/>
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <TextBlock x:Name="TxtDoctorName"
                                       Text="Bác sĩ"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource SlateGray800}"/>
                            <TextBlock x:Name="TxtDepartment"
                                       Text="Khoa Nội Tổng Quát"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource SlateGray400}"
                                       CharacterSpacing="30"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Navigation Items -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Auto">
                    <StackPanel Spacing="4" Margin="16,0">

                        <Button x:Name="NavHome" Style="{StaticResource NavItemActiveStyle}"
                                Click="NavHome_Click">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <FontIcon Glyph="&#xE80F;" FontSize="18" Foreground="#0078D4"
                                          FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="Trang chủ" FontSize="14" FontWeight="Bold"
                                           Foreground="#0078D4" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavSchedule" Style="{StaticResource NavItemButtonStyle}"
                                Click="NavSchedule_Click">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <FontIcon Glyph="&#xE787;" FontSize="18"
                                          FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="Quản lý lịch khám" FontSize="14"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavPatients" Style="{StaticResource NavItemButtonStyle}"
                                Click="NavPatients_Click">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <FontIcon Glyph="&#xE9F9;" FontSize="18"
                                          FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="Danh sách bệnh nhân" FontSize="14"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="NavRevenue" Style="{StaticResource NavItemButtonStyle}"
                                Click="NavRevenue_Click">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <FontIcon Glyph="&#xE9D2;" FontSize="18"
                                          FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="Thống kê" FontSize="14"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>

                <!-- Logout -->
                <Border Grid.Row="3" Margin="0,0,0,16">
                    <Button Margin="16,0"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="16,14"
                            CornerRadius="16"
                            Click="LogoutBtn_Click">
                        <StackPanel Orientation="Horizontal" Spacing="14">
                            <FontIcon Glyph="&#xF3B1;" FontSize="18"
                                      Foreground="{StaticResource ErrorBrush}"
                                      FontFamily="Segoe Fluent Icons"/>
                            <TextBlock Text="Đăng xuất" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource ErrorBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- RIGHT SIDE                                               -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="80"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TOP BAR -->
            <Border Grid.Row="0"
                    Background="{StaticResource ShellTopBarAcrylicBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="0,0,0,1">
                <Grid Margin="40,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MaxWidth="480"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <AutoSuggestBox Grid.Column="0"
                                    PlaceholderText="Tìm kiếm bệnh nhân, hồ sơ..."
                                    VerticalAlignment="Center"
                                    QueryIcon="Find"
                                    CornerRadius="16"
                                    Background="{StaticResource SlateGray100}"/>

                    <!-- Date + Shift chip -->
                    <Border Grid.Column="1"
                            HorizontalAlignment="Right"
                            Margin="0,0,24,0"
                            Background="White"
                            CornerRadius="16"
                            Padding="16,8"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="1"
                            Translation="0,0,2"
                            Shadow="{StaticResource HealthcareThemeShadow}">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE787;" FontSize="16"
                                      Foreground="{StaticResource PrimaryBrush}"
                                      FontFamily="Segoe Fluent Icons"/>
                            <StackPanel VerticalAlignment="Center" Spacing="1">
                                <TextBlock x:Name="TxtDate"
                                           Text="Thứ Hai, 24/05/2026"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource SlateGray500}"/>
                                <TextBlock x:Name="TxtShift"
                                           Text="CA TRỰC: SÁNG"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           CharacterSpacing="50"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4"
                                VerticalAlignment="Center">
                        <!-- Notification Bell Button with Flyout -->
                        <Button x:Name="BtnNotification" Style="{StaticResource IconButtonStyle}" ToolTipService.ToolTip="Thông báo">
                            <Button.Flyout>
                                <Flyout Placement="BottomEdgeAlignedRight">
                                    <Flyout.FlyoutPresenterStyle>
                                        <Style TargetType="FlyoutPresenter">
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="CornerRadius" Value="14"/>
                                            <Setter Property="MinWidth" Value="0"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </Style>
                                    </Flyout.FlyoutPresenterStyle>
                                    <comp:NotificationPanel x:Name="NotifPanel"
                                                             UnreadCountChanged="NotifPanel_UnreadCountChanged"
                                                             NavigationRequested="NotifPanel_NavigationRequested"/>
                                </Flyout>
                            </Button.Flyout>
                            <Grid>
                                <FontIcon Glyph="&#xEA8F;" FontSize="20"
                                          Foreground="{StaticResource SlateGray500}"
                                          FontFamily="Segoe Fluent Icons"/>
                                <!-- Unread badge -->
                                <Border x:Name="NotifBadge"
                                        Background="#EF4444"
                                        CornerRadius="8"
                                        MinWidth="16" Height="16"
                                        Padding="4,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="0,-4,-4,0"
                                        Visibility="Collapsed">
                                    <TextBlock x:Name="NotifBadgeText"
                                               Text="0" FontSize="9" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>
                        <!-- Settings -->
                        <Button x:Name="BtnSettings" Style="{StaticResource IconButtonStyle}"
                                Click="BtnSettings_Click"
                                ToolTipService.ToolTip="Cài đặt">
                            <FontIcon Glyph="&#xE713;" FontSize="20"
                                      Foreground="{StaticResource SlateGray500}"
                                      FontFamily="Segoe Fluent Icons"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Frame x:Name="ContentFrame" Grid.Row="1"/>
        </Grid>
    </Grid>
</Page>